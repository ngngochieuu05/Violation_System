<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ComplianceHub</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
            body {
                font-family: 'Inter', sans-serif;
                background-color: #F8F9FA;
                color: #111827;
            }
            /* Cấu trúc bo góc 8px và bóng đổ Level 1 theo Design System */
            .system-card {
                background-color: #FFFFFF;
                border-radius: 8px;
                border: 1px solid #E5E7EB;
                box-shadow: rgba(0, 0, 0, 0.03) 0px 4px 10px 0px, rgba(0, 0, 0, 0.06) 0px 0px 2px 0px, rgba(0, 0, 0, 0.12) 0px 2px 6px 0px;
            }
            /* Các màu sắc vẫn giữ nguyên bản sắc Đỏ/Slate như bạn muốn */
            .nav-item.active {
                background-color: #FEF2F2;
                color: #DC2626;
                font-weight: 600;
                border-right: 3px solid #DC2626;
            }

            .nav-item {
                color: #64748B;
                font-weight: 500;
                transition: all 0.2s;
            }

                .nav-item:hover {
                    background-color: #F1F5F9;
                    color: #0F172A;
                }
    </style>
</head>
<body class="flex h-screen overflow-hidden">

    <aside class="w-64 bg-white border-r border-slate-200 flex flex-col">
        <div class="h-16 flex items-center px-6 border-b border-slate-100">
            <i class="fa-solid fa-shield-halved text-2xl text-red-600 mr-3"></i>
            <span class="font-bold text-lg text-slate-800">Doanh nghiệp</span>
        </div>
        <nav class="flex-1 overflow-y-auto py-4">
            <a href="@Url.Action("Index", "Manager")" class="nav-item @(ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "") flex items-center px-6 py-3 text-sm">
                <i class="fa-solid fa-house w-6 text-center mr-2"></i> Trang chủ
            </a>
            <a href="@Url.Action("WorkSessions", "Manager")" class="nav-item @(ViewContext.RouteData.Values["Action"].ToString() == "WorkSessions" ? "active" : "") flex items-center px-6 py-3 text-sm">
                <i class="fa-solid fa-clock-rotate-left w-6 text-center mr-2"></i> QL Phiên làm việc
            </a>
            <a href="@Url.Action("Approvals", "Manager")" class="nav-item @(ViewContext.RouteData.Values["Action"].ToString() == "Approvals" ? "active" : "") flex items-center px-6 py-3 text-sm">
                <i class="fa-solid fa-file-signature w-6 text-center mr-2"></i> QL Xét duyệt
            </a>
            <a href="@Url.Action("Forms", "Manager")" class="nav-item @(ViewContext.RouteData.Values["Action"].ToString() == "Forms" ? "active" : "") flex items-center px-6 py-3 text-sm">
                <i class="fa-solid fa-folder-open w-6 text-center mr-2"></i> QL Biểu mẫu
            </a>
        </nav>
        <div class="p-4 border-t border-slate-100">
            <a href="@Url.Action("Logout", "Account")" class="flex items-center justify-center w-full py-2.5 text-sm text-slate-500 hover:bg-red-50 hover:text-red-600 rounded-md transition font-medium">
                <i class="fa-solid fa-right-from-bracket mr-2"></i> Đăng xuất
            </a>
        </div>
    </aside>

    <div class="flex-1 flex overflow-hidden">
        <main class="flex-1 overflow-y-auto p-8 bg-slate-50">
            <div class="max-w-[1440px] mx-auto">
                @RenderBody()
            </div>
        </main>

        <aside class="w-80 bg-white border-l border-slate-200 overflow-y-auto p-6 flex flex-col">
            <div class="text-center mb-6">
                <div class="w-20 h-20 bg-slate-100 rounded-full mx-auto mb-3 flex items-center justify-center text-slate-400 text-3xl">
                    <i class="fa-solid fa-user-tie"></i>
                </div>
                <h3 class="font-bold text-lg text-slate-900">@User.FindFirst("FullName")?.Value</h3>
                <p class="text-sm text-slate-500">@User.Identity?.Name</p>
            </div>

            <div class="space-y-4 flex-1">
                <div>
                    <label class="block text-xs font-semibold text-slate-600 mb-1">Họ tên</label>
                    <input type="text" value="@User.FindFirst("FullName")?.Value" class="w-full text-sm p-2 bg-slate-50 border border-slate-200 rounded-[8px] outline-none" readonly />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-600 mb-1">Quyền hạn</label>
                    <input type="text" value="@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value" class="w-full text-sm p-2 bg-slate-50 border border-slate-200 rounded-[8px] outline-none text-red-600 font-medium" readonly />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-600 mb-1">Email liên hệ</label>
                    <input type="email" placeholder="Nhập email..." class="w-full text-sm p-2 border border-slate-200 rounded-[8px] outline-none focus:border-red-500 transition" />
                </div>
            </div>

            <button class="w-full mt-6 py-2.5 bg-red-600 hover:bg-red-700 text-white rounded-[8px] text-sm font-semibold transition shadow-md shadow-red-600/20">
                Lưu thông tin
            </button>
        </aside>
    </div>
</body>
</html>