<section data-tab-panel="attendance" class="employee-tab-panel hidden">
    <!-- Top Summary Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="saas-card p-4 flex flex-col justify-between">
            <div class="flex items-center justify-between text-slate-400 mb-2">
                <span class="saas-label">Mã nhân viên</span>
                <i class="fa-solid fa-id-card text-red-500"></i>
            </div>
            <p class="font-outfit text-lg font-bold text-slate-900 truncate" data-profile-id>@User.Identity?.Name</p>
        </div>
        
        <div class="saas-card p-4 flex flex-col justify-between">
            <div class="flex items-center justify-between text-slate-400 mb-2">
                <span class="saas-label">Phòng ban</span>
                <i class="fa-solid fa-sitemap text-blue-500"></i>
            </div>
            <p class="font-outfit text-base font-bold text-slate-900 truncate" data-profile-department>...</p>
        </div>
        
        <div class="saas-card p-4 flex flex-col justify-between">
            <div class="flex items-center justify-between text-slate-400 mb-2">
                <span class="saas-label">Ca làm việc</span>
                <i class="fa-solid fa-business-time text-amber-500"></i>
            </div>
            <p class="font-outfit text-base font-bold text-slate-900">08:00 - 17:00</p>
        </div>
        
        <div class="saas-card p-4 flex flex-col justify-between">
            <div class="flex items-center justify-between text-slate-400 mb-2">
                <span class="saas-label">Chấm công ngày</span>
                <i class="fa-solid fa-fingerprint text-emerald-500"></i>
            </div>
            <div class="flex items-center gap-1.5">
                <span class="h-2 w-2 rounded-full bg-amber-500" id="attendanceStatusDot"></span>
                <p class="font-outfit text-sm font-bold text-slate-900" id="attendanceStatusText">Chưa Check-in</p>
            </div>
        </div>
    </div>

    <!-- Main Action Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-6">
        <!-- Cột trái: Xác thực -->
        <div class="lg:col-span-8 flex flex-col gap-6">
            <div class="saas-card p-6 flex-1 flex flex-col">
                <div class="mb-6">
                    <h3 class="saas-heading text-xl">Điểm danh bằng khuôn mặt</h3>
                    <p class="text-sm text-slate-500 mt-1">Sử dụng camera thiết bị để xác thực danh tính nhanh chóng.</p>
                </div>
                
                <div class="flex-1 flex flex-col justify-center">
                    <div class="grid sm:grid-cols-2 gap-4">
                        <button type="button" data-attendance-action-trigger="checkin" class="flex flex-col items-center justify-center p-5 rounded-2xl bg-red-600 text-white shadow-sm hover:bg-red-700 transition active:scale-95 group">
                            <i class="fa-solid fa-right-to-bracket text-2xl mb-2 group-hover:-translate-y-1 transition-transform"></i>
                            <span class="font-bold">Check-in</span>
                        </button>
                        <button type="button" data-attendance-action-trigger="checkout" class="flex flex-col items-center justify-center p-5 rounded-2xl bg-white border border-slate-200 text-slate-700 shadow-sm hover:bg-slate-50 hover:border-slate-300 transition active:scale-95 group">
                            <i class="fa-solid fa-right-from-bracket text-2xl mb-2 group-hover:translate-x-1 transition-transform text-slate-400"></i>
                            <span class="font-bold">Check-out</span>
                        </button>
                    </div>
                </div>

                <div class="mt-6 p-4 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-between">
                    <div>
                        <p class="saas-label">Tài khoản xác thực</p>
                        <p class="font-bold text-slate-900 mt-1" data-attendance-username>@User.Identity?.Name</p>
                    </div>
                    <div class="text-right">
                        <p class="saas-label">Hệ thống</p>
                        <p class="text-sm text-emerald-600 font-semibold mt-1"><i class="fa-solid fa-circle-check mr-1"></i>Sẵn sàng</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cột phải: Camera preview -->
        <div class="lg:col-span-4 flex flex-col gap-6">
            <div class="saas-card p-5 flex-1 flex flex-col">
                <h3 class="saas-heading text-base mb-4">Ảnh chụp gần nhất</h3>
                <div class="flex-1 rounded-xl overflow-hidden bg-slate-100 border border-slate-200 flex items-center justify-center relative min-h-[200px]">
                    <img data-attendance-preview class="hidden absolute inset-0 w-full h-full object-cover" alt="Ảnh xác thực chấm công" />
                    <div data-attendance-preview-empty class="text-slate-400 text-sm flex flex-col items-center gap-2">
                        <i class="fa-solid fa-image text-2xl"></i>
                        <span>Chưa có ảnh</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Overview & History -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-4 flex flex-col gap-4">
            <!-- Tổng quan hôm nay -->
            <div class="saas-card p-5">
                <h3 class="saas-heading text-base mb-4">Tổng quan hôm nay</h3>
                <div class="space-y-4">
                    <div class="flex justify-between items-center pb-3 border-b border-slate-100">
                        <span class="text-sm text-slate-500">Giờ vào</span>
                        <span class="font-outfit font-bold text-slate-900" data-attendance-checkin>--:--</span>
                    </div>
                    <div class="flex justify-between items-center pb-3 border-b border-slate-100">
                        <span class="text-sm text-slate-500">Giờ ra</span>
                        <span class="font-outfit font-bold text-slate-900" data-attendance-checkout>--:--</span>
                    </div>
                    <div class="flex justify-between items-center pb-3 border-b border-slate-100">
                        <span class="text-sm text-slate-500">Tổng giờ làm</span>
                        <span class="font-outfit font-bold text-emerald-600" data-attendance-total>00h 00m</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-slate-500">Trạng thái</span>
                        <span class="font-medium text-amber-600 text-sm" data-attendance-status>Chưa check-in</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-8">
            <div class="saas-card p-6 h-full flex flex-col">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="saas-heading text-lg">Lịch sử chấm công</h3>
                    <span class="text-xs text-slate-400">Hôm nay</span>
                </div>
                <div class="flex-1 space-y-3" data-attendance-history>
                    <!-- Injected by JS -->
                    <div class="rounded-xl border border-slate-100 bg-slate-50 p-4 text-center text-sm text-slate-500">
                        Chưa có lịch sử chấm công
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Camera Modal -->
    <div data-attendance-camera-modal class="fixed inset-0 z-[1200] hidden items-center justify-center p-4 backdrop-blur-sm" style="background-color: rgba(15, 23, 42, 0.7);">
        <div class="w-full max-w-md overflow-hidden rounded-[20px] bg-white shadow-2xl">
            <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4">
                <h3 class="font-outfit text-base font-bold text-slate-900" data-attendance-camera-title>Xác thực khuôn mặt</h3>
                <button type="button" data-attendance-camera-close class="text-slate-400 hover:text-slate-600 transition">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>
            </div>
            <div class="relative aspect-[4/3] bg-black">
                <video data-attendance-video autoplay muted playsinline class="h-full w-full object-cover transform -scale-x-100"></video>
                <canvas data-attendance-canvas class="hidden"></canvas>
                <div data-attendance-scanline class="absolute left-0 top-0 hidden h-[2px] w-full bg-gradient-to-r from-transparent via-red-500 to-transparent shadow-[0_0_10px_#dc2626]"></div>
                <div data-attendance-camera-status class="absolute inset-0 flex flex-col items-center justify-center bg-slate-900/80 p-5 text-center text-white hidden">
                    <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-white/20">
                        <i class="fa-solid fa-spinner fa-spin text-lg"></i>
                    </div>
                    <p class="text-sm font-semibold" data-attendance-camera-status-text>Đang khởi tạo camera...</p>
                </div>
            </div>
            <div class="p-5">
                <p class="mb-4 text-center text-xs text-slate-500" data-attendance-camera-message>
                    Vui lòng nhìn thẳng vào camera và nhấn nút bên dưới.
                </p>
                <button type="button" data-attendance-camera-capture class="w-full rounded-xl bg-red-600 px-5 py-3 text-sm font-bold text-white shadow-sm hover:bg-red-700 transition active:scale-95 flex items-center justify-center">
                    <i class="fa-solid fa-camera mr-2"></i>Chụp ảnh & Xác thực
                </button>
            </div>
        </div>
    </div>

    <!-- Attendance Detail Modal -->
    <div data-attendance-detail-modal class="fixed inset-0 z-[1100] hidden items-center justify-center overflow-y-auto p-4 backdrop-blur-sm" style="background-color: rgba(15, 23, 42, 0.5); -webkit-overflow-scrolling: touch;">
        <div data-attendance-detail-content class="relative my-auto flex w-full max-w-2xl flex-col overflow-hidden rounded-[20px] border border-red-100 bg-white shadow-2xl" style="max-height: min(88vh, 920px);">
            <div data-attendance-detail-header class="flex-none flex items-center justify-between border-b border-red-100 bg-red-600 px-5 py-4 text-white select-none cursor-grab">
                <h3 class="font-outfit text-base font-bold tracking-wide">Chi tiết phiên làm việc</h3>
                <button type="button" data-attendance-detail-close class="flex h-7 w-7 items-center justify-center rounded-lg bg-white/15 transition hover:bg-white/25">
                    <i class="fa-solid fa-xmark text-sm"></i>
                </button>
            </div>

            <div class="min-h-0 flex-1 overflow-y-auto overscroll-contain p-5" style="max-height: calc(88vh - 76px); -webkit-overflow-scrolling: touch; scrollbar-gutter: stable;">
                <div class="flex flex-col space-y-5">
                    <!-- Session Info -->
                    <div class="grid grid-cols-2 gap-4">
                        <div class="rounded-xl border border-emerald-100 bg-emerald-50 p-4">
                            <p class="saas-label text-emerald-600">Tổng thời gian</p>
                            <p class="mt-1 font-outfit text-2xl font-bold text-slate-900" data-attendance-detail-duration>00h 00m</p>
                        </div>
                        <div class="rounded-xl border border-amber-100 bg-amber-50 p-4">
                            <p class="saas-label text-amber-600">Ngày làm việc</p>
                            <p class="mt-1 text-base font-bold text-slate-900" data-attendance-detail-date>--</p>
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                        <p class="saas-label text-slate-500">Trạng thái</p>
                        <p class="mt-1 text-base font-bold text-slate-900" data-attendance-detail-status>--</p>
                    </div>

                    <!-- Images -->
                    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                        <p class="saas-label text-slate-500">Ảnh Check-in</p>
                        <p class="mt-1 text-base font-bold text-slate-900" data-attendance-detail-checkin>--</p>
                        <div class="mt-3 overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm" style="position: relative; padding-top: 56.25%;">
                            <img data-attendance-detail-checkin-image class="hidden absolute top-0 left-0 h-full w-full object-cover" alt="Ảnh check-in" />
                            <div data-attendance-detail-checkin-empty class="flex absolute top-0 left-0 h-full w-full items-center justify-center text-xs text-slate-400">
                                Không có ảnh check-in
                            </div>
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                        <p class="saas-label text-slate-500">Ảnh Check-out</p>
                        <p class="mt-1 text-base font-bold text-slate-900" data-attendance-detail-checkout>--</p>
                        <div class="mt-3 overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm" style="position: relative; padding-top: 56.25%;">
                            <img data-attendance-detail-checkout-image class="hidden absolute top-0 left-0 h-full w-full object-cover" alt="Ảnh check-out" />
                            <div data-attendance-detail-checkout-empty class="flex absolute top-0 left-0 h-full w-full items-center justify-center text-xs text-slate-400">
                                Chưa có ảnh check-out
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
