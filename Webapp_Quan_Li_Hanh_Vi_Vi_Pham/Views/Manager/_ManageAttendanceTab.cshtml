<div data-tab-panel="attendance" class="hidden space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="font-outfit text-2xl font-bold text-slate-900">Quản lý Chấm công</h2>
            <p class="text-sm text-slate-500 mt-1">Theo dõi giờ vào ra và phiên làm việc của nhân viên.</p>
        </div>
        <div class="flex gap-2">
            <input type="date" class="border border-slate-200 rounded-lg px-3 py-2 text-sm text-slate-600 focus:outline-none focus:border-red-300">
            <button onclick="window.location.href='/Manager/ExportWorkSessionsCsv'" class="bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 px-4 py-2 rounded-lg text-sm font-medium transition shadow-sm flex items-center">
                <i class="fa-solid fa-download mr-2"></i>Xuất phiên làm việc
            </button>
        </div>
    </div>

    <div class="saas-card bg-white">
        <div class="p-4 border-b border-slate-100 bg-slate-50/50 rounded-t-2xl">
            <h3 class="font-bold text-slate-800"><i class="fa-solid fa-clock-rotate-left text-slate-400 mr-2"></i>Lịch sử Phiên làm việc</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-slate-600">
                <thead class="text-xs uppercase bg-slate-50 text-slate-500 border-b border-slate-200">
                    <tr>
                        <th class="p-4 py-3 font-bold">Mã NV</th>
                        <th class="p-4 py-3 font-bold">Ngày</th>
                        <th class="p-4 py-3 font-bold">Giờ vào</th>
                        <th class="p-4 py-3 font-bold">Giờ ra</th>
                        <th class="p-4 py-3 font-bold">Trạng thái</th>
                    </tr>
                </thead>
                <tbody id="workSessionTbody">
                    <!-- Dữ liệu sẽ được load qua JS -->
                    <tr><td colspan="5" class="p-8 text-center text-slate-400">Đang tải dữ liệu...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
