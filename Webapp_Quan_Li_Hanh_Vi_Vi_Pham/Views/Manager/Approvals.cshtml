@model IEnumerable<Webapp_Quan_Li_Hanh_Vi_Vi_Pham.Models.Manager.ApprovalRequest>
@{
    ViewData["Title"] = "QL Xét duyệt"; Layout = "_ManagerLayout";
}

<div class="space-y-6">
    <div class="flex justify-between items-center">
        <div><h1 class="text-2xl font-bold text-slate-900">Quản lý xét duyệt</h1></div>
    </div>
    <div class="system-card overflow-hidden">
        <table class="w-full text-left text-sm">
            <thead class="bg-slate-50 text-slate-600 font-semibold border-b border-slate-200">
                <tr><th class="px-6 py-3">Người gửi</th><th class="px-6 py-3">Yêu cầu</th><th class="px-6 py-3">Nội dung</th><th class="px-6 py-3 text-right">Thao tác</th></tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50/50">
                            <td class="px-6 py-4 font-medium">@item.EmployeeName</td>
                            <td class="px-6 py-4">@item.RequestType</td>
                            <td class="px-6 py-4 truncate max-w-xs">@item.Content</td>
                            <td class="px-6 py-4 text-right space-x-2">
                                @if (item.Status == "Chờ duyệt")
                                {
                                    <button class="px-3 py-1.5 bg-[#3F51B5] text-white rounded-[4px] text-xs font-medium">Duyệt</button>
                                    <button class="px-3 py-1.5 bg-slate-200 text-slate-700 rounded-[4px] text-xs font-medium">Từ chối</button>
                                }
                                else
                                {

                                    <span class="px-3 py-1 bg-slate-100 text-slate-500 rounded-[4px] text-xs font-medium">@item.Status</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="4" class="px-6 py-8 text-center text-slate-500">Chưa có đơn từ nào cần duyệt.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>