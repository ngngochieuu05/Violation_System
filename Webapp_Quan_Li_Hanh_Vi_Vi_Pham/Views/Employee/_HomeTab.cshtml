<section data-tab-panel="home" class="employee-tab-panel grid gap-8 xl:grid-cols-[1.35fr_0.95fr]">
    <div class="space-y-8">
        <div class="employee-surface rounded-[30px] border border-slate-200/70 bg-white p-6 shadow-sm sm:p-8">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <p class="text-xs font-bold uppercase tracking-[0.24em] text-red-500">Trang chủ</p>
                    <h3 class="employee-text mt-2 font-outfit text-2xl font-bold text-slate-900">Thông tin nhanh trong ngày</h3>
                </div>
                <span class="inline-flex items-center rounded-full bg-green-50 px-3 py-1 text-xs font-semibold text-green-700">
                    <span class="mr-2 h-2 w-2 rounded-full bg-green-500"></span>
                    Phiên làm việc ổn định
                </span>
            </div>
            <div class="mt-6 grid gap-4 md:grid-cols-3">
                <div class="employee-muted rounded-2xl bg-slate-50 p-5">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Ngày hiện tại</p>
                    <p class="employee-text mt-3 font-outfit text-2xl font-bold text-slate-900" data-home-date>--/--/----</p>
                </div>
                <div class="employee-muted rounded-2xl bg-slate-50 p-5">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Thời gian</p>
                    <p class="employee-text mt-3 font-outfit text-2xl font-bold text-slate-900" data-home-time>--:--:--</p>
                </div>
                <div class="employee-muted rounded-2xl bg-slate-50 p-5">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Ca làm việc</p>
                    <p class="employee-text mt-3 font-outfit text-2xl font-bold text-slate-900">08:00 - 17:00</p>
                </div>
            </div>
        </div>
    </div>

    <div class="space-y-8">
        <div class="employee-surface rounded-[30px] border border-slate-200/70 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-4">
                <div class="employee-avatar-placeholder relative flex h-16 w-16 items-center justify-center overflow-hidden rounded-3xl bg-red-50 text-red-600">
                    <img data-avatar-image class="hidden absolute inset-0 h-full w-full object-cover z-10" alt="Avatar employee" />
                    <i data-avatar-fallback class="fa-solid fa-user text-2xl z-0"></i>
                </div>
                <div>
                    <p class="employee-text font-outfit text-2xl font-bold text-slate-900" data-home-name>@User.FindFirst("FullName")?.Value</p>
                    <p class="employee-subtext text-sm text-slate-500" data-home-username>@User.Identity?.Name</p>
                </div>
            </div>
            <div class="mt-6 space-y-4">
                <div class="employee-muted rounded-2xl bg-slate-50 p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Mã nhân viên</p>
                    <p class="employee-text mt-2 font-semibold text-slate-900" data-profile-id>EMP-2026-014</p>
                </div>
                <div class="employee-muted rounded-2xl bg-slate-50 p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Phòng ban</p>
                    <p class="employee-text mt-2 font-semibold text-slate-900" data-profile-department>Khối vận hành</p>
                </div>
                <div class="employee-muted rounded-2xl bg-slate-50 p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Quyền truy cập</p>
                    <p class="employee-text mt-2 font-semibold text-slate-900">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
                </div>
            </div>
        </div>
    </div>
</section>
