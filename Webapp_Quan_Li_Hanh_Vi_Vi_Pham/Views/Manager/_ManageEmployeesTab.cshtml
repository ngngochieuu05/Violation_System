<div data-tab-panel="employees" class="hidden space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="font-outfit text-2xl font-bold text-slate-900">Quản lý Nhân viên</h2>
            <p class="text-sm text-slate-500 mt-1">Danh sách tất cả nhân viên trong hệ thống.</p>
        </div>
        <button class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition shadow-sm flex items-center">
            <i class="fa-solid fa-plus mr-2"></i>Thêm nhân viên
        </button>
    </div>

    <div class="saas-card bg-white">
        <div class="p-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50 rounded-t-2xl">
            <h3 class="font-bold text-slate-800"><i class="fa-solid fa-users text-slate-400 mr-2"></i>Danh sách nhân sự</h3>
            <div class="relative">
                <i class="fa-solid fa-magnifying-glass absolute left-3 top-2.5 text-slate-400 text-sm"></i>
                <input type="text" placeholder="Tìm kiếm nhân viên..." class="pl-9 pr-4 py-1.5 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-red-100 focus:border-red-300 outline-none w-64">
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-slate-600">
                <thead class="text-xs uppercase bg-slate-50 text-slate-500 border-b border-slate-200">
                    <tr>
                        <th class="p-4 py-3 font-bold">Mã NV</th>
                        <th class="p-4 py-3 font-bold">Họ & Tên</th>
                        <th class="p-4 py-3 font-bold">Phòng ban</th>
                        <th class="p-4 py-3 font-bold">Tài khoản</th>
                        <th class="p-4 py-3 font-bold text-center">Camera</th>
                    </tr>
                </thead>
                <tbody id="employeeListTbody">
                    <!-- Dữ liệu sẽ được load qua JS -->
                    <tr><td colspan="6" class="p-8 text-center text-slate-400">Đang tải dữ liệu...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
