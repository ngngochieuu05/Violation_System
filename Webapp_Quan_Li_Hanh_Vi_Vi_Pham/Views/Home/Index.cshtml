@{
    Layout = null;
    ViewData["Title"] = "ComplianceHub - Nền tảng quản lý hành vi vi phạm | Team DevHD";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="/css/output.css" asp-append-version="true" />

    <style>
            body {
                font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
                background-color: #fef2f2 !important;
                color: #0f0f11 !important;
            }
    </style>
</head>
<body class="bg-red-50 text-zinc-900 antialiased min-h-screen selection:bg-red-900 selection:text-white overflow-x-hidden">

    <header class="sticky top-0 z-50 w-full bg-red-50/90 border-b border-red-100 backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3.5 flex items-center justify-between">

            <div class="flex items-center gap-3">
                <img src="/images/logo/logo.png" alt="ComplianceHub Logo" class="w-10 h-10 object-contain" />
                <div class="flex items-baseline gap-1">
                    <span class="text-xl font-bold text-zinc-900 tracking-tight">Compliance<span class="font-bold">Hub</span></span>
                    <span class="text-xs text-zinc-500 font-medium hidden sm:block ml-1">Misconduct Management System</span>
                </div>
            </div>

            <nav class="hidden md:flex items-center gap-7">
                <a href="#hero" class="text-sm font-medium text-zinc-600 hover:text-red-600 transition-colors no-underline">Trang chủ</a>
                <a href="#features" class="text-sm font-medium text-zinc-600 hover:text-red-600 transition-colors no-underline">Tính năng</a>
                <a href="#roles" class="text-sm font-medium text-zinc-600 hover:text-red-600 transition-colors no-underline">Vai trò</a>
                <a href="#about" class="text-sm font-medium text-zinc-600 hover:text-red-600 transition-colors no-underline">Giới thiệu</a>
            </nav>

            <div class="flex items-center gap-3">
                <a asp-controller="Account" asp-action="Login" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors border border-red-200 bg-white hover:bg-red-50 text-zinc-700 h-9 px-4 py-2 no-underline">Đăng nhập</a>
                <a asp-controller="Account" asp-action="Register" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors bg-red-600 text-white hover:bg-red-700 h-9 px-4 py-2 no-underline font-semibold shadow-sm">Đăng ký</a>
            </div>

        </div>
    </header>

    <section id="hero" class="relative w-full py-16 sm:py-24 overflow-hidden border-b border-red-100">
        <div class="absolute inset-0 bg-gradient-to-b from-red-100/50 to-transparent opacity-80 pointer-events-none"></div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

                <div class="space-y-8">
                    <div class="space-y-5">
                        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-red-100 rounded-full border border-red-200">
                            <span class="text-sm font-semibold text-red-700">✨ Nền tảng quản lý hành vi vi phạm</span>
                        </div>
                        <h1 class="text-balance text-4xl sm:text-5xl font-bold tracking-tight text-zinc-900 leading-tight">
                            Quản lý hành vi vi phạm một cách <span class="text-red-600">minh bạch</span> & <span class="text-zinc-900">hiệu quả</span>
                        </h1>
                        <p class="text-lg text-zinc-600 leading-relaxed max-w-2xl">
                            ComplianceHub giúp tổ chức của bạn xây dựng môi trường làm việc lành mạnh thông qua hệ thống quản lý hành vi vi phạm toàn diện, công bằng và minh bạch.
                        </p>
                    </div>

                    <div class="space-y-4 max-w-xl">
                        <div class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" /></svg>
                            <span class="text-base text-zinc-700 font-medium">Quản lý đơn vị, nhân sự và hành vi vi phạm tập trung</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" /></svg>
                            <span class="text-base text-zinc-700 font-medium">Quy trình làm việc tự động và minh bạch</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" /></svg>
                            <span class="text-base text-zinc-700 font-medium">Báo cáo chi tiết và phân tích dữ liệu</span>
                        </div>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-4 pt-2">
                        <a asp-controller="Violations" asp-action="Index" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors bg-red-600 text-white hover:bg-red-700 h-11 px-8 group no-underline font-semibold shadow-sm">
                            Bắt đầu ngay
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-1 transition-transform"><path d="M5 12h14" /><path d="M12 5l7 7-7 7" /></svg>
                        </a>
                        <button class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors border border-red-200 bg-white hover:bg-red-50 text-zinc-700 h-11 px-8">
                            Xem demo
                        </button>
                    </div>
                </div>

                <div class="relative h-96 sm:h-[400px] hidden lg:block">
                    <div class="absolute inset-0 bg-gradient-to-br from-red-500/20 to-orange-500/10 rounded-2xl blur-3xl"></div>

                    <div class="absolute inset-4 bg-white rounded-xl border border-red-100 overflow-hidden shadow-2xl flex flex-col justify-between p-6">
                        <div class="flex items-center justify-between border-b border-red-50 pb-4">
                            <div class="flex items-center gap-2">
                                <span class="w-3 h-3 rounded-full bg-red-400"></span>
                                <span class="w-3 h-3 rounded-full bg-amber-400"></span>
                                <span class="w-3 h-3 rounded-full bg-green-400"></span>
                            </div>
                            <span class="text-xs text-zinc-400 font-mono">Hệ thống quản lý active</span>
                        </div>

                        <div class="grid grid-cols-2 gap-4 my-auto">
                            <div class="p-4 bg-red-50 border border-red-100 rounded-lg">
                                <div class="text-3xl font-bold text-red-600 tracking-tight">3</div>
                                <div class="text-xs text-red-700 mt-1">Vai trò chính</div>
                            </div>
                            <div class="p-4 bg-orange-50 border border-orange-100 rounded-lg">
                                <div class="text-3xl font-bold text-orange-600 tracking-tight">∞</div>
                                <div class="text-xs text-orange-700 mt-1">Khả năng mở rộng</div>
                            </div>
                        </div>

                        <div class="bg-red-50 p-3 rounded border border-red-100 flex items-center justify-between">
                            <span class="text-xs font-mono text-zinc-600">> Console: Connected on Branch DevHD</span>
                            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <section id="roles" class="w-full py-20 border-b border-red-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

            <div class="text-center space-y-4 mb-16 max-w-2xl mx-auto">
                <h2 class="text-3xl font-bold tracking-tight text-zinc-900 sm:text-4xl">Các vai trò & chức năng chính</h2>
                <p class="text-zinc-500">Mỗi vai trò có những chức năng riêng biệt, được thiết kế để phù hợp với nhu cầu cụ thể của tổ chức</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="group relative rounded-xl border border-red-100 bg-white p-8 hover:border-red-500 transition-all duration-300 shadow-sm hover:shadow-md">
                    <div class="inline-flex p-3 rounded-lg bg-red-50 text-red-600 mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                    </div>
                    <h3 class="text-xl font-bold text-zinc-900 mb-2">Admin - Quản lý hệ thống</h3>
                    <p class="text-sm text-zinc-500 leading-relaxed mb-4">Toàn quyền kiểm soát hệ thống và định cấu hình chính sách</p>
                    <div class="space-y-2 text-sm text-zinc-700 mb-4">
                        <div class="flex items-center gap-2"><span class="text-red-600 font-bold">✓</span> Quản lý mô hình vi phạm</div>
                        <div class="flex items-center gap-2"><span class="text-red-600 font-bold">✓</span> Quản lý tài khoản nhân sự</div>
                        <div class="flex items-center gap-2"><span class="text-red-600 font-bold">✓</span> Thiết lập quy tắc và tiêu chuẩn</div>
                    </div>
                    <button class="w-full bg-red-600 hover:bg-red-700 text-white rounded-md text-sm font-medium h-9 px-4 transition-colors">Tìm hiểu thêm</button>
                </div>

                <div class="group relative rounded-xl border border-red-100 bg-white p-8 hover:border-red-500 transition-all duration-300 shadow-sm hover:shadow-md">
                    <div class="inline-flex p-3 rounded-lg bg-red-50 text-red-600 mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18" /><path d="M18 17V9" /><path d="M13 17V5" /><path d="M8 17v-3" /></svg>
                    </div>
                    <h3 class="text-xl font-bold text-zinc-900 mb-2">Quản lý - Giám sát và xét duyệt</h3>
                    <p class="text-sm text-zinc-500 leading-relaxed mb-4">Theo dõi, phê duyệt và quản lý hành vi vi phạm của nhân viên</p>
                    <div class="space-y-2 text-sm text-zinc-700 mb-4">
                        <div class="flex items-center gap-2"><span class="text-red-600 font-bold">✓</span> Quản lý việc làm của nhân sự</div>
                        <div class="flex items-center gap-2"><span class="text-red-600 font-bold">✓</span> Xét duyệt yêu cầu nghỉ phép</div>
                        <div class="flex items-center gap-2"><span class="text-red-600 font-bold">✓</span> Theo dõi biểu mẫu vi phạm</div>
                    </div>
                    <button class="w-full bg-red-600 hover:bg-red-700 text-white rounded-md text-sm font-medium h-9 px-4 transition-colors">Tìm hiểu thêm</button>
                </div>

                <div class="group relative rounded-xl border border-red-100 bg-white p-8 hover:border-red-500 transition-all duration-300 shadow-sm hover:shadow-md">
                    <div class="inline-flex p-3 rounded-lg bg-red-50 text-red-600 mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                    </div>
                    <h3 class="text-xl font-bold text-zinc-900 mb-2">Nhân viên - Tự quản lý</h3>
                    <p class="text-sm text-zinc-500 leading-relaxed mb-4">Quản lý thông tin cá nhân và theo dõi trạng thái yêu cầu của bạn</p>
                    <div class="space-y-2 text-sm text-zinc-700 mb-4">
                        <div class="flex items-center gap-2"><span class="text-red-600 font-bold">✓</span> Thực hiện công việc được giao</div>
                        <div class="flex items-center gap-2"><span class="text-red-600 font-bold">✓</span> Kiểm tra phê duyệt từ quản lý</div>
                        <div class="flex items-center gap-2"><span class="text-red-600 font-bold">✓</span> Xem lịch sử và báo cáo cá nhân</div>
                    </div>
                    <button class="w-full bg-red-600 hover:bg-red-700 text-white rounded-md text-sm font-medium h-9 px-4 transition-colors">Tìm hiểu thêm</button>
                </div>
            </div>

        </div>
    </section>

    <section id="features" class="w-full py-20 border-b border-red-100 relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

            <div class="text-center space-y-4 mb-16 max-w-2xl mx-auto">
                <h2 class="text-3xl font-bold tracking-tight text-zinc-900 sm:text-4xl">Tính năng nổi bật</h2>
                <p class="text-zinc-500">ComplianceHub cung cấp tất cả những gì bạn cần để quản lý hành vi vi phạm hiệu quả</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

                <div class="p-8 rounded-xl border border-red-100 bg-white hover:border-red-500 transition-all duration-300 shadow-sm hover:shadow-md">
                    <div class="p-3 bg-red-50 text-red-600 rounded-lg inline-flex mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-zinc-900 mb-2">Xử lý nhanh chóng</h3>
                    <p class="text-sm text-zinc-500 leading-relaxed">Tự động hóa quy trình xử lý vi phạm để giảm thời gian xử lý.</p>
                </div>

                <div class="p-8 rounded-xl border border-red-100 bg-white hover:border-red-500 transition-all duration-300 shadow-sm hover:shadow-md">
                    <div class="p-3 bg-red-50 text-red-600 rounded-lg inline-flex mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-zinc-900 mb-2">Bảo mật & Quyền riêng tư</h3>
                    <p class="text-sm text-zinc-500 leading-relaxed">Dữ liệu nhân viên được bảo vệ với mã hóa cấp doanh nghiệp.</p>
                </div>

                <div class="p-8 rounded-xl border border-red-100 bg-white hover:border-red-500 transition-all duration-300 shadow-sm hover:shadow-md">
                    <div class="p-3 bg-red-50 text-red-600 rounded-lg inline-flex mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-zinc-900 mb-2">Phân tích dữ liệu</h3>
                    <p class="text-sm text-zinc-500 leading-relaxed">Báo cáo chi tiết giúp xác định xu hướng và cải thiện chính sách.</p>
                </div>

                <div class="p-8 rounded-xl border border-red-100 bg-white hover:border-red-500 transition-all duration-300 shadow-sm hover:shadow-md">
                    <div class="p-3 bg-red-50 text-red-600 rounded-lg inline-flex mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-zinc-900 mb-2">Tài liệu toàn diện</h3>
                    <p class="text-sm text-zinc-500 leading-relaxed">Lưu trữ tất cả hồ sơ vi phạm và quyết định quản lý tập trung.</p>
                </div>

                <div class="p-8 rounded-xl border border-red-100 bg-white hover:border-red-500 transition-all duration-300 shadow-sm hover:shadow-md">
                    <div class="p-3 bg-red-50 text-red-600 rounded-lg inline-flex mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-zinc-900 mb-2">Quy trình theo thời gian</h3>
                    <p class="text-sm text-zinc-500 leading-relaxed">Báo cáo được xem xét định kỳ để đảm bảo tính công bằng và minh bạch.</p>
                </div>

                <div class="p-8 rounded-xl border border-red-100 bg-white hover:border-red-500 transition-all duration-300 shadow-sm hover:shadow-md">
                    <div class="p-3 bg-red-50 text-red-600 rounded-lg inline-flex mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-zinc-900 mb-2">Cảnh báo & Thông báo</h3>
                    <p class="text-sm text-zinc-500 leading-relaxed">Nhận thông báo thời gian thực về các sự kiện vi phạm quan trọng.</p>
                </div>

            </div>

            <div class="mt-20 p-12 rounded-2xl bg-gradient-to-r from-red-100/50 to-transparent border border-red-200 text-center space-y-6 shadow-sm relative overflow-hidden">
                <div class="absolute inset-0 bg-red-500/5 blur-3xl rounded-full"></div>
                <div class="relative z-10">
                    <h3 class="text-3xl font-bold text-zinc-900">Sẵn sàng tối ưu hóa quản lý hành vi vi phạm của bạn?</h3>
                    <p class="text-lg text-zinc-500 max-w-2xl mx-auto">Hơn 500 tổ chức đang sử dụng ComplianceHub để tạo môi trường làm việc công bằng hơn</p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
                        <button class="px-8 py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg transition-colors shadow-sm">Liên hệ ngay</button>
                        <button class="px-8 py-3 border border-red-200 bg-white text-zinc-700 font-semibold rounded-lg hover:bg-red-50 transition-colors shadow-sm">Xem tài liệu</button>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <footer class="w-full bg-[#09090b] text-zinc-300 border-t border-zinc-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">

                <div class="space-y-5">
                    <div class="flex items-center gap-2.5">
                        <div class="bg-red-600 rounded-lg flex items-center justify-center" style="width: 32px; height: 32px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><path d="M12 8v4" /><path d="M12 16h.01" /></svg>
                        </div>
                        <span class="text-lg text-white tracking-tight">Compliance<span class="font-bold">Hub</span></span>
                    </div>
                    <p class="text-sm text-zinc-400 leading-relaxed max-w-xs">
                        Nền tảng quản lý hành vi vi phạm toàn diện cho môi trường làm việc hiện đại
                    </p>
                </div>

                <div class="space-y-4">
                    <h4 class="font-semibold text-white tracking-wide text-sm uppercase">Sản phẩm</h4>
                    <ul class="space-y-2.5 text-sm text-zinc-400 p-0 m-0 list-none">
                        <li><a href="#features" class="text-zinc-400 hover:text-white transition-colors no-underline">Tính năng</a></li>
                        <li><a href="#" class="text-zinc-400 hover:text-white transition-colors no-underline">Giá cả</a></li>
                        <li><a href="#" class="text-zinc-400 hover:text-white transition-colors no-underline">Bảo mật</a></li>
                        <li><a href="#" class="text-zinc-400 hover:text-white transition-colors no-underline">Blog</a></li>
                    </ul>
                </div>

                <div class="space-y-4">
                    <h4 class="font-semibold text-white tracking-wide text-sm uppercase">Công ty</h4>
                    <ul class="space-y-2.5 text-sm text-zinc-400 p-0 m-0 list-none">
