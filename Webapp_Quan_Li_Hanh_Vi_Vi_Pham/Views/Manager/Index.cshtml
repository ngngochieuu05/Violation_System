@{
    ViewData["Title"] = "Trang chủ Quản lý";
    Layout = "_ManagerLayout";
}

<div class="space-y-6">
    <div class="system-card overflow-hidden">
        <div class="bg-gradient-to-r from-red-600 via-red-700 to-rose-700 px-8 py-8 text-white relative overflow-hidden rounded-t-[8px]">
            <div class="absolute w-64 h-64 bg-white/10 rounded-full blur-2xl -top-20 -right-20"></div>
            <div class="relative z-10">
                <span class="px-3 py-1 bg-white/20 text-white text-xs font-semibold uppercase tracking-wider rounded-full backdrop-blur-sm">Quản lý Doanh nghiệp</span>
                <h1 class="text-2xl font-bold mt-3">Chào mừng bạn trở lại, @User.FindFirst("FullName")?.Value</h1>
                <p class="text-red-100 text-sm mt-1">Hệ thống đã xác nhận phiên đăng nhập và kích hoạt khóa bảo mật thành công.</p>
            </div>
        </div>

        <div class="p-6">
            <div class="flex items-center bg-green-50 rounded-[8px] p-4 border border-green-100 gap-4 mb-6">
                <div class="w-10 h-10 bg-green-500 rounded-full flex items-center justify-center text-white text-lg flex-shrink-0">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div>
                    <h3 class="font-bold text-green-900 text-sm">Đăng nhập & Kích hoạt thành công</h3>
                    <p class="text-xs text-green-700 mt-0.5">Tài khoản quản lý của bạn đã được liên kết với khóa bản quyền và sẵn sàng hoạt động. Mọi luồng xử lý và dữ liệu đã được cấu hình đồng bộ.</p>
                </div>
            </div>

            <div class="grid grid-cols-3 gap-6">
                <div class="system-card p-5 border-slate-200">
                    <p class="text-xs text-slate-500 font-semibold mb-1">Phiên làm việc hôm nay</p>
                    <p class="text-2xl font-bold text-slate-900">124 <span class="text-xs text-green-500 font-normal ml-1">Đang hoạt động</span></p>
                </div>
                <div class="system-card p-5 border-slate-200">
                    <p class="text-xs text-slate-500 font-semibold mb-1">Đơn cần xét duyệt</p>
                    <p class="text-2xl font-bold text-slate-900">8 <span class="text-xs text-red-500 font-normal ml-1">Cần xử lý ngay</span></p>
                </div>
                <div class="system-card p-5 border-slate-200">
                    <p class="text-xs text-slate-500 font-semibold mb-1">Biểu mẫu hệ thống</p>
                    <p class="text-2xl font-bold text-slate-900">12 <span class="text-xs text-slate-400 font-normal ml-1">Sẵn sàng</span></p>
                </div>
            </div>
        </div>
    </div>
</div>