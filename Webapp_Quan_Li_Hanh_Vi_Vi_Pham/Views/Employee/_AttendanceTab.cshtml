<section data-tab-panel="attendance" class="employee-tab-panel hidden">
    <div class="grid gap-8 lg:grid-cols-[1.25fr_0.75fr]">
        <div class="rounded-[30px] border border-slate-200/70 bg-white p-6 shadow-sm sm:p-8">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <p class="text-xs font-bold uppercase tracking-[0.24em] text-amber-500">Chấm công</p>
                    <h3 class="mt-2 font-outfit text-2xl font-bold text-slate-900">Điểm danh bằng khuôn mặt</h3>
                    <p class="mt-2 text-sm text-slate-500">
                        Check-in và check-out thông qua xác thực khuôn mặt từ camera thiết bị.
                    </p>
                </div>
            </div>

            <div class="mt-6 grid gap-6 md:grid-cols-2">
                <div class="space-y-4">
                    <div class="rounded-2xl border border-amber-100 bg-amber-50 p-5">
                        <p class="text-xs uppercase tracking-[0.18em] text-amber-600">Tài khoản xác thực</p>
                        <p class="mt-3 text-lg font-bold text-slate-900" data-attendance-username>@User.Identity?.Name</p>
                    </div>
                    <div class="grid gap-3">
                        <button type="button" data-attendance-action-trigger="checkin" class="rounded-2xl bg-red-600 px-5 py-4 text-sm font-semibold text-white shadow-sm transition hover:bg-red-700 flex items-center justify-center">
                            <i class="fa-solid fa-right-to-bracket mr-3 text-lg"></i>Check-in bằng face
                        </button>
                        <button type="button" data-attendance-action-trigger="checkout" class="rounded-2xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 flex items-center justify-center">
                            <i class="fa-solid fa-right-from-bracket mr-3 text-lg"></i>Check-out bằng face
                        </button>
                    </div>
                </div>

                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5 flex flex-col h-full">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Ảnh chụp gần nhất</p>
                    <div class="mt-3 flex-1 overflow-hidden rounded-2xl border border-slate-200 bg-white flex items-center justify-center aspect-[4/3] md:aspect-auto min-h-[160px]">
                        <img data-attendance-preview class="hidden h-full w-full object-cover" alt="Ảnh xác thực chấm công" />
                        <div data-attendance-preview-empty class="flex h-full items-center justify-center text-sm text-slate-400 p-4 text-center">
                            Chưa có ảnh xác thực
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-6 grid gap-4 md:grid-cols-4">
                <div class="rounded-2xl border border-amber-100 bg-amber-50 p-5">
                    <p class="text-xs uppercase tracking-[0.18em] text-amber-600">Giờ vào</p>
                    <p class="mt-3 font-outfit text-3xl font-bold text-slate-900" data-attendance-checkin>--:--</p>
                </div>
                <div class="rounded-2xl border border-sky-100 bg-sky-50 p-5">
                    <p class="text-xs uppercase tracking-[0.18em] text-sky-600">Giờ ra</p>
                    <p class="mt-3 font-outfit text-3xl font-bold text-slate-900" data-attendance-checkout>--:--</p>
                </div>
                <div class="rounded-2xl border border-emerald-100 bg-emerald-50 p-5">
                    <p class="text-xs uppercase tracking-[0.18em] text-emerald-600">Tổng giờ làm</p>
                    <p class="mt-3 font-outfit text-3xl font-bold text-slate-900" data-attendance-total>00h 00m</p>
                </div>
                <div class="rounded-2xl border border-violet-100 bg-violet-50 p-5">
                    <p class="text-xs uppercase tracking-[0.18em] text-violet-600">Trạng thái</p>
                    <p class="mt-3 text-xl font-bold text-slate-900" data-attendance-status>Chưa check-in</p>
                </div>
            </div>

            <div class="mt-5 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600" data-attendance-message>
                Sẵn sàng chấm công cho ngày làm việc mới.
            </div>
        </div>

        <div class="rounded-[30px] border border-slate-200/70 bg-white p-6 shadow-sm">
            <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-500">Lịch sử</p>
            <h3 class="mt-2 font-outfit text-2xl font-bold text-slate-900">Các phiên đã ghi</h3>
            <div class="mt-6 space-y-3" data-attendance-history>
                <div class="rounded-2xl bg-slate-50 p-4 text-sm text-slate-500">
                    Chưa có lịch sử chấm công trong trình duyệt này.
                </div>
            </div>
        </div>
    </div>

    <!-- Camera Modal -->
    <div data-attendance-camera-modal class="fixed inset-0 z-[1200] hidden items-center justify-center bg-slate-950/70 p-4 backdrop-blur-sm">
        <div class="w-full max-w-md overflow-hidden rounded-[30px] border border-slate-700 bg-slate-900 shadow-2xl">
            <div class="flex items-center justify-between border-b border-slate-800 px-6 py-4">
                <h3 class="font-outfit text-lg font-bold text-white" data-attendance-camera-title>Xác thực khuôn mặt</h3>
                <button type="button" data-attendance-camera-close class="text-slate-400 hover:text-white transition">
                    <i class="fa-solid fa-xmark text-xl"></i>
                </button>
            </div>
            <div class="relative aspect-[4/3] bg-black">
                <video data-attendance-video autoplay muted playsinline class="h-full w-full object-cover transform -scale-x-100"></video>
                <canvas data-attendance-canvas class="hidden"></canvas>
                <div data-attendance-scanline class="absolute left-0 top-0 hidden h-[2px] w-full bg-gradient-to-r from-transparent via-red-500 to-transparent shadow-[0_0_10px_#dc2626]"></div>
                <div data-attendance-camera-status class="absolute inset-0 flex flex-col items-center justify-center bg-slate-950/70 p-5 text-center text-white hidden">
                    <div class="mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-white/10">
                        <i class="fa-solid fa-spinner fa-spin text-lg"></i>
                    </div>
                    <p class="text-sm font-semibold" data-attendance-camera-status-text>Đang khởi tạo camera...</p>
                </div>
            </div>
            <div class="p-6">
                <p class="mb-4 text-center text-sm text-slate-300" data-attendance-camera-message>
                    Vui lòng nhìn thẳng vào camera và nhấn nút bên dưới để xác thực.
                </p>
                <button type="button" data-attendance-camera-capture class="w-full rounded-2xl bg-red-600 px-5 py-3.5 text-sm font-bold text-white shadow-sm transition hover:bg-red-700 flex items-center justify-center">
                    <i class="fa-solid fa-camera mr-3 text-lg"></i>Chụp ảnh & Xác thực
                </button>
            </div>
        </div>
    </div>

    <!-- Attendance Detail Modal -->
    <div data-attendance-detail-modal class="fixed inset-0 z-[1100] hidden items-center justify-center bg-slate-950/55 p-4">
        <div class="max-h-[90vh] w-full max-w-3xl overflow-auto rounded-[30px] border border-red-100 bg-white shadow-2xl">
            <div class="flex items-start justify-between border-b border-red-100 bg-red-600 px-6 py-5 text-white">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-red-100">Chi tiết phiên</p>
                    <h3 class="mt-2 font-outfit text-2xl font-bold">Thông tin check-in / check-out</h3>
                </div>
                <button type="button" data-attendance-detail-close class="flex h-10 w-10 items-center justify-center rounded-2xl bg-white/15 transition hover:bg-white/25">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="grid gap-6 p-6 lg:grid-cols-2">
                <div class="space-y-4">
                    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4">
                        <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Check-in</p>
                        <p class="mt-2 text-lg font-bold text-slate-900" data-attendance-detail-checkin>--</p>
                        <div class="mt-4 overflow-hidden rounded-2xl border border-slate-200 bg-white aspect-video">
                            <img data-attendance-detail-checkin-image class="hidden h-full w-full object-cover" alt="Ảnh check-in" />
                            <div data-attendance-detail-checkin-empty class="flex h-full items-center justify-center text-sm text-slate-400">
                                Không có ảnh check-in
                            </div>
                        </div>
                    </div>

                    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4">
                        <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Check-out</p>
                        <p class="mt-2 text-lg font-bold text-slate-900" data-attendance-detail-checkout>--</p>
                        <div class="mt-4 overflow-hidden rounded-2xl border border-slate-200 bg-white aspect-video">
                            <img data-attendance-detail-checkout-image class="hidden h-full w-full object-cover" alt="Ảnh check-out" />
                            <div data-attendance-detail-checkout-empty class="flex h-full items-center justify-center text-sm text-slate-400">
                                Chưa có ảnh check-out
                            </div>
                        </div>
                    </div>
                </div>

                <div class="space-y-4">
                    <div class="rounded-3xl border border-emerald-100 bg-emerald-50 p-5">
                        <p class="text-xs uppercase tracking-[0.18em] text-emerald-600">Tổng thời gian</p>
                        <p class="mt-3 font-outfit text-3xl font-bold text-slate-900" data-attendance-detail-duration>00h 00m</p>
                    </div>
                    <div class="rounded-3xl border border-amber-100 bg-amber-50 p-5">
                        <p class="text-xs uppercase tracking-[0.18em] text-amber-600">Ngày làm việc</p>
                        <p class="mt-3 text-lg font-bold text-slate-900" data-attendance-detail-date>--</p>
                    </div>
                    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
                        <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Trạng thái</p>
                        <p class="mt-3 text-lg font-bold text-slate-900" data-attendance-detail-status>--</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
