<section data-tab-panel="requests" class="employee-tab-panel hidden">
    <!-- Top Summary Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-6">
        <div class="saas-card p-6 flex items-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-slate-50 flex items-center justify-center text-slate-500 border border-slate-100 shrink-0">
                <i class="fa-solid fa-file-lines text-2xl"></i>
            </div>
            <div>
                <p class="text-3xl font-bold font-outfit text-slate-900 leading-none">12</p>
                <p class="text-sm font-medium text-slate-500 mt-1">Tổng đơn</p>
            </div>
        </div>
        <div class="saas-card p-6 flex items-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-amber-50 flex items-center justify-center text-amber-500 border border-amber-100 shrink-0">
                <i class="fa-solid fa-clock text-2xl"></i>
            </div>
            <div>
                <p class="text-3xl font-bold font-outfit text-slate-900 leading-none">3</p>
                <p class="text-sm font-medium text-slate-500 mt-1">Chờ duyệt</p>
            </div>
        </div>
        <div class="saas-card p-6 flex items-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-500 border border-emerald-100 shrink-0">
                <i class="fa-solid fa-check text-2xl"></i>
            </div>
            <div>
                <p class="text-3xl font-bold font-outfit text-slate-900 leading-none">8</p>
                <p class="text-sm font-medium text-slate-500 mt-1">Đã duyệt</p>
            </div>
        </div>
        <div class="saas-card p-6 flex items-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-red-50 flex items-center justify-center text-red-500 border border-red-100 shrink-0">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </div>
            <div>
                <p class="text-3xl font-bold font-outfit text-slate-900 leading-none">1</p>
                <p class="text-sm font-medium text-slate-500 mt-1">Từ chối</p>
            </div>
        </div>
    </div>

    <!-- Form & Preview (Top, Side by Side) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <!-- Form Tạo đơn mới -->
        <div class="saas-card p-8 flex flex-col min-h-[500px]">
            <h3 class="saas-heading text-xl mb-6">Tạo đơn mới</h3>
            
            <div class="space-y-5 flex-1 flex flex-col">
                <div>
                    <label class="mb-2 block text-sm font-bold uppercase tracking-wider text-slate-500">Loại đơn</label>
                    <select data-request-type class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-base text-slate-900 outline-none focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 transition">
                        <option value="Nghỉ phép">Đơn xin nghỉ phép</option>
                        <option value="Đi muộn">Đơn xin đi muộn / về sớm</option>
                        <option value="Tăng ca">Đơn xin làm thêm giờ (Tăng ca)</option>
                        <option value="Điều chỉnh ca">Đơn xin điều chỉnh ca</option>
                    </select>
                </div>
                <div>
                    <label class="mb-2 block text-sm font-bold uppercase tracking-wider text-slate-500">Ngày áp dụng</label>
                    <input type="date" data-request-date class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-base text-slate-900 outline-none focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 transition" />
                </div>
                <div class="flex-1 flex flex-col">
                    <label class="mb-2 block text-sm font-bold uppercase tracking-wider text-slate-500">Lý do</label>
                    <textarea data-request-reason class="w-full flex-1 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-base text-slate-900 outline-none focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 transition resize-none min-h-[160px]" placeholder="Nhập lý do chi tiết..."></textarea>
                </div>
                
                <!-- Form actions -->
                <div class="flex gap-4 pt-6 border-t border-slate-100 mt-6">
                    <button type="button" data-request-submit class="flex-1 rounded-xl bg-red-600 px-6 py-3.5 text-base font-bold text-white shadow-sm hover:bg-red-700 transition active:scale-95">
                        Gửi duyệt
                    </button>
                    <button type="button" data-request-draft class="flex-1 rounded-xl border border-slate-200 bg-white px-6 py-3.5 text-base font-bold text-slate-700 hover:bg-slate-50 transition active:scale-95 shadow-sm">
                        Lưu nháp
                    </button>
                </div>
            </div>
        </div>

        <!-- Preview -->
        <div class="saas-card p-8 flex flex-col min-h-[500px]">
            <div class="flex items-center justify-between mb-6">
                <h3 class="saas-heading text-xl">Xem trước văn bản</h3>
                <span class="text-xs text-slate-400 bg-slate-100 px-3 py-1 rounded-full border border-slate-200">Cập nhật tự động</span>
            </div>
            <div class="flex-1 bg-white rounded-xl shadow-inner border border-slate-200 p-8 overflow-y-auto w-full relative">
                <!-- A4 Aspect Ratio container styling -->
                <div data-request-preview class="text-slate-800 text-sm md:text-base leading-relaxed font-serif min-h-[400px]"></div>
            </div>
        </div>
    </div>

    <!-- Danh sách đơn từ (Bottom, Full width) -->
    <div class="saas-card p-8 w-full">
        <div class="flex items-center justify-between mb-6 border-b border-slate-100 pb-4">
            <div>
                <h3 class="saas-heading text-xl">Danh sách đơn từ đã tạo</h3>
                <p class="text-sm text-slate-500 mt-1">Theo dõi trạng thái và lịch sử duyệt đơn của bạn.</p>
            </div>
            <div>
                <button class="text-sm text-red-600 font-semibold hover:underline"><i class="fa-solid fa-filter mr-1"></i> Bộ lọc</button>
            </div>
        </div>

        <div class="space-y-4" data-request-list>
            <!-- Injected by JS -->
            <div class="rounded-xl border border-slate-100 bg-slate-50 p-8 text-center max-w-xl mx-auto">
                <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center mx-auto mb-4 shadow-sm border border-slate-100">
                    <i class="fa-solid fa-folder-open text-slate-400 text-2xl"></i>
                </div>
                <p class="text-base font-bold text-slate-700 mb-1">Chưa có đơn từ nào</p>
                <p class="text-sm text-slate-500">Các đơn từ bạn tạo sẽ xuất hiện tại đây sau khi lưu nháp hoặc gửi duyệt.</p>
            </div>
        </div>
    </div>
</section>
