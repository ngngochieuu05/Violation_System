@{
    ViewData["Title"] = "Workspace Nhân viên";
    Layout = null; // Use standalone layout for the Dashboard UI
    var initialTab = (Context.Request.Query["tab"].ToString() ?? "home").ToLowerInvariant();
    if (string.IsNullOrWhiteSpace(initialTab))
    {
        initialTab = "home";
    }
}
<!DOCTYPE html>
<html lang="vi" class="h-full bg-slate-50">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ComplianceHub</title>
    
    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- CSS: Tailwind & Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            margin: 0; padding: 0;
        }
        h1, h2, h3, h4, h5, h6, .font-outfit {
            font-family: 'Outfit', sans-serif;
        }
        
        /* Dashboard Layout */
        .dashboard-layout {
            display: flex;
            height: 100vh;
            width: 100%;
            overflow: hidden;
        }
        
        .dashboard-sidebar {
            width: 260px;
            background-color: #ffffff;
            border-right: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            z-index: 40;
        }
        
        .dashboard-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }
        
        .dashboard-header {
            height: 64px;
            background-color: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            flex-shrink: 0;
        }

        .dashboard-content {
            flex: 1;
            overflow-y: auto;
            padding: 24px;
        }

        /* Dark Mode overrides for Employee */
        .employee-dark body,
        body.employee-dark {
            background-color: #0f172a !important;
            color: #e2e8f0 !important;
        }
        body.employee-dark .dashboard-sidebar {
            background-color: #1e293b !important;
            border-color: #334155 !important;
        }
        body.employee-dark .dashboard-header {
            background-color: #0f172a !important;
            border-color: #334155 !important;
        }
        body.employee-dark .employee-surface {
            background: #111827 !important;
            border-color: rgba(148, 163, 184, 0.18) !important;
            color: #e2e8f0 !important;
        }
        body.employee-dark .employee-muted {
            background: #1e293b !important;
            color: #cbd5e1 !important;
            border-color: rgba(148, 163, 184, 0.14) !important;
        }
        body.employee-dark .employee-text { color: #e2e8f0 !important; }
        body.employee-dark .employee-subtext { color: #94a3b8 !important; }
        body.employee-dark .employee-input {
            background: #1e293b !important;
            border-color: rgba(148, 163, 184, 0.18) !important;
            color: #e2e8f0 !important;
        }
        body.employee-dark .employee-tab-shell {
            background: #111827 !important;
            border-color: rgba(148, 163, 184, 0.18) !important;
        }
        body.employee-dark .employee-avatar-placeholder {
            background: #1e293b !important;
            color: #f87171 !important;
        }
    </style>
</head>
<body class="text-slate-800">

<div class="dashboard-layout"
     data-employee-app
     data-initial-tab="@initialTab"
     data-user-id="@User.FindFirst("UserId")?.Value"
     data-username="@User.Identity?.Name"
     data-full-name="@User.FindFirst("FullName")?.Value">
    
    <!-- Sidebar -->
    <aside class="dashboard-sidebar shadow-sm">
        <!-- Logo -->
        <div class="h-16 flex items-center px-6 border-b border-slate-100">
            <a class="flex items-center space-x-2 text-red-600 hover:text-red-700 transition" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-shield-halved text-2xl"></i>
                <span class="font-outfit font-extrabold text-xl tracking-tight text-slate-900 employee-text">Compliance<span class="text-red-600">Hub</span></span>
            </a>
        </div>
        
        <!-- Navigation -->
        <div class="p-4 space-y-1 flex-1 overflow-y-auto">
            <p class="px-2 text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-3 mt-2">Workspace</p>
            
            <button type="button" data-tab-trigger="home" class="flex w-full items-center rounded-lg px-3 py-2.5 text-left text-sm font-medium transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:shadow-md text-slate-600 hover:bg-red-50 hover:text-red-600">
                <i class="fa-solid fa-house w-5 text-center mr-3"></i>Trang chủ
            </button>
            <button type="button" data-tab-trigger="attendance" class="flex w-full items-center rounded-lg px-3 py-2.5 text-left text-sm font-medium transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:shadow-md text-slate-600 hover:bg-red-50 hover:text-red-600">
                <i class="fa-solid fa-fingerprint w-5 text-center mr-3"></i>Chấm công
            </button>
            <button type="button" data-tab-trigger="schedule" class="flex w-full items-center rounded-lg px-3 py-2.5 text-left text-sm font-medium transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:shadow-md text-slate-600 hover:bg-red-50 hover:text-red-600">
                <i class="fa-solid fa-calendar-check w-5 text-center mr-3"></i>Lịch làm việc
            </button>
            <button type="button" data-tab-trigger="messages" class="flex w-full items-center rounded-lg px-3 py-2.5 text-left text-sm font-medium transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:shadow-md text-slate-600 hover:bg-red-50 hover:text-red-600">
                <i class="fa-solid fa-comments w-5 text-center mr-3"></i>Tin nhắn
            </button>
            <button type="button" data-tab-trigger="requests" class="flex w-full items-center rounded-lg px-3 py-2.5 text-left text-sm font-medium transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:shadow-md text-slate-600 hover:bg-red-50 hover:text-red-600">
                <i class="fa-solid fa-file-signature w-5 text-center mr-3"></i>Đơn từ
            </button>
            
            <div class="my-4 border-t border-slate-100 employee-muted border-opacity-50"></div>
            <p class="px-2 text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-3">Hệ thống</p>
            
            <button type="button" data-tab-trigger="profile" class="flex w-full items-center rounded-lg px-3 py-2.5 text-left text-sm font-medium transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:shadow-md text-slate-600 hover:bg-red-50 hover:text-red-600">
                <i class="fa-solid fa-user-gear w-5 text-center mr-3"></i>Cài đặt hồ sơ
            </button>
            <button type="button" data-tab-trigger="settings" class="flex w-full items-center rounded-lg px-3 py-2.5 text-left text-sm font-medium transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:shadow-md text-slate-600 hover:bg-red-50 hover:text-red-600">
                <i class="fa-solid fa-gear w-5 text-center mr-3"></i>Cài đặt
            </button>
        </div>
    </aside>

    <!-- Main Content Wrapper -->
    <div class="dashboard-main relative overflow-hidden">
        <div class="absolute inset-0 -z-10 pointer-events-none">
            <div class="absolute inset-0 bg-cover bg-center bg-no-repeat blur-sm opacity-10" style="background-image: url('@Url.Content("~/images/anh_nen123.png")');"></div>
            <div class="absolute inset-0 bg-gradient-to-br from-slate-50/80 via-white/60 to-slate-100/80"></div>
        </div>
        
        <!-- Dashboard Header -->
        <header class="dashboard-header relative z-10 bg-transparent">
            <div>
                <h2 class="font-outfit text-lg font-bold text-slate-800 employee-text">Workspace Dashboard</h2>
            </div>
            
            <div class="flex items-center space-x-4">
                <!-- Search (Placeholder to match image) -->
                <div class="hidden sm:flex items-center relative">
                    <i class="fa-solid fa-magnifying-glass absolute left-3 text-slate-400 text-sm"></i>
                    <input type="text" placeholder="Tìm kiếm..." class="bg-white border border-slate-200 rounded-full py-1.5 pl-9 pr-4 text-sm focus:ring-2 focus:ring-red-100 focus:border-red-300 transition w-48 text-slate-700 shadow-sm">
                </div>

                <!-- Notifications -->
                <div class="relative ml-2" id="dashboardNotificationDropdown">
                    <button type="button" class="relative text-slate-500 hover:text-red-600 transition-all duration-200 hover:-translate-y-0.5 active:scale-95 focus:outline-none" id="dashboardNotificationTrigger">
                        <i class="fa-regular fa-bell text-xl"></i>
                        <span class="absolute top-0 right-0 flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
                        </span>
                    </button>
                    
                    <div id="dashboardNotificationMenu" class="absolute mt-2 w-80 origin-top-right rounded-2xl bg-white shadow-xl ring-1 ring-slate-200 hidden z-50" style="right: 0;">
                        <div class="px-4 py-3 border-b border-slate-100 flex justify-between items-center gap-2">
                            <p class="text-sm font-semibold text-slate-900 whitespace-nowrap">Thông báo</p>
                            <span class="text-xs text-red-600 cursor-pointer hover:underline whitespace-nowrap text-right">Đánh dấu đã đọc</span>
                        </div>
                        <div class="py-2 max-h-64 overflow-y-auto">
                            <div class="px-4 py-3 hover:bg-slate-50 transition cursor-pointer border-b border-slate-50 last:border-0">
                                <p class="text-sm text-slate-800 font-medium">Đơn xin nghỉ phép của bạn đã được duyệt</p>
                                <p class="text-xs text-slate-500 mt-1">10 phút trước</p>
                            </div>
                            <div class="px-4 py-3 hover:bg-slate-50 transition cursor-pointer border-b border-slate-50 last:border-0">
                                <p class="text-sm text-slate-800 font-medium">Sếp nhắn tin cho bạn: "Cập nhật tiến độ nhé"</p>
                                <p class="text-xs text-slate-500 mt-1">1 giờ trước</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- User Avatar Dropdown -->
                <div class="relative ml-4 border-l border-slate-200 pl-4" id="dashboardUserDropdown">
                    <button type="button" class="flex items-center focus:outline-none transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:shadow-md hover:opacity-80" id="dashboardDropdownTrigger">
                        <div class="employee-avatar-placeholder relative flex h-10 w-10 items-center justify-center overflow-hidden rounded-full bg-red-50 text-red-600 ring-2 ring-white shadow-sm">
                            <img data-avatar-image class="hidden absolute inset-0 h-full w-full object-cover z-10" alt="Avatar" />
                            <i data-avatar-fallback class="fa-solid fa-user text-xl z-0"></i>
                        </div>
                    </button>
                    
                    <div id="dashboardDropdownMenu" class="absolute mt-2 w-48 origin-top-right rounded-2xl bg-white shadow-xl ring-1 ring-slate-200 hidden z-50" style="right: 0;">
                        <div class="px-4 py-3 border-b border-slate-100">
                            <p class="text-sm font-semibold text-slate-900 truncate" data-profile-name>@User.FindFirst("FullName")?.Value</p>
                            <p class="text-xs text-slate-500 truncate uppercase font-bold tracking-wider">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
                        </div>
                        <div class="py-1">
                            <button type="button" id="dashboardProfileModalTrigger" class="flex w-full items-center text-left px-4 py-2 text-sm font-medium text-slate-700 hover:bg-red-50 hover:text-red-600 transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:shadow-md">
                                <i class="fa-solid fa-id-badge w-5 text-center mr-3"></i>Hồ sơ
                            </button>
                            <button type="button" data-tab-trigger="profile" class="flex w-full items-center text-left px-4 py-2 text-sm font-medium text-slate-700 hover:bg-red-50 hover:text-red-600 transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:shadow-md">
                                <i class="fa-solid fa-user-gear w-5 text-center mr-3"></i>Cài đặt hồ sơ
                            </button>
                        </div>
                        <div class="border-t border-slate-100 py-1">
                            <a asp-area="" asp-controller="Account" asp-action="Logout" class="flex w-full items-center px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-50 hover:text-red-700 transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:shadow-md">
                                <i class="fa-solid fa-right-from-bracket w-5 text-center mr-3"></i>Đăng xuất
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Main Content Area -->
        <main class="dashboard-content relative" style="background: transparent;">
            <div class="max-w-5xl mx-auto space-y-8 pb-12">
                <!-- Hero Section for Home Tab -->
                <section data-tab-panel="home" data-home-hero class="employee-tab-panel relative overflow-hidden rounded-[2rem] bg-white/90 backdrop-blur-xl border border-white/60 px-6 py-8 text-black shadow-xl shadow-slate-200/50 sm:px-8 lg:px-10">
                    <div class="absolute -right-14 -top-16 h-52 w-52 rounded-full bg-red-100 blur-3xl opacity-60"></div>
                    <div class="absolute bottom-0 left-1/3 h-28 w-28 rounded-full bg-slate-100 blur-2xl"></div>
                    <div class="relative grid gap-6 lg:grid-cols-[1.35fr_0.95fr] lg:items-end">
                        <div class="space-y-5">
                            <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/80 backdrop-blur-md px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.24em] text-slate-700">
                                <i class="fa-solid fa-user-check text-[11px]"></i>
                                Employee Workspace
                            </span>
                            <div class="space-y-3">
                                <h1 class="font-outfit text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
                                    Xin chào, <span class="text-red-600" data-home-name>@User.FindFirst("FullName")?.Value</span>
                                </h1>
                                <p class="max-w-2xl text-sm leading-6 text-slate-500 sm:text-base">
                                    Chào mừng bạn đến với môi trường làm việc của mình.
                                </p>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-3">
                            <div class="rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md p-4">
                                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Vai trò</p>
                                <p class="mt-3 font-outfit text-2xl font-bold text-slate-900">Employee</p>
                            </div>
                            <div class="rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md p-4">
                                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Trạng thái</p>
                                <p class="mt-3 font-outfit text-2xl font-bold text-green-600" data-live-status>Online</p>
                            </div>
                            <div class="rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md p-4">
                                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Ngày</p>
                                <p class="mt-3 text-sm font-semibold text-slate-900" data-home-date>--/--/----</p>
                            </div>
                            <div class="rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md p-4">
                                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Giờ hiện tại</p>
                                <p class="mt-3 font-mono text-lg font-semibold text-slate-900" data-home-time>--:--:--</p>
                            </div>
                        </div>
                    </div>
                </section>

                <partial name="_HomeTab" />
                <partial name="_ScheduleTab" />
                <partial name="_AttendanceTab" />
                <partial name="_MessagesTab" />
                <partial name="_RequestsTab" />
                <partial name="_ProfileTab" />
                <partial name="_SettingsTab" />
            </div>
        </main>
    </div>
</div>

<!-- Read-only Profile Modal -->
<div id="profileModal" class="fixed inset-0 hidden flex items-center justify-center bg-slate-900/50 backdrop-blur-sm transition-opacity" style="z-index: 9999;">
    <div id="profileModalContent" class="bg-white rounded-xl shadow-2xl w-[90%] max-w-2xl overflow-hidden transform transition-all">
        <!-- Header -->
        <div id="profileModalHeader" class="bg-red-600 px-6 py-4 flex justify-between items-center cursor-move select-none">
            <h2 class="text-white font-bold text-lg uppercase tracking-wide">THÔNG TIN NHÂN VIÊN</h2>
            <button id="closeProfileModal" class="text-white hover:text-red-200 transition-all duration-200 hover:-translate-y-0.5 active:scale-95 focus:outline-none">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>

        <!-- Body -->
        <div class="p-6">
            <div class="flex flex-col-reverse md:flex-row gap-8">
                <!-- Info List (Left side) -->
                <div class="flex-1 space-y-0">
                    <div class="flex py-3 border-b border-slate-200">
                        <span class="w-1/3 text-slate-500 text-sm font-medium">Mã nhân viên:</span>
                        <span class="w-2/3 text-slate-800 text-sm font-semibold" data-profile-id>EMP-2026-014</span>
                    </div>
                    <div class="flex py-3 border-b border-slate-200">
                        <span class="w-1/3 text-slate-500 text-sm font-medium">Họ & Tên:</span>
                        <span class="w-2/3 text-slate-800 text-sm font-semibold" data-profile-name>@User.FindFirst("FullName")?.Value</span>
                    </div>
                    <div class="flex py-3 border-b border-slate-200">
                        <span class="w-1/3 text-slate-500 text-sm font-medium">Bộ phận:</span>
                        <span class="w-2/3 text-slate-800 text-sm font-semibold" data-profile-department-view>Khối vận hành</span>
                    </div>
                    <div class="flex py-3 border-b border-slate-200">
                        <span class="w-1/3 text-slate-500 text-sm font-medium">Email:</span>
                        <span class="w-2/3 text-slate-800 text-sm font-semibold" data-profile-email-view>employee@compliancehub.vn</span>
                    </div>
                    <div class="flex py-3 border-b border-slate-200">
                        <span class="w-1/3 text-slate-500 text-sm font-medium">SĐT:</span>
                        <span class="w-2/3 text-slate-800 text-sm font-semibold" data-profile-phone-view>0123 456 789</span>
                    </div>
                </div>

                <div class="flex-shrink-0 flex justify-center items-start pt-2">
                    <div class="relative w-32 h-32 md:w-36 md:h-36">
                        <div class="employee-avatar-placeholder w-full h-full rounded-full border border-slate-200 overflow-hidden bg-slate-50 flex items-center justify-center shadow-sm relative">
                            <img data-avatar-image class="hidden absolute inset-0 h-full w-full object-cover z-10" alt="Avatar" />
                            <i data-avatar-fallback class="fa-solid fa-user text-5xl text-slate-300 z-0"></i>
                        </div>
                        <label class="transition hover:bg-red-600" style="position: absolute; bottom: 4px; right: 4px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 50%; background-color: #1e293b; color: white; border: 2px solid white; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); cursor: pointer; z-index: 20;" title="Cập nhật ảnh đại diện">
                            <input type="file" accept="image/*" data-avatar-input style="display: none;" />
                            <i class="fa-solid fa-camera" style="font-size: 0.875rem;"></i>
                        </label>
                    </div>
                </div>
            </div>
            
            <div class="mt-8 flex justify-end">
                <button type="button" id="btnGoToProfileSettings" class="text-sm bg-white text-red-600 border border-red-600 font-semibold py-2 px-6 rounded-lg hover:bg-red-50 transition-all duration-200 hover:-translate-y-0.5 active:scale-95 shadow-sm flex items-center">
                    <i class="fa-solid fa-user-gear mr-3"></i>Chuyển đến Cài đặt hồ sơ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/employee.js" asp-append-version="true"></script>

<!-- Dashboard Dropdown Logic -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const trigger = document.getElementById('dashboardDropdownTrigger');
        const menu = document.getElementById('dashboardDropdownMenu');
        const dropdownContainer = document.getElementById('dashboardUserDropdown');
        
        if (trigger && menu && dropdownContainer) {
            trigger.addEventListener('click', function(e) {
                e.stopPropagation();
                menu.classList.toggle('hidden');
            });
            
            document.addEventListener('click', function(e) {
                if (!dropdownContainer.contains(e.target)) {
                    menu.classList.add('hidden');
                }
            });
            
            // Also hide dropdown if a menu item is clicked
            const items = menu.querySelectorAll('button, a');
            items.forEach(item => {
                item.addEventListener('click', () => {
                    menu.classList.add('hidden');
                });
            });
        }

        // Notification dropdown logic
        const notifTrigger = document.getElementById('dashboardNotificationTrigger');
        const notifMenu = document.getElementById('dashboardNotificationMenu');
        const notifContainer = document.getElementById('dashboardNotificationDropdown');
        
        if (notifTrigger && notifMenu && notifContainer) {
            notifTrigger.addEventListener('click', function(e) {
                e.stopPropagation();
                notifMenu.classList.toggle('hidden');
            });
            
            document.addEventListener('click', function(e) {
                if (!notifContainer.contains(e.target)) {
                    notifMenu.classList.add('hidden');
                }
            });
        }

        // Profile Modal Logic
        const modal = document.getElementById('profileModal');
        const openModalBtn = document.getElementById('dashboardProfileModalTrigger');
        const closeModalBtn = document.getElementById('closeProfileModal');
        const goToSettingsBtn = document.getElementById('btnGoToProfileSettings');
        
        if (modal && openModalBtn && closeModalBtn) {
            openModalBtn.addEventListener('click', (e) => {
                e.preventDefault();
                modal.classList.remove('hidden');
            });
            
            closeModalBtn.addEventListener('click', () => {
                modal.classList.add('hidden');
            });
            
            // close on backdrop click
            modal.addEventListener('click', (e) => {
                if (e.target === modal) {
                    modal.classList.add('hidden');
                }
            });
            
            if (goToSettingsBtn) {
                goToSettingsBtn.addEventListener('click', () => {
                    modal.classList.add('hidden');
                    const settingsBtn = document.querySelector('[data-tab-trigger="profile"]');
                    if (settingsBtn) settingsBtn.click();
                });
            }

            // Draggable Modal Logic
            const modalContent = document.getElementById('profileModalContent');
            const modalHeader = document.getElementById('profileModalHeader');
            let isDragging = false;
            let currentX;
            let currentY;
            let initialX;
            let initialY;
            let xOffset = 0;
            let yOffset = 0;

            if (modalContent && modalHeader) {
                modalHeader.addEventListener('mousedown', dragStart);
                document.addEventListener('mousemove', drag);
                document.addEventListener('mouseup', dragEnd);

                function dragStart(e) {
                    if (e.target.closest('#closeProfileModal')) return; // Ignore close button
                    initialX = e.clientX - xOffset;
                    initialY = e.clientY - yOffset;
                    
                    if (e.target === modalHeader || modalHeader.contains(e.target)) {
                        isDragging = true;
                        modalContent.style.transition = 'none'; // Disable transition while dragging
                    }
                }

                function drag(e) {
                    if (isDragging) {
                        e.preventDefault();
                        currentX = e.clientX - initialX;
                        currentY = e.clientY - initialY;

                        xOffset = currentX;
                        yOffset = currentY;

                        setTranslate(currentX, currentY, modalContent);
                    }
                }

                function dragEnd(e) {
                    initialX = currentX;
                    initialY = currentY;
                    isDragging = false;
                    modalContent.style.transition = ''; // Re-enable original transition
                }

                function setTranslate(xPos, yPos, el) {
                    el.style.transform = `translate3d(${xPos}px, ${yPos}px, 0)`;
                }

                // Reset position when modal is closed
                const observer = new MutationObserver((mutations) => {
                    mutations.forEach((mutation) => {
                        if (mutation.target.classList.contains('hidden')) {
                            xOffset = 0;
                            yOffset = 0;
                            setTranslate(0, 0, modalContent);
                        }
                    });
                });
                observer.observe(modal, { attributes: true, attributeFilter: ['class'] });
            }
            
            // Attendance Detail Drag & Teleport Logic (Inline to bypass caching)
            const detailModal = document.querySelector('[data-attendance-detail-modal]');
            const detailContent = document.querySelector('[data-attendance-detail-content]');
            const detailHeader = document.querySelector('[data-attendance-detail-header]');
            
            if (detailModal) document.body.appendChild(detailModal);
            
            if (detailContent && detailHeader) {
                let isDraggingAtt = false;
                let currentXAtt = 0, currentYAtt = 0, initialXAtt = 0, initialYAtt = 0;
                let xOffsetAtt = 0, yOffsetAtt = 0;

                detailHeader.style.cursor = 'grab';
                detailHeader.addEventListener('mousedown', (e) => {
                    if (e.target.closest('[data-attendance-detail-close]')) return;
                    initialXAtt = e.clientX - xOffsetAtt;
                    initialYAtt = e.clientY - yOffsetAtt;
                    
                    if (e.target === detailHeader || detailHeader.contains(e.target)) {
                        isDraggingAtt = true;
                        detailContent.style.transition = 'none';
                        detailHeader.style.cursor = 'grabbing';
                    }
                });

                document.addEventListener('mousemove', (e) => {
                    if (isDraggingAtt) {
                        e.preventDefault();
                        currentXAtt = e.clientX - initialXAtt;
                        currentYAtt = e.clientY - initialYAtt;
                        xOffsetAtt = currentXAtt;
                        yOffsetAtt = currentYAtt;
                        detailContent.style.transform = `translate3d(${currentXAtt}px, ${currentYAtt}px, 0)`;
                    }
                });

                document.addEventListener('mouseup', () => {
                    if (isDraggingAtt) {
                        isDraggingAtt = false;
                        detailContent.style.transition = '';
                        detailHeader.style.cursor = 'grab';
                    }
                });

                const observerAtt = new MutationObserver((mutations) => {
                    mutations.forEach((mutation) => {
                        if (mutation.target.classList.contains('hidden')) {
                            xOffsetAtt = 0;
                            yOffsetAtt = 0;
                            detailContent.style.transform = `translate3d(0, 0, 0)`;
                        }
                    });
                });
                observerAtt.observe(detailModal, { attributes: true, attributeFilter: ['class'] });
            }
        }
    });
</script>

</body>
</html>
