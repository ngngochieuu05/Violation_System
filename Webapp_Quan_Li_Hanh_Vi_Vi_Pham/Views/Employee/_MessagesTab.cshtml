<section data-tab-panel="messages" class="employee-tab-panel hidden h-full">
    <div class="h-[calc(100vh-140px)] grid grid-cols-1 lg:grid-cols-12 gap-6">
        <!-- Sidebar Danh sách hội thoại -->
        <div class="lg:col-span-4 flex flex-col saas-card overflow-hidden">
            <div class="p-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                <h3 class="saas-heading text-lg">Tin nhắn</h3>
                <button class="w-8 h-8 rounded-full bg-slate-200 text-slate-600 flex items-center justify-center hover:bg-red-100 hover:text-red-600 transition">
                    <i class="fa-solid fa-pen-to-square text-sm"></i>
                </button>
            </div>
            <div class="p-3 border-b border-slate-100">
                <div class="relative">
                    <i class="fa-solid fa-magnifying-glass absolute left-3 top-2.5 text-slate-400 text-sm"></i>
                    <input type="text" class="w-full bg-slate-100 border-none rounded-xl py-2 pl-9 pr-3 text-sm focus:ring-2 focus:ring-red-200 focus:bg-white transition" placeholder="Tìm kiếm tin nhắn..." />
                </div>
            </div>
            
            <div class="flex-1 overflow-y-auto">
                <div class="p-2 space-y-1">
                    <!-- Item 1 (Active) -->
                    <button type="button" class="w-full flex items-center gap-3 p-3 rounded-xl bg-red-50 transition text-left" data-chat-target="manager">
                        <div class="relative flex-shrink-0">
                            <img src="https://ui-avatars.com/api/?name=QL&background=fca5a5&color=fff&rounded=true" alt="Manager" class="w-10 h-10 rounded-full" />
                            <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full bg-green-500 border-2 border-white"></span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-baseline mb-0.5">
                                <p class="text-sm font-bold text-slate-900 truncate">Quản lý trực tiếp</p>
                                <span class="text-[10px] text-slate-500 flex-shrink-0 ml-2">10:24</span>
                            </div>
                            <p class="text-xs text-red-600 font-medium truncate">Bạn: Vâng, em sẽ gửi báo cáo ngay.</p>
                        </div>
                    </button>
                    
                    <!-- Item 2 -->
                    <button type="button" class="w-full flex items-center gap-3 p-3 rounded-xl hover:bg-slate-50 transition text-left" data-chat-target="hr">
                        <div class="relative flex-shrink-0">
                            <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold">HR</div>
                            <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full bg-slate-300 border-2 border-white"></span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-baseline mb-0.5">
                                <p class="text-sm font-semibold text-slate-700 truncate">Phòng nhân sự</p>
                                <span class="text-[10px] text-slate-400 flex-shrink-0 ml-2">Hôm qua</span>
                            </div>
                            <p class="text-xs text-slate-500 truncate">Thông báo nghỉ lễ sắp tới...</p>
                        </div>
                        <div class="w-5 h-5 rounded-full bg-red-500 text-white text-[10px] font-bold flex items-center justify-center flex-shrink-0">
                            2
                        </div>
                    </button>
                    
                    <!-- Item 3 -->
                    <button type="button" class="w-full flex items-center gap-3 p-3 rounded-xl hover:bg-slate-50 transition text-left" data-chat-target="it">
                        <div class="relative flex-shrink-0">
                            <div class="w-10 h-10 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center font-bold">IT</div>
                            <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full bg-green-500 border-2 border-white"></span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-baseline mb-0.5">
                                <p class="text-sm font-semibold text-slate-700 truncate">Hỗ trợ kỹ thuật</p>
                                <span class="text-[10px] text-slate-400 flex-shrink-0 ml-2">T2</span>
                            </div>
                            <p class="text-xs text-slate-500 truncate">Hệ thống đã được khôi phục.</p>
                        </div>
                    </button>
                </div>
            </div>
        </div>

        <!-- Khung Chat -->
        <div class="lg:col-span-8 flex flex-col saas-card overflow-hidden">
            <!-- Header -->
            <div class="h-16 flex items-center justify-between px-6 border-b border-slate-100 bg-white flex-shrink-0">
                <div class="flex items-center gap-3">
                    <img src="https://ui-avatars.com/api/?name=QL&background=fca5a5&color=fff&rounded=true" alt="Manager" class="w-10 h-10 rounded-full" />
                    <div>
                        <h2 class="saas-heading text-base leading-tight" data-chat-title>Quản lý trực tiếp</h2>
                        <p class="text-xs text-green-600 font-medium flex items-center gap-1 mt-0.5">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Đang hoạt động
                        </p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <button class="w-9 h-9 rounded-full text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition flex items-center justify-center">
                        <i class="fa-solid fa-phone"></i>
                    </button>
                    <button class="w-9 h-9 rounded-full text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition flex items-center justify-center">
                        <i class="fa-solid fa-video"></i>
                    </button>
                    <button class="w-9 h-9 rounded-full text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition flex items-center justify-center">
                        <i class="fa-solid fa-ellipsis-vertical"></i>
                    </button>
                </div>
            </div>

            <!-- Messages Area -->
            <div class="flex-1 overflow-y-auto p-6 bg-slate-50/50" data-chat-thread>
                <!-- Demo Bubble Chat -->
                <div class="text-center mb-6">
                    <span class="text-[10px] font-semibold text-slate-400 bg-slate-100 px-3 py-1 rounded-full">Hôm nay, 10:20</span>
                </div>
                
                <div class="flex flex-col gap-4">
                    <!-- Received Message -->
                    <div class="flex items-end gap-2 max-w-[80%]">
                        <img src="https://ui-avatars.com/api/?name=QL&background=fca5a5&color=fff&rounded=true" alt="Manager" class="w-6 h-6 rounded-full flex-shrink-0 mb-1" />
                        <div>
                            <div class="bg-white border border-slate-200 rounded-2xl rounded-bl-none px-4 py-2.5 shadow-sm">
                                <p class="text-sm text-slate-700">Chào bạn, bạn đã chuẩn bị xong báo cáo KPI tháng này chưa?</p>
                            </div>
                            <p class="text-[10px] text-slate-400 mt-1 ml-1">10:20</p>
                        </div>
                    </div>
                    
                    <!-- Received Message -->
                    <div class="flex items-end gap-2 max-w-[80%]">
                        <img src="https://ui-avatars.com/api/?name=QL&background=fca5a5&color=fff&rounded=true" alt="Manager" class="w-6 h-6 rounded-full flex-shrink-0 mb-1 opacity-0" />
                        <div>
                            <div class="bg-white border border-slate-200 rounded-2xl rounded-bl-none px-4 py-2.5 shadow-sm">
                                <p class="text-sm text-slate-700">Gửi cho mình trước 2h chiều nhé.</p>
                            </div>
                            <p class="text-[10px] text-slate-400 mt-1 ml-1">10:21</p>
                        </div>
                    </div>

                    <!-- Sent Message -->
                    <div class="flex items-end gap-2 max-w-[80%] ml-auto justify-end">
                        <div class="flex flex-col items-end">
                            <div class="bg-red-600 text-white rounded-2xl rounded-br-none px-4 py-2.5 shadow-sm">
                                <p class="text-sm">Vâng, em đang hoàn thiện phần cuối cùng.</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Sent Message -->
                    <div class="flex items-end gap-2 max-w-[80%] ml-auto justify-end">
                        <div class="flex flex-col items-end">
                            <div class="bg-red-600 text-white rounded-2xl rounded-br-none px-4 py-2.5 shadow-sm">
                                <p class="text-sm">Em sẽ gửi báo cáo ngay trước 12h trưa ạ.</p>
                            </div>
                            <div class="flex items-center gap-1 mt-1 mr-1">
                                <p class="text-[10px] text-slate-400">10:24</p>
                                <i class="fa-solid fa-check-double text-[10px] text-blue-500"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Input Area -->
            <div class="p-4 border-t border-slate-100 bg-white flex-shrink-0">
                <div class="flex items-center gap-3">
                    <button class="text-slate-400 hover:text-red-500 transition w-8 h-8 flex items-center justify-center">
                        <i class="fa-solid fa-paperclip text-lg"></i>
                    </button>
                    <div class="flex-1 relative">
                        <input type="text" data-chat-input class="w-full bg-slate-100 border-transparent focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 rounded-full py-2.5 pl-4 pr-10 text-sm transition" placeholder="Nhập tin nhắn..." />
                        <button class="absolute right-2 top-1.5 text-slate-400 hover:text-slate-600 w-7 h-7 flex items-center justify-center">
                            <i class="fa-regular fa-face-smile"></i>
                        </button>
                    </div>
                    <button type="button" data-chat-send class="w-10 h-10 rounded-full bg-red-600 text-white hover:bg-red-700 transition flex items-center justify-center shadow-sm active:scale-95 flex-shrink-0">
                        <i class="fa-solid fa-paper-plane text-sm ml-[-2px] mt-[1px]"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>
