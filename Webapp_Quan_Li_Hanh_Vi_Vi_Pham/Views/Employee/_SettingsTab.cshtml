<section data-tab-panel="settings" class="employee-tab-panel hidden">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8 flex flex-col gap-6">
            <div class="saas-card p-6 md:p-8">
                <div class="mb-6 border-b border-slate-100 pb-4">
                    <p class="saas-label mb-1">Thiết lập chung</p>
                    <h3 class="saas-heading text-lg">Tùy chọn giao diện người dùng</h3>
                </div>

                <div class="space-y-4">
                    <label class="flex items-center justify-between rounded-xl border border-slate-200 bg-slate-50 px-5 py-4 cursor-pointer hover:bg-slate-100 transition">
                        <div>
                            <p class="text-sm font-bold text-slate-900">Nhận thông báo nội bộ</p>
                            <p class="text-xs text-slate-500 mt-0.5">Lưu cục bộ trong trình duyệt</p>
                        </div>
                        <input type="checkbox" data-setting-toggle="notifications" class="h-5 w-5 rounded border-slate-300 text-red-600 focus:ring-red-500 transition" checked />
                    </label>
                    <label class="flex items-center justify-between rounded-xl border border-slate-200 bg-slate-50 px-5 py-4 cursor-pointer hover:bg-slate-100 transition">
                        <div>
                            <p class="text-sm font-bold text-slate-900">Chế độ hiển thị gọn</p>
                            <p class="text-xs text-slate-500 mt-0.5">Ẩn bớt khoảng cách trong các card</p>
                        </div>
                        <input type="checkbox" data-setting-toggle="compact" class="h-5 w-5 rounded border-slate-300 text-red-600 focus:ring-red-500 transition" />
                    </label>
                    <label class="flex items-center justify-between rounded-xl border border-slate-200 bg-slate-50 px-5 py-4 cursor-pointer hover:bg-slate-100 transition">
                        <div>
                            <p class="text-sm font-bold text-slate-900">Giảm hiệu ứng chuyển động</p>
                            <p class="text-xs text-slate-500 mt-0.5">Phù hợp khi muốn giao diện ổn định hơn</p>
                        </div>
                        <input type="checkbox" data-setting-toggle="reducedMotion" class="h-5 w-5 rounded border-slate-300 text-red-600 focus:ring-red-500 transition" />
                    </label>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                            <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-500">Ngôn ngữ hiển thị</label>
                            <select data-setting-select="language" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 outline-none focus:ring-2 focus:ring-red-100 transition">
                                <option value="vi-VN">Tiếng Việt</option>
                                <option value="en-US">English</option>
                            </select>
                        </div>
                        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                            <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-500">Chủ đề giao diện</label>
                            <select data-setting-select="theme" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 outline-none focus:ring-2 focus:ring-red-100 transition">
                                <option value="light">Sáng mặc định</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="mt-6 pt-6 border-t border-slate-100 flex items-center justify-between">
                    <p class="text-xs text-slate-500" data-setting-message>Thiết lập tự động lưu.</p>
                    <button type="button" data-setting-reset class="rounded-xl border border-slate-200 bg-white px-5 py-2.5 text-sm font-bold text-slate-600 hover:bg-slate-50 hover:text-red-600 hover:border-red-100 transition shadow-sm active:scale-95">
                        Khôi phục mặc định
                    </button>
                </div>
            </div>
        </div>

        <div class="lg:col-span-4 flex flex-col gap-6">
            <div class="saas-card p-6">
                <div class="mb-6 border-b border-slate-100 pb-4">
                    <p class="saas-label mb-1">Tài khoản</p>
                    <h3 class="saas-heading text-lg">Phiên làm việc & Bảo mật</h3>
                </div>
                
                <div class="space-y-3">
                    <button type="button" data-tab-trigger="profile" class="w-full flex items-center justify-between p-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-700 hover:bg-slate-100 transition group active:scale-95">
                        <span class="text-sm font-bold">Mở trang hồ sơ</span>
                        <i class="fa-solid fa-angle-right text-slate-400 group-hover:text-slate-600 transition"></i>
                    </button>
                    
                    <button type="button" id="btnOpenPayrollPinSetup" class="w-full flex items-center justify-between p-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-700 hover:bg-slate-100 transition group active:scale-95">
                        <div>
                            <span class="text-sm font-bold block text-left">Đăng ký / Đổi mã PIN</span>
                            <span class="text-xs text-slate-500 font-normal">Dùng để xem phiếu lương</span>
                        </div>
                        <i class="fa-solid fa-key text-slate-400 group-hover:text-slate-600 transition"></i>
                    </button>
                    
                    <a asp-controller="Account" asp-action="Logout" class="w-full flex items-center justify-between p-4 rounded-xl bg-red-50 border border-red-100 text-red-600 hover:bg-red-100 transition group active:scale-95 no-underline">
                        <span class="text-sm font-bold">Đăng xuất an toàn</span>
                        <i class="fa-solid fa-right-from-bracket group-hover:translate-x-1 transition-transform"></i>
                    </a>
                </div>
            </div>
        </div>
    <!-- Setup Payroll PIN Modal -->
    <div id="setupPayrollPinModal" class="fixed inset-0 z-[1200] hidden items-center justify-center p-4 backdrop-blur-sm" style="background-color: rgba(15, 23, 42, 0.5);">
        <div class="w-full max-w-sm overflow-hidden rounded-[20px] bg-white shadow-2xl flex flex-col transform scale-95 opacity-0 transition-all duration-300" id="setupPayrollPinModalContent">
            <div class="flex flex-col items-center border-b border-slate-100 p-6 bg-slate-50">
                <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-red-100 text-red-600">
                    <i class="fa-solid fa-key text-2xl"></i>
                </div>
                <h3 class="font-outfit text-xl font-bold text-slate-900">Đăng ký Mã PIN</h3>
                <p class="mt-1 text-center text-sm text-slate-500">Mã PIN dùng để bảo mật khi xem phiếu lương</p>
            </div>
            <div class="p-6 flex flex-col gap-4">
                <div>
                    <label class="mb-2 block text-sm font-bold uppercase tracking-wider text-slate-500">Mã PIN mới</label>
                    <input type="password" id="newPayrollPinInput" maxlength="6" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-center text-2xl font-bold tracking-[0.5em] text-slate-900 outline-none transition focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100" placeholder="••••" />
                </div>
                <div>
                    <label class="mb-2 block text-sm font-bold uppercase tracking-wider text-slate-500">Xác nhận mã PIN</label>
                    <input type="password" id="confirmPayrollPinInput" maxlength="6" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-center text-2xl font-bold tracking-[0.5em] text-slate-900 outline-none transition focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100" placeholder="••••" />
                </div>
                <p id="setupPayrollPinError" class="hidden text-center text-sm font-medium text-red-500"></p>
            </div>
            <div class="border-t border-slate-100 bg-slate-50 p-6 flex gap-3">
                <button type="button" id="closeSetupPayrollPinModal" class="flex-1 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50 transition">Hủy</button>
                <button type="button" id="submitSetupPayrollPinBtn" class="flex-1 rounded-xl bg-red-600 px-4 py-3 text-sm font-bold text-white hover:bg-red-700 transition">Xác nhận</button>
            </div>
        </div>
    </div>
</section>
