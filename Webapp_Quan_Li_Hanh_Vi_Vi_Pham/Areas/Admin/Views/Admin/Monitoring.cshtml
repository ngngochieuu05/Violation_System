@model Webapp_Quan_Li_Hanh_Vi_Vi_Pham.Areas.Admin.Models.MonitoringCenterViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Monitoring Center";
    ViewData["ActivePage"] = "Monitoring";
}

<div class="space-y-6">
    <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
        <div>
            <h1 class="mb-2 text-3xl font-bold text-zinc-900">Monitoring Center</h1>
            <p class="text-sm text-zinc-500">Chạy testcase vi phạm và kiểm tra luồng Telegram end-to-end.</p>
        </div>
        <a href="/Admin/AuditLogs" class="inline-flex items-center gap-2 rounded-lg border border-zinc-200 bg-white px-4 py-2 text-sm font-semibold text-zinc-700 shadow-sm hover:bg-zinc-50">
            <i class="fa-solid fa-clock-rotate-left"></i>Xem Audit Logs
        </a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">@successMessage</div>
    }
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">@errorMessage</div>
    }

    <div class="grid gap-4 lg:grid-cols-4">
        <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-bold uppercase tracking-widest text-zinc-400">Polling</p>
            <p class="mt-3 text-3xl font-bold text-zinc-900">@Model.PollingIntervalSeconds s</p>
        </div>
        <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-bold uppercase tracking-widest text-zinc-400">Smoke Threshold</p>
            <p class="mt-3 text-3xl font-bold text-zinc-900">@Model.SmokeDetectionThresholdCount lần</p>
        </div>
        <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-bold uppercase tracking-widest text-zinc-400">Leaving Threshold</p>
            <p class="mt-3 text-3xl font-bold text-zinc-900">@Model.EmptyChairThresholdMinutes phút</p>
        </div>
        <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-bold uppercase tracking-widest text-zinc-400">Telegram</p>
            <p class="mt-3 text-3xl font-bold @(Model.TelegramEnabled ? "text-emerald-600" : "text-red-600")">@(Model.TelegramEnabled ? "ON" : "OFF")</p>
        </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
        <div class="space-y-6">
            <div class="rounded-2xl border border-zinc-200 bg-white shadow-sm">
                <div class="border-b border-zinc-100 p-6">
                    <h2 class="text-lg font-bold text-zinc-900">Testcase Vi Phạm</h2>
                    <p class="mt-1 text-sm text-zinc-500">Chạy tay để kiểm tra luồng tạo vi phạm, audit log và Telegram.</p>
                </div>
                <div class="grid gap-4 p-6 md:grid-cols-2">
                    <form asp-action="TestSmoke" asp-controller="Admin" asp-area="Admin" method="post" class="rounded-2xl border border-amber-200 bg-amber-50 p-5">
                        @Html.AntiForgeryToken()
                        <div class="flex items-center justify-between gap-3">
                            <div>
                                <h3 class="text-base font-bold text-amber-900">Smoke Test</h3>
                                <p class="mt-2 text-sm text-amber-800">Mô phỏng cảnh báo hút thuốc ngay lập tức theo ngưỡng cấu hình.</p>
                            </div>
                            <i class="fa-solid fa-smoking text-2xl text-amber-500"></i>
                        </div>
                        <button type="submit" class="mt-5 inline-flex items-center gap-2 rounded-lg bg-amber-500 px-4 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-amber-600">
                            <i class="fa-solid fa-play"></i>Chạy smoke testcase
                        </button>
                    </form>

                    <form asp-action="TestLeaving" asp-controller="Admin" asp-area="Admin" method="post" class="rounded-2xl border border-sky-200 bg-sky-50 p-5">
                        @Html.AntiForgeryToken()
                        <div class="flex items-center justify-between gap-3">
                            <div>
                                <h3 class="text-base font-bold text-sky-900">Leaving Position Test</h3>
                                <p class="mt-2 text-sm text-sky-800">Mô phỏng ghế trống/non-human quá ngưỡng 10 phút và phát cảnh báo.</p>
                            </div>
                            <i class="fa-solid fa-chair text-2xl text-sky-500"></i>
                        </div>
                        <button type="submit" class="mt-5 inline-flex items-center gap-2 rounded-lg bg-sky-500 px-4 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-sky-600">
                            <i class="fa-solid fa-play"></i>Chạy leaving testcase
                        </button>
                    </form>
                </div>
                @if (Model.LastAlertResult is not null)
                {
                    <div class="border-t border-zinc-100 bg-zinc-50 p-6">
                        <h3 class="text-sm font-bold uppercase tracking-widest text-zinc-500">Kết quả testcase gần nhất</h3>
                        <div class="mt-3 rounded-xl border border-zinc-200 bg-white p-4 text-sm text-zinc-700">
                            <p><span class="font-semibold">Track:</span> @Model.LastAlertResult.TrackId</p>
                            <p><span class="font-semibold">Violation:</span> @Model.LastAlertResult.ViolationType</p>
                            <p><span class="font-semibold">Severity:</span> @Model.LastAlertResult.Severity</p>
                            <p><span class="font-semibold">Time:</span> @Model.LastAlertResult.DetectedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</p>
                            <p><span class="font-semibold">Message:</span> @Model.LastAlertResult.Message</p>
                        </div>
                    </div>
                }
            </div>

            <div class="rounded-2xl border border-zinc-200 bg-white shadow-sm">
                <div class="border-b border-zinc-100 p-6">
                    <h2 class="text-lg font-bold text-zinc-900">Recent Violations</h2>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-zinc-100 text-sm">
                        <thead class="bg-zinc-50">
                            <tr>
                                <th class="px-4 py-3 text-left font-semibold text-zinc-600">Time</th>
                                <th class="px-4 py-3 text-left font-semibold text-zinc-600">Track/Emp</th>
                                <th class="px-4 py-3 text-left font-semibold text-zinc-600">Violation</th>
                                <th class="px-4 py-3 text-left font-semibold text-zinc-600">Severity</th>
                                <th class="px-4 py-3 text-left font-semibold text-zinc-600">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-zinc-100">
                        @foreach (var item in Model.RecentViolations)
                        {
                            <tr>
                                <td class="px-4 py-3 text-zinc-600">@item.DetectedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td class="px-4 py-3 font-medium text-zinc-900">@item.EmployeeCode</td>
                                <td class="px-4 py-3 text-zinc-700">@item.ViolationType</td>
                                <td class="px-4 py-3 text-zinc-700">@item.Severity</td>
                                <td class="px-4 py-3 text-zinc-700">@item.Status</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="rounded-2xl border border-zinc-200 bg-white shadow-sm">
                <div class="border-b border-zinc-100 p-6">
                    <h2 class="text-lg font-bold text-zinc-900">Telegram Flow</h2>
                    <p class="mt-1 text-sm text-zinc-500">Lấy chat id từ getUpdates và gửi message thử trực tiếp.</p>
                </div>
                <div class="space-y-4 p-6">
                    <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-4 text-sm text-zinc-700">
                        <p><span class="font-semibold">Camera:</span> @Model.CameraLocation</p>
                        <p><span class="font-semibold">ChatIds config:</span> @(string.IsNullOrWhiteSpace(Model.ConfiguredChatIds) ? "Chưa có" : Model.ConfiguredChatIds)</p>
                        <p><span class="font-semibold">ChatIds động:</span> @(string.IsNullOrWhiteSpace(Model.KnownChatIds) ? "Chưa có" : Model.KnownChatIds)</p>
                        <p><span class="font-semibold">Hướng dẫn:</span> Mở Telegram, nhắn tin cho bot rồi tải lại trang này.</p>
                    </div>

                    <form asp-action="SendTelegramTest" asp-controller="Admin" asp-area="Admin" method="post" class="space-y-4">
                        @Html.AntiForgeryToken()
                        <div>
                            <label class="mb-2 block text-sm font-semibold text-zinc-700">Chat ID để gửi thử</label>
                            <input type="text" name="chatId" value="@(Model.RecentTelegramUpdates.FirstOrDefault()?.ChatId ?? string.Empty)" class="w-full rounded-xl border border-zinc-200 px-4 py-2.5 text-sm outline-none focus:border-red-400" placeholder="Nhập chat id hoặc để trống để dùng chat id đầu tiên đã học được" />
                        </div>
                        <div>
                            <label class="mb-2 block text-sm font-semibold text-zinc-700">Nội dung</label>
                            <textarea name="message" rows="4" class="w-full rounded-xl border border-zinc-200 px-4 py-3 text-sm outline-none focus:border-red-400" placeholder="[TEST TELEGRAM] Gửi từ Monitoring Center"></textarea>
                        </div>
                        <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-red-600 px-4 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-red-700">
                            <i class="fa-solid fa-paper-plane"></i>Gửi test Telegram
                        </button>
                    </form>

                    @if (Model.LastTelegramSendResult is not null)
                    {
                        <div class="rounded-xl border @(Model.LastTelegramSendResult.Success ? "border-emerald-200 bg-emerald-50" : "border-red-200 bg-red-50") p-4 text-sm @(Model.LastTelegramSendResult.Success ? "text-emerald-800" : "text-red-800")">
                            <p><span class="font-semibold">Chat:</span> @Model.LastTelegramSendResult.ChatId</p>
                            <p><span class="font-semibold">Kết quả:</span> @Model.LastTelegramSendResult.ResponseSummary</p>
                        </div>
                    }
                </div>
            </div>

            <div class="rounded-2xl border border-zinc-200 bg-white shadow-sm">
                <div class="border-b border-zinc-100 p-6">
                    <h2 class="text-lg font-bold text-zinc-900">Recent Telegram Updates</h2>
                </div>
                <div class="max-h-[520px] overflow-y-auto divide-y divide-zinc-100">
                    @if (Model.RecentTelegramUpdates.Count == 0)
                    {
                        <div class="p-6 text-sm text-zinc-500">Chưa có update nào. Hãy nhắn cho bot &#64;Smoke_VIP_VN_Bot rồi tải lại trang này.</div>
                    }
                    else
                    {
                        @foreach (var update in Model.RecentTelegramUpdates)
                        {
                            <div class="p-5">
                                <div class="flex items-start justify-between gap-3">
                                    <div>
                                        <p class="text-sm font-semibold text-zinc-900">@(!string.IsNullOrWhiteSpace(update.ChatTitle) ? update.ChatTitle : update.SenderName)</p>
                                        <p class="mt-1 text-xs uppercase tracking-widest text-zinc-400">@update.ChatType</p>
                                    </div>
                                    <span class="rounded-full bg-zinc-100 px-3 py-1 text-xs font-semibold text-zinc-600">@update.ChatId</span>
                                </div>
                                <p class="mt-3 text-sm text-zinc-700">@update.MessageText</p>
                                <p class="mt-2 text-xs text-zinc-400">@update.MessageUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</p>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
