{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=TEDDYY\\SQLEXPRESS;Database=Violation_Webbapp;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "AllowedHosts": "*",
  "YoloModel": {
    "PythonExecutable": "python",
    "InferenceScriptPath": "ML/scripts/run_yolo_inference.py",
    "ModelPath": "ML/weights/best.pt",
    "SampleSourcePath": "ML/samples/sample.jpg"
  },
  "ViolationMonitoring": {
    "PollingIntervalSeconds": 5,
    "SmokeDetectionThresholdCount": 3,
    "EmptyChairThresholdMinutes": 10,
    "TrackMatchIouThreshold": 0.4,
    "CameraLocation": "Camera giám sát mặc định"
  },
  "TelegramBot": {
    "BotToken": "SET_TELEGRAM_BOT_TOKEN",
    "ChatIds": [],
    "Enabled": true,
    "AllowDynamicChatIds": true,
    "CommandPollingIntervalSeconds": 5,
    "WelcomeMessage": "Xin chào. Bot cảnh báo vi phạm đã sẵn sàng. Hệ thống sẽ tự động gửi cảnh báo khi phát hiện hút thuốc hoặc rời vị trí làm việc."
  },
  "GeminiChat": {
    "ApiKey": "SET_GEMINI_API_KEY",
    "Model": "gemini-2.5-flash",
    "Enabled": true
  },
  "DeepFace": {
    "ModelName": "VGG-Face",
    "DetectorBackend": "opencv",
    "Align": true,
    "EnforceDetection": true
  },
  "Authentication": {
    "Google": {
      "ClientId": "SET_GOOGLE_CLIENT_ID",
      "ClientSecret": "SET_GOOGLE_CLIENT_SECRET"
    }
