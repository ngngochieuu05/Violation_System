@{
    ViewData["Title"] = "Quản lý xét duyệt";
    Layout = "_ManagerLayout";
}

<div class="space-y-6">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">Quản lý xét duyệt</h1>
            <p class="text-sm text-slate-500 mt-1">Xử lý đơn xin nghỉ và tin nhắn từ nhân viên.</p>
        </div>
    </div>

    <div class="system-card overflow-hidden">
        <table class="w-full text-left text-sm">
            <thead class="bg-slate-50 text-slate-600 font-semibold border-b border-slate-200">
                <tr>
                    <th class="px-6 py-3">Người gửi</th>
                    <th class="px-6 py-3">Loại yêu cầu</th>
                    <th class="px-6 py-3">Nội dung</th>
                    <th class="px-6 py-3 text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50/50">
                    <td class="px-6 py-4 font-medium text-slate-900">Lê Văn C</td>
                    <td class="px-6 py-4 text-slate-500">Đơn xin nghỉ phép</td>
                    <td class="px-6 py-4">Nghỉ ốm ngày 20/10...</td>
                    <td class="px-6 py-4 text-right space-x-2">
                        <button class="px-3 py-1.5 bg-green-600 text-white rounded-[4px] text-xs font-medium hover:bg-green-700">Duyệt</button>
                        <button class="px-3 py-1.5 bg-slate-200 text-slate-700 rounded-[4px] text-xs font-medium hover:bg-slate-300">Từ chối</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>