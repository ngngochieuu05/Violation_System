<section data-tab-panel="profile" class="employee-tab-panel hidden">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <!-- Cột Trái: Avatar & Overview -->
        <div class="lg:col-span-4 flex flex-col gap-6">
            <div class="saas-card p-6 flex flex-col items-center text-center relative overflow-hidden">
                <div class="absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-red-50 to-white"></div>
                
                <div class="relative w-32 h-32 mb-4 mt-8 mx-auto">
                    <div class="w-full h-full rounded-full border-4 border-white shadow-md bg-slate-100 flex items-center justify-center overflow-hidden relative">
                        <img data-avatar-image class="hidden absolute inset-0 w-full h-full object-cover z-10" alt="Avatar employee" />
                        <i data-avatar-fallback class="fa-solid fa-user text-4xl text-slate-300 z-0"></i>
                    </div>
                    <label class="absolute bottom-0 right-0 w-8 h-8 rounded-full bg-red-600 text-white flex items-center justify-center shadow-md cursor-pointer hover:bg-red-700 transition border-2 border-white z-20" title="Cập nhật ảnh đại diện">
                        <input type="file" accept="image/*" data-avatar-input class="hidden" />
                        <i class="fa-solid fa-camera text-xs"></i>
                    </label>
                </div>

                <h3 class="saas-heading text-xl" data-profile-name>@User.FindFirst("FullName")?.Value</h3>
                <p class="text-sm text-slate-500 mt-1">@User.Identity?.Name</p>
                
                <span class="inline-flex items-center rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-600 mt-3 border border-red-100">
                    @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                </span>

                <div class="w-full mt-6 space-y-3 text-left">
                    <div class="flex items-center justify-between p-3 rounded-xl bg-slate-50 border border-slate-100">
                        <span class="text-xs font-semibold text-slate-500">Mã nhân viên</span>
                        <span class="text-sm font-bold text-slate-900" data-profile-id>EMP-2026-014</span>
                    </div>
                    <div class="flex items-center justify-between p-3 rounded-xl bg-slate-50 border border-slate-100">
                        <span class="text-xs font-semibold text-slate-500">Phòng ban</span>
                        <span class="text-sm font-bold text-slate-900" data-profile-department-view>Khối vận hành</span>
                    </div>
                </div>

                <div class="mt-4 w-full">
                    <button type="button" data-avatar-remove class="w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-xs font-bold text-slate-600 hover:text-red-600 hover:bg-red-50 hover:border-red-100 transition shadow-sm">
                        <i class="fa-solid fa-trash-can mr-2"></i>Xóa ảnh đại diện
                    </button>
                    <p class="mt-3 text-[10px] text-slate-400" data-avatar-message>Ảnh đại diện hiện đang dùng mặc định.</p>
                </div>
            </div>
            <div class="mt-4 bg-white border border-zinc-200 rounded-2xl p-6 shadow-sm hover:shadow-md border-emerald-100 bg-gradient-to-br from-emerald-50/50 to-white transition duration-250">
                <h3 class="font-outfit font-bold text-base mb-2 text-slate-900">Dữ liệu khuôn mặt</h3>
                <p class="text-xs text-slate-500 mb-4 leading-relaxed">
                    Dữ liệu sinh trắc học dùng để điểm danh AI. Hãy cập nhật nếu bạn thay đổi diện mạo.
                </p>
                <button type="button" data-profile-update-face class="w-full rounded-xl bg-emerald-600 px-4 py-2.5 text-sm font-bold text-white hover:bg-emerald-700 transition shadow-sm flex items-center justify-center">
                    Cập nhật khuôn mặt
                </button>
            </div>
        </div>

        <!-- Cột Phải: Form Thông tin & Cài đặt -->
        <div class="lg:col-span-8 flex flex-col gap-6">
            <!-- Thông tin cá nhân -->
            <div class="saas-card p-6 md:p-8">
                <h3 class="saas-heading text-lg border-b border-slate-100 pb-4 mb-6">Thông tin cá nhân & Liên hệ</h3>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div>
                        <label class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-500">Họ tên</label>
                        <input type="text" data-profile-input="name" value="@User.FindFirst("FullName")?.Value" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm text-slate-900 outline-none focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 transition" />
                    </div>
                    <div>
                        <label class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-500">Bộ phận</label>
                        <input type="text" data-profile-input="department" value="Khối vận hành" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm text-slate-900 outline-none focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 transition" />
                    </div>
                    <div>
                        <label class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-500">Email</label>
                        <input type="email" data-profile-input="email" value="" placeholder="Ví dụ: nguyenvan@gmail.com" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm text-slate-900 outline-none focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 transition" />
                    </div>
                    <div>
                        <label class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-500">Số điện thoại</label>
                        <input type="text" data-profile-input="phone" value="0123 456 789" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm text-slate-900 outline-none focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 transition" />
                    </div>
                </div>
                
                <div class="mt-6 pt-6 border-t border-slate-100 flex items-center justify-between">
                    <p class="text-xs text-slate-500" data-profile-message>Thông tin đang ở trạng thái mặc định.</p>
                    <button type="button" data-profile-save class="rounded-xl bg-red-600 px-6 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-red-700 transition active:scale-95">
                        Lưu thay đổi
                    </button>
                </div>
            </div>

            <!-- Bảo mật tài khoản -->
            <div class="saas-card p-6 md:p-8">
                <h3 class="saas-heading text-lg border-b border-slate-100 pb-4 mb-6">Bảo mật tài khoản</h3>
                
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
                    <div>
                        <label class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-500">Mật khẩu cũ</label>
                        <input type="password" data-profile-pwd-old class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm text-slate-900 outline-none focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 transition" />
                    </div>
                    <div>
                        <label class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-500">Mật khẩu mới</label>
                        <input type="password" data-profile-pwd-new class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm text-slate-900 outline-none focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 transition" />
                    </div>
                    <div>
                        <label class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-500">Xác nhận mật khẩu mới</label>
                        <input type="password" data-profile-pwd-confirm class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm text-slate-900 outline-none focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 transition" />
                    </div>
                </div>

                <div class="mt-6 pt-6 border-t border-slate-100 flex items-center justify-between">
                    <p data-profile-pwd-msg class="text-xs font-semibold text-red-600 hidden"></p>
                    <button type="button" data-profile-change-pwd class="ml-auto rounded-xl bg-slate-800 px-6 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-slate-900 transition active:scale-95">
                        Cập nhật mật khẩu
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Face Update Modal -->
    <div data-face-modal class="fixed inset-0 z-[1200] hidden items-center justify-center bg-slate-950/70 p-4 backdrop-blur-sm">
        <!-- Vẫn giữ cấu trúc Modal Face -->
        <div class="w-full max-w-lg overflow-hidden rounded-[24px] bg-white shadow-2xl">
            <div class="flex items-center justify-between border-b border-slate-100 px-6 py-4">
                <h3 class="font-outfit text-lg font-bold text-slate-900">Cập nhật dữ liệu khuôn mặt</h3>
                <button type="button" data-face-close class="text-slate-400 hover:text-slate-600 transition">
                    <i class="fa-solid fa-xmark text-xl"></i>
                </button>
            </div>
            
            <div class="p-6">
                <!-- Instruction Steps -->
                <div class="mb-6 flex justify-between gap-2 text-center text-xs font-semibold">
                    <div class="flex-1 rounded-lg bg-red-50 py-2 text-red-600 border border-red-200 transition-colors duration-300" id="step-0">Trực diện</div>
                    <div class="flex-1 rounded-lg bg-slate-100 py-2 text-slate-500 transition-colors duration-300" id="step-1">Quay trái</div>
                    <div class="flex-1 rounded-lg bg-slate-100 py-2 text-slate-500 transition-colors duration-300" id="step-2">Quay phải</div>
                    <div class="flex-1 rounded-lg bg-slate-100 py-2 text-slate-500 transition-colors duration-300" id="step-3">Ngước lên</div>
                </div>

                <div class="relative aspect-[4/3] bg-black rounded-2xl overflow-hidden shadow-inner">
                    <video data-face-video autoplay muted playsinline class="h-full w-full object-cover transform -scale-x-100"></video>
                    <canvas data-face-canvas class="hidden"></canvas>
                    <div data-face-scanline class="absolute left-0 top-0 hidden h-[2px] w-full bg-gradient-to-r from-transparent via-red-500 to-transparent shadow-[0_0_10px_#dc2626]"></div>
                    <div data-face-overlay class="pointer-events-none absolute inset-0 border-2 border-dashed border-white/30 rounded-2xl m-4 transition-colors"></div>
                    <div data-face-status class="absolute inset-0 flex flex-col items-center justify-center bg-slate-900/80 p-5 text-center text-white hidden">
                        <div class="mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-white/20">
                            <i class="fa-solid fa-spinner fa-spin text-lg"></i>
                        </div>
                        <p class="text-sm font-semibold" data-face-status-text>Đang khởi tạo camera...</p>
                    </div>
                </div>

                <div class="mt-6 text-center">
                    <p class="mb-4 text-sm font-medium text-amber-600" data-face-instruction>
                        Nhìn thẳng trực diện vào camera và nhấn chụp.
                    </p>
                    <button type="button" data-face-capture class="mx-auto flex w-full max-w-xs items-center justify-center rounded-xl bg-red-600 px-5 py-3.5 text-sm font-bold text-white shadow-sm hover:bg-red-700 transition active:scale-95">
                        <i class="fa-solid fa-camera mr-2"></i>Chụp góc hiện tại
                    </button>
                </div>
            </div>
        </div>
    </div>

</section>
