@model Webapp_Quan_Li_Hanh_Vi_Vi_Pham.Models.Entities.ModelSetting
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Cài đặt hệ thống";
    ViewData["ActivePage"] = "SettingsSystem";
}

<div class="space-y-6">
    <div class="flex items-start justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-zinc-900 mb-2">Cài đặt DeepFace</h1>
            <p class="text-zinc-500 max-w-3xl">
                Cấu hình này được dùng chung cho ba luồng sinh trắc học trong hệ thống:
                đăng ký khuôn mặt, cập nhật khuôn mặt và đăng nhập bằng khuôn mặt.
            </p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
            @successMessage
        </div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
            @errorMessage
        </div>
    }

    <div class="grid gap-6 lg:grid-cols-[1.4fr,0.9fr]">
        <section class="rounded-2xl border border-zinc-200 bg-white shadow-sm">
            <div class="border-b border-zinc-100 px-6 py-5">
                <h2 class="text-lg font-bold text-zinc-900">Runtime DeepFace</h2>
                <p class="mt-1 text-sm text-zinc-500">
                    Các thay đổi tại đây sẽ tác động trực tiếp đến quá trình trích xuất embedding ở mọi luồng DeepFace.
                </p>
            </div>

            <form asp-action="UpdateDeepFaceSettings" method="post" class="space-y-6 px-6 py-6">
                @Html.AntiForgeryToken()

                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label for="deepfaceDetectorBackend" class="mb-2 block text-sm font-semibold text-zinc-900">Detector backend</label>
                        <select
                            id="deepfaceDetectorBackend"
                            name="deepfaceDetectorBackend"
                            class="w-full rounded-lg border border-zinc-200 bg-white px-3 py-2.5 text-sm text-zinc-900 outline-none transition focus:border-red-500 focus:ring-2 focus:ring-red-100">
                            @{
                                var backends = new[]
                                {
                                    "opencv",
                                    "retinaface",
                                    "mtcnn",
                                    "ssd",
                                    "dlib",
                                    "mediapipe",
                                    "yolov8",
                                    "centerface",
                                    "skip"
                                };
                            }
                            @foreach (var backend in backends)
                            {
                                <option value="@backend" selected="@(Model.DeepfaceDetectorBackend.Equals(backend, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                                    @backend
                                </option>
                            }
                        </select>
                        <p class="mt-2 text-xs text-zinc-500">
                            Backend phát hiện khuôn mặt trước khi DeepFace trích xuất embedding.
                        </p>
                    </div>

                    <div class="rounded-xl border border-zinc-200 bg-zinc-50 px-4 py-4">
                        <p class="text-sm font-semibold text-zinc-900">Phạm vi đồng bộ</p>
                        <ul class="mt-3 space-y-2 text-sm text-zinc-600">
                            <li>Đăng ký thủ công có chụp 4 ảnh khuôn mặt</li>
                            <li>Cập nhật lại bộ ảnh khuôn mặt trong hồ sơ</li>
                            <li>Đăng nhập hoặc xác minh bằng khuôn mặt</li>
                        </ul>
                    </div>
                </div>

                <div class="grid gap-4 md:grid-cols-2">
                    <label class="flex items-start gap-3 rounded-xl border border-zinc-200 bg-white px-4 py-4">
                        <input type="hidden" name="deepfaceAlign" value="false" />
                        <input type="checkbox" name="deepfaceAlign" value="true" checked="@(Model.DeepfaceAlign ? "checked" : null)" class="mt-1 h-4 w-4 accent-red-600" />
                        <span>
                            <span class="block text-sm font-semibold text-zinc-900">Căn chỉnh khuôn mặt</span>
                            <span class="mt-1 block text-sm text-zinc-500">
                                Bật để chuẩn hóa góc mặt trước khi sinh embedding. Nên giữ bật cho đa số trường hợp.
                            </span>
                        </span>
                    </label>

                    <label class="flex items-start gap-3 rounded-xl border border-zinc-200 bg-white px-4 py-4">
                        <input type="hidden" name="deepfaceEnforceDetection" value="false" />
                        <input type="checkbox" name="deepfaceEnforceDetection" value="true" checked="@(Model.DeepfaceEnforceDetection ? "checked" : null)" class="mt-1 h-4 w-4 accent-red-600" />
                        <span>
                            <span class="block text-sm font-semibold text-zinc-900">Bắt buộc phát hiện khuôn mặt</span>
                            <span class="mt-1 block text-sm text-zinc-500">
                                Nếu tắt, hệ thống vẫn cố xử lý ảnh khi detector không tìm thấy mặt rõ ràng.
                            </span>
                        </span>
                    </label>
                </div>

                <div class="flex items-center justify-end gap-3 border-t border-zinc-100 pt-5">
                    <button type="submit" class="rounded-lg bg-red-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-red-700">
                        Lưu cấu hình DeepFace
                    </button>
                </div>
            </form>
        </section>

        <aside class="space-y-6">
            <section class="rounded-2xl border border-zinc-200 bg-white shadow-sm">
                <div class="border-b border-zinc-100 px-6 py-5">
                    <h2 class="text-lg font-bold text-zinc-900">Thông tin đang áp dụng</h2>
                </div>
                <div class="space-y-4 px-6 py-6 text-sm">
                    <div class="flex items-center justify-between gap-4">
                        <span class="text-zinc-500">Detector backend</span>
                        <span class="font-semibold text-zinc-900">@Model.DeepfaceDetectorBackend</span>
                    </div>
                    <div class="flex items-center justify-between gap-4">
                        <span class="text-zinc-500">Align</span>
                        <span class="font-semibold text-zinc-900">@(Model.DeepfaceAlign ? "Bật" : "Tắt")</span>
                    </div>
                    <div class="flex items-center justify-between gap-4">
                        <span class="text-zinc-500">Enforce detection</span>
                        <span class="font-semibold text-zinc-900">@(Model.DeepfaceEnforceDetection ? "Bật" : "Tắt")</span>
                    </div>
                    <div class="flex items-center justify-between gap-4">
                        <span class="text-zinc-500">Ngưỡng DeepFace lưu trong DB</span>
                        <span class="font-semibold text-zinc-900">@Model.DeepfaceConfThreshold.ToString("0.00")</span>
                    </div>
                </div>
            </section>

            <section class="rounded-2xl border border-amber-200 bg-amber-50 shadow-sm">
                <div class="px-6 py-5">
                    <h2 class="text-lg font-bold text-amber-900">Lưu ý</h2>
                    <ul class="mt-3 space-y-2 text-sm text-amber-800">
                        <li>Kiến trúc DeepFace và ngưỡng so khớp hiện được quản lý tại mục Quản lý Model.</li>
                        <li>Trang này quản lý backend detector và hai cờ runtime dùng chung cho mọi luồng DeepFace.</li>
                        <li>App sẽ ưu tiên cấu hình admin trong DB trước, chỉ fallback về <code>appsettings</code> nếu DB chưa có giá trị.</li>
                    </ul>
                </div>
            </section>
        </aside>
    </div>
</div>
