@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_Layout";
}

<div class="min-h-screen flex items-center justify-center bg-red-50/50 px-4 sm:px-6 lg:px-8 relative overflow-hidden py-12">
    <!-- Soft red decorative backgrounds -->
    <div class="absolute w-[400px] h-[400px] bg-red-100 rounded-full blur-[100px] -top-20 -left-20 pointer-events-none"></div>
    <div class="absolute w-[400px] h-[400px] bg-red-100 rounded-full blur-[100px] -bottom-20 -right-20 pointer-events-none"></div>

    <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-3xl shadow-xl relative z-10 border border-red-100">
        <!-- Logo and Heading -->
        <div class="text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-red-50 text-red-600 mb-4 border border-red-100 shadow-inner">
                <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><path d="M12 8v4" /><path d="M12 16h.01" /></svg>
            </div>
            <h2 class="font-outfit text-3xl font-extrabold tracking-tight text-zinc-900">Chào mừng trở lại</h2>
            <p class="mt-2 text-sm text-zinc-500">Chọn phương thức để đăng nhập vào ComplianceHub</p>
        </div>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
        {
            <div class="bg-red-50 border border-red-100 text-red-800 text-sm rounded-xl p-4 flex items-start space-x-2">
                <i class="fa-solid fa-triangle-exclamation mt-0.5 text-red-500"></i>
                <div>
                    @foreach (var modelError in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p class="text-xs">@modelError.ErrorMessage</p>
                    }
                </div>
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="bg-red-50 border border-red-100 text-red-800 text-sm rounded-xl p-4 flex items-center space-x-2">
                <i class="fa-solid fa-circle-check text-red-600"></i>
                <p>@TempData["SuccessMessage"]</p>
            </div>
        }

        <!-- Tab Controllers -->
        <div class="flex p-1.5 bg-zinc-100 rounded-2xl border border-zinc-200/50">
            <button id="btnTabPassword" class="flex-1 py-2.5 text-xs font-semibold rounded-xl transition-all duration-300 bg-red-600 text-white shadow" onclick="switchTab('password')">
                <i class="fa-solid fa-key mr-3"></i>Mật khẩu
            </button>
            <button id="btnTabFace" class="flex-1 py-2.5 text-xs font-semibold rounded-xl transition-all duration-300 text-zinc-500 hover:text-zinc-900" onclick="switchTab('face')">
                <i class="fa-solid fa-face-smile mr-3"></i>Khuôn mặt (AI)
            </button>
        </div>

        <!-- Password Form -->
        <form id="formPassword" asp-action="Login" method="post" class="space-y-5">
            <div>
                <label for="username" class="block text-xs font-semibold text-zinc-700 mb-2">Tên đăng nhập</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-zinc-400">
                        <i class="fa-solid fa-user"></i>
                    </span>
                    <input type="text" id="username" name="username" required 
                           class="block w-full pl-10 pr-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent text-sm transition" 
                           placeholder="Nhập tên đăng nhập..." />
                </div>
            </div>

            <div>
                <label for="password" class="block text-xs font-semibold text-zinc-700 mb-2">Mật khẩu</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-zinc-400">
                        <i class="fa-solid fa-lock"></i>
                    </span>
                    <input type="password" id="password" name="password" required 
                           class="block w-full pl-10 pr-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent text-sm transition" 
                           placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" />
                </div>
            </div>

            <div class="flex items-center justify-between text-xs">
                <div class="flex items-center">
                    <input id="remember-me" name="remember-me" type="checkbox" class="h-4 w-4 text-red-600 focus:ring-red-500 border-zinc-200 rounded bg-zinc-50">
                    <label for="remember-me" class="ml-2 block text-zinc-500">Ghi nhớ đăng nhập</label>
                </div>
                <a href="#" class="font-semibold text-red-600 hover:underline transition">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="w-full py-3 px-4 bg-red-600 hover:bg-red-700 text-white rounded-xl text-sm font-semibold shadow-lg shadow-red-600/10 hover:-translate-y-0.5 transition duration-200">
                Đăng nhập
            </button>
        </form>

        <!-- Biometric Face Form -->
        <div id="formFace" class="space-y-5 hidden">
            <div>
                <label for="faceUsername" class="block text-xs font-semibold text-zinc-700 mb-2">Tên đăng nhập để nhận diện</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-zinc-400">
                        <i class="fa-solid fa-user"></i>
                    </span>
                    <input type="text" id="faceUsername" name="faceUsername" 
                           class="block w-full pl-10 pr-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent text-sm transition" 
                           placeholder="Nhập tên đăng nhập để quét..." />
                </div>
            </div>

            <!-- Webcam Container -->
            <div class="relative rounded-2xl overflow-hidden bg-zinc-950/5 aspect-video border border-zinc-200 flex items-center justify-center">
                <video id="webcam" autoplay muted playsinline class="w-full h-full object-cover transform -scale-x-100"></video>
                <canvas id="photoCanvas" class="hidden"></canvas>
                
                <!-- Scanning animation overlay -->
                <div id="scanLine" class="absolute w-full h-[2px] bg-gradient-to-r from-transparent via-red-500 to-transparent shadow-[0_0_8px_#dc2626] top-0 left-0 hidden"></div>
                
                <!-- No-camera status message -->
                <div id="cameraStatus" class="absolute text-center p-4">
                    <div class="w-12 h-12 rounded-full bg-white text-zinc-400 flex items-center justify-center mx-auto mb-2 border border-zinc-200">
                        <i class="fa-solid fa-video-slash text-base"></i>
                    </div>
                    <p class="text-xs text-zinc-500">Nhấn "Bật Camera" bên dưới để bắt đầu quét khuôn mặt</p>
                </div>
            </div>

            <div class="flex space-x-3">
                <button type="button" id="btnToggleCamera" onclick="startCamera()" class="flex-1 py-2.5 px-4 bg-zinc-100 hover:bg-zinc-200 text-zinc-700 rounded-xl text-xs font-semibold border border-zinc-200 transition">
                    <i class="fa-solid fa-camera mr-3"></i>Bật Camera
                </button>
                <button type="button" id="btnCapture" onclick="captureAndLogin()" disabled class="flex-1 py-2.5 px-4 bg-red-600 hover:bg-red-700 disabled:opacity-50 text-white rounded-xl text-xs font-semibold shadow-lg shadow-red-600/10 transition">
                    <i class="fa-solid fa-fingerprint mr-3"></i>Quét khuôn mặt
                </button>
            </div>
            
            <div id="biometricMsg" class="text-xs text-center font-medium mt-1"></div>
        </div>

        <!-- Footer link -->
        <div class="border-t border-zinc-100 pt-6 text-center text-xs text-zinc-400">
            Chưa có tài khoản? 
            <a asp-action="Register" class="font-semibold text-red-600 hover:underline transition">Đăng ký ngay</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.BiometricLoginConfig = {
            loginUrl: '@Url.Action("BiometricLogin", "Account")'
        };
    </script>
    <script src="~/js/login.js" asp-append-version="true"></script>
}
