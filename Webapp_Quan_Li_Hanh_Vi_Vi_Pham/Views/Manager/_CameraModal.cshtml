<!-- Modal Xem Camera -->
<div id="cameraModal" class="hidden items-center justify-center transition-opacity" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1500; background-color: rgba(15, 23, 42, 0.9); backdrop-filter: blur(8px);">
    <div class="w-full max-w-4xl overflow-hidden saas-card shadow-2xl relative bg-black rounded-2xl border border-slate-800">
        <div class="flex justify-between items-center p-4 border-b border-slate-800 text-white bg-slate-900 absolute top-0 w-full z-10 opacity-80 hover:opacity-100 transition">
            <div class="flex items-center gap-3">
                <i class="fa-solid fa-video text-red-500 animate-pulse"></i>
                <h3 class="font-outfit text-lg font-bold" id="cameraModalTitle">Camera Giám sát</h3>
            </div>
            <button onclick="closeCameraModal()" class="text-slate-400 hover:text-red-500 transition-colors h-8 w-8 flex items-center justify-center rounded-full hover:bg-slate-800">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>
        <div class="relative w-full aspect-video bg-black flex items-center justify-center">
            <div class="text-center" id="cameraLoading">
                <i class="fa-solid fa-spinner fa-spin text-4xl text-red-500 mb-3"></i>
                <p class="text-slate-400 text-sm">Đang kết nối luồng Live Stream...</p>
            </div>
            <video id="cameraVideo" class="hidden w-full h-full object-cover" autoplay loop muted>
                <source src="https://www.w3schools.com/html/mov_bbb.mp4" type="video/mp4">
            </video>
            <!-- Overlay Info -->
            <div id="cameraOverlay" class="hidden absolute bottom-4 left-4 right-4 flex justify-between items-end text-white text-xs text-shadow">
                <div>
                    <p class="font-bold text-lg drop-shadow-md">CAM_01_OFFICE</p>
                    <p class="opacity-80 drop-shadow-md" id="cameraLiveTime"></p>
                </div>
                <div class="bg-red-600 px-2 py-1 rounded font-bold uppercase tracking-wider text-[10px]">
                    <span class="w-1.5 h-1.5 inline-block bg-white rounded-full animate-pulse mr-1"></span> LIVE
                </div>
            </div>
        </div>
    </div>
</div>
