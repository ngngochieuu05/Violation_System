@model Webapp_Quan_Li_Hanh_Vi_Vi_Pham.Models.ViewModels.ViolationDashboardViewModel

@{
    ViewData["Title"] = "Bảng điều khiển Vi phạm";
    Layout = "_Layout";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
    <!-- Top Header -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between border-b border-slate-200 pb-6 gap-4">
        <div>
            <h1 class="font-outfit text-3xl font-extrabold text-slate-900 tracking-tight">Giám sát & Quản lý Vi phạm</h1>
            <p class="text-sm text-slate-500 mt-1">Hệ thống nhận diện hành vi không an toàn lao động trong thời gian thực.</p>
        </div>
        <div class="flex items-center space-x-2">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-red-50 text-red-700 border border-red-100">
                <span class="w-2 h-2 bg-red-600 rounded-full mr-1.5 animate-ping"></span> Real-time Active
            </span>
        </div>
    </div>

    <!-- Stats Cards Row -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <!-- Card 1 -->
        <div class="bg-white rounded-2xl border border-slate-200/80 p-6 flex items-center space-x-4 shadow-sm hover:shadow-md transition duration-300">
            <div class="w-12 h-12 rounded-xl bg-red-50 text-red-600 flex items-center justify-center text-xl flex-shrink-0">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            <div>
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Vi phạm hôm nay</p>
                <h3 class="font-outfit text-3xl font-bold text-slate-900 mt-1">@Model.TotalViolationsToday</h3>
            </div>
        </div>

        <!-- Card 2 -->
        <div class="bg-white rounded-2xl border border-slate-200/80 p-6 flex items-center space-x-4 shadow-sm hover:shadow-md transition duration-300">
            <div class="w-12 h-12 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center text-xl flex-shrink-0">
                <i class="fa-solid fa-clock"></i>
            </div>
            <div>
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Chờ xét duyệt</p>
                <h3 class="font-outfit text-3xl font-bold text-slate-900 mt-1">@Model.PendingReviews</h3>
            </div>
        </div>

        <!-- Card 3 -->
        <div class="bg-white rounded-2xl border border-slate-200/80 p-6 flex items-center space-x-4 shadow-sm hover:shadow-md transition duration-300">
            <div class="w-12 h-12 rounded-xl bg-red-50 text-red-600 flex items-center justify-center text-xl flex-shrink-0">
                <i class="fa-solid fa-circle-exclamation"></i>
            </div>
            <div>
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Nghiêm trọng (High)</p>
                <h3 class="font-outfit text-3xl font-bold text-slate-900 mt-1">@Model.HighSeverityCases</h3>
            </div>
        </div>
    </div>

    <!-- Details Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left 2 columns: Recent Violations -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-slate-100 flex items-center justify-between">
                    <h3 class="font-outfit font-bold text-slate-900 flex items-center space-x-2">
                        <i class="fa-solid fa-clock-rotate-left text-slate-400"></i>
                        <span>Vi phạm được ghi nhận gần đây</span>
                    </h3>
                    <span class="text-xs text-red-600 font-semibold cursor-pointer hover:underline">Xem tất cả</span>
                </div>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse text-sm">
                        <thead>
                            <tr class="bg-slate-50 border-b border-slate-100 text-slate-400 text-xs font-bold uppercase tracking-wider">
                                <th class="p-4 pl-6">Nhân viên</th>
                                <th class="p-4">Loại vi phạm</th>
                                <th class="p-4">Mức độ</th>
                                <th class="p-4">Vị trí</th>
                                <th class="p-4 pr-6">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            @if (!Model.RecentViolations.Any())
                            {
                                <tr>
                                    <td colspan="5" class="p-6 text-center text-slate-400">Chưa ghi nhận vi phạm nào.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in Model.RecentViolations)
                                {
                                    <tr class="hover:bg-slate-50/50 transition">
                                        <td class="p-4 pl-6">
                                            <div class="font-semibold text-slate-900">@item.EmployeeName</div>
                                            <div class="text-xs text-slate-400">Mã NV: @item.EmployeeCode</div>
                                        </td>
                                        <td class="p-4 text-slate-700">@item.ViolationType</td>
                                        <td class="p-4">
                                            @if (item.Severity.Equals("High", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <span class="px-2 py-0.5 bg-red-50 text-red-700 text-xs font-semibold rounded-full border border-red-100">Cao (High)</span>
                                            }
                                            else
                                            {
                                                <span class="px-2 py-0.5 bg-amber-50 text-amber-700 text-xs font-semibold rounded-full border border-amber-100">Trung bình</span>
                                            }
                                        </td>
                                        <td class="p-4 text-slate-500 text-xs flex items-center space-x-1.5 mt-2">
                                            <i class="fa-solid fa-camera text-slate-400"></i>
                                            <span>@item.CameraLocation</span>
                                        </td>
                                        <td class="p-4 pr-6">
                                            @if (item.Status.Equals("Pending", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-800 border border-amber-100">Cho duyet</span>
                                            }
                                            else if (item.Status.Equals("Rejected", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-800 border border-red-100">Tu choi</span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-800 border border-green-100">Da duyet</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right 1 column: YOLO Live detection log -->
        <div class="lg:col-span-1 space-y-6">
            <!-- Video Box (Camera View) -->
            <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm overflow-hidden">
                <div class="p-4 border-b border-slate-100 flex items-center justify-between bg-slate-900">
                    <h3 class="font-outfit font-bold text-white flex items-center space-x-2 text-sm">
                        <i class="fa-solid fa-video text-red-500 animate-pulse"></i>
                        <span>Live Camera - YOLO</span>
                    </h3>
                    <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-red-500/20 text-red-400 border border-red-500/30">REC</span>
                </div>
                <div class="bg-black relative aspect-video flex items-center justify-center overflow-hidden">
                    <img id="yoloCameraStream" src="http://localhost:5000/video_feed" class="w-full h-full object-cover" onerror="this.style.display='none'; document.getElementById('cameraError').style.display='flex';" />
                    <div id="cameraError" class="absolute inset-0 flex-col items-center justify-center text-slate-500 space-y-2 hidden" style="display: none;">
                        <i class="fa-solid fa-video-slash text-3xl mb-2"></i>
                        <p class="text-xs">Camera Offline hoặc chưa bật server Python</p>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-slate-100 flex items-center justify-between">
                    <h3 class="font-outfit font-bold text-slate-900 flex items-center space-x-2">
                        <i class="fa-solid fa-microchip text-red-500"></i>
                        <span>Phát hiện YOLO mới nhất</span>
                    </h3>
                    <span class="w-2 h-2 bg-green-500 rounded-full" title="Model Online"></span>
                </div>
                
                <div class="p-6">
                    <ul class="space-y-4">
                        @if (!Model.LatestDetections.Any())
                        {
                            <li class="text-sm text-slate-400 text-center py-4">Chưa có dữ liệu phân tích YOLO.</li>
                        }
                        else
                        {
                            @foreach (var item in Model.LatestDetections)
                            {
                                <li class="p-4 bg-slate-50 rounded-xl border border-slate-100 flex flex-col space-y-2 hover:bg-slate-100/50 transition">
                                    <div class="flex items-center justify-between">
                                        <span class="text-xs font-bold uppercase tracking-wider text-red-600 bg-red-50 px-2.5 py-0.5 rounded-md border border-red-100">@item.Label</span>
                                        <span class="text-xs font-semibold text-slate-400">@((item.Confidence * 100).ToString("0.0"))% Conf</span>
                                    </div>
                                    <div class="text-[11px] text-slate-500 font-mono">
                                        <span class="font-semibold text-slate-700">Box:</span> @item.BoundingBox
                                    </div>
                                    <div class="text-[10px] text-slate-400 text-right">
                                        Ghi nhận: @item.ProcessedAtUtc.ToLocalTime().ToString("HH:mm:ss")
                                    </div>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
