@{
    ViewData["Title"] = "Đăng ký thành viên";
    Layout = "_Layout";
}

<div class="min-h-screen flex items-center justify-center bg-red-50/50 px-4 sm:px-6 lg:px-8 relative overflow-hidden py-12">
    <!-- Soft red decorative backgrounds -->
    <div class="absolute w-[400px] h-[400px] bg-red-100 rounded-full blur-[100px] -top-20 -left-20 pointer-events-none"></div>
    <div class="absolute w-[400px] h-[400px] bg-red-100 rounded-full blur-[100px] -bottom-20 -right-20 pointer-events-none"></div>

    <div class="max-w-xl w-full space-y-6 bg-white p-8 rounded-3xl shadow-xl relative z-10 border border-red-100">
        <!-- Logo and Heading -->
        <div class="text-center">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-red-50 text-red-600 mb-3 border border-red-100 shadow-inner">
                <i class="fa-solid fa-user-plus text-2xl"></i>
            </div>
            <h2 class="font-outfit text-3xl font-extrabold tracking-tight text-zinc-900">Đăng ký thành viên</h2>
            <p class="mt-1 text-sm text-zinc-500">Tạo tài khoản và cấu hình sinh trắc học nhiều góc độ</p>
        </div>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
        {
            <div class="bg-red-50 border border-red-100 text-red-800 text-sm rounded-xl p-4 flex items-start space-x-2">
                <i class="fa-solid fa-triangle-exclamation mt-0.5 text-red-500"></i>
                <div>
                    @foreach (var modelError in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p class="text-xs">@modelError.ErrorMessage</p>
                    }
                </div>
            </div>
        }

        <form id="formRegister" asp-action="Register" method="post" onsubmit="return validateForm()" class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Left Side: Credentials -->
            <div class="space-y-4">
                <div>
                    <label for="username" class="block text-xs font-semibold text-zinc-700 mb-1.5">Tên đăng nhập</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-zinc-400">
                            <i class="fa-solid fa-user"></i>
                        </span>
                        <input type="text" id="username" name="username" required 
                               class="block w-full pl-10 pr-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent text-sm transition" 
                               placeholder="Tên đăng nhập..." />
                    </div>
                </div>

                <div>
                    <label for="fullName" class="block text-xs font-semibold text-zinc-700 mb-1.5">Họ và tên</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-zinc-400">
                            <i class="fa-solid fa-id-card"></i>
                        </span>
                        <input type="text" id="fullName" name="fullName" required 
                               class="block w-full pl-10 pr-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent text-sm transition" 
                               placeholder="Họ và tên..." />
                    </div>
                </div>

                <div>
                    <label for="password" class="block text-xs font-semibold text-zinc-700 mb-1.5">Mật khẩu</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-zinc-400">
                            <i class="fa-solid fa-lock"></i>
                        </span>
                        <input type="password" id="password" name="password" required 
                               class="block w-full pl-10 pr-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent text-sm transition" 
                               placeholder="Tối thiểu 6 ký tự..." />
                    </div>
                </div>

                <div>
                    <label for="role" class="block text-xs font-semibold text-zinc-700 mb-1.5 font-outfit">Vai trò</label>
                    <select id="role" name="role" onchange="toggleManagerKeySection()"
                            class="block w-full px-3 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent text-sm transition">
                        <option value="Employee">Nhân viên (Employee)</option>
                        <option value="Manager">Quản lý (Manager)</option>
                        <option value="Admin">Quản trị viên (Admin)</option>
                    </select>
                </div>

                <div id="managerKeySection" class="hidden">
                    <label for="managerKey" class="block text-xs font-semibold text-zinc-700 mb-1.5 font-outfit">Khóa kích hoạt doanh nghiệp</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-zinc-400">
                            <i class="fa-solid fa-key"></i>
                        </span>
                        <input type="text" id="managerKey" name="managerKey" value="hieudeptraivcl"
                               class="block w-full pl-10 pr-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent text-sm transition" />
                    </div>
                </div>
            </div>

            <!-- Right Side: Biometrics (Face Register with Multi-angle Instructions) -->
            <div class="flex flex-col space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-zinc-700 mb-1">Đăng ký khuôn mặt</label>
                    <span id="photoCountBadge" class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-red-100 text-red-700">Đã chụp: 0/4</span>
                </div>
                
                <!-- Webcam Container -->
                <div class="relative rounded-2xl overflow-hidden bg-zinc-950/5 aspect-video border border-zinc-200 flex items-center justify-center min-h-[160px]">
                    <video id="webcam" autoplay muted playsinline class="w-full h-full object-cover transform -scale-x-100"></video>
                    <canvas id="photoCanvas" class="hidden"></canvas>
                    
                    <!-- Scan animation overlay -->
                    <div id="scanLine" class="absolute w-full h-[2px] bg-gradient-to-r from-transparent via-red-500 to-transparent shadow-[0_0_8px_#dc2626] top-0 left-0 hidden"></div>

                    <!-- No camera state -->
                    <div id="cameraStatus" class="absolute text-center p-4">
                        <div class="w-10 h-10 rounded-full bg-white text-zinc-400 flex items-center justify-center mx-auto mb-1 border border-zinc-200">
                            <i class="fa-solid fa-camera text-sm"></i>
                        </div>
                        <p class="text-[10px] text-zinc-500 font-medium">Bật camera để bắt đầu</p>
                    </div>
                </div>

                <div class="flex space-x-2">
                    <button type="button" id="btnToggleCamera" onclick="startCamera()" class="flex-1 py-2 px-3 bg-zinc-100 hover:bg-zinc-200 text-zinc-700 rounded-xl text-xs font-semibold border border-zinc-200 transition">
                        Bật Camera
                    </button>
                    <button type="button" id="btnCapture" onclick="capturePhoto()" disabled class="flex-1 py-2 px-3 bg-red-600 hover:bg-red-700 disabled:opacity-50 text-white rounded-xl text-xs font-semibold shadow-md transition">
                        Chụp ảnh
                    </button>
                </div>
                
                <!-- Thumbnail Preview Grid -->
                <div id="thumbsGrid" class="grid grid-cols-4 gap-2 pt-1">
                    <!-- Dynamic thumbs will go here -->
                </div>

                <input type="hidden" id="faceImage" name="faceImage" />
                
                <div id="biometricMsg" class="text-[11px] font-medium text-zinc-500 mt-1"></div>
            </div>

            <!-- Instruction Tag (Vietnamese Guideline for multiple angles) -->
            <div class="md:col-span-2 bg-red-50/70 border border-red-100 rounded-2xl p-4 flex items-start space-x-2.5">
                <i class="fa-solid fa-circle-info text-red-600 text-base mt-0.5"></i>
                <div class="text-xs text-red-800 leading-relaxed space-y-1">
                    <p class="font-bold">Hướng dẫn đăng ký góc độ khuôn mặt:</p>
                    <p>Để tăng tỉ lệ nhận dạng chính xác, vui lòng chụp **ít nhất 4 bức ảnh** theo các góc độ:</p>
                    <ul class="list-disc pl-4 space-y-0.5">
                        <li><strong>Ảnh 1:</strong> Nhìn thẳng trực tiếp vào camera.</li>
                        <li><strong>Ảnh 2:</strong> Nghiêng đầu nhẹ sang bên trái.</li>
                        <li><strong>Ảnh 3:</strong> Nghiêng đầu nhẹ sang bên phải.</li>
                        <li><strong>Ảnh 4:</strong> Hơi cúi đầu xuống hoặc hơi ngẩng đầu lên.</li>
                    </ul>
                </div>
            </div>

            <!-- Submit Button (span 2 cols) -->
            <div class="md:col-span-2 border-t border-zinc-100 pt-4">
                <button type="submit" class="w-full py-3 bg-red-600 hover:bg-red-700 text-white rounded-xl text-sm font-semibold shadow-lg shadow-red-600/20 hover:-translate-y-0.5 transition duration-200">
                    Tạo tài khoản
                </button>
            </div>
        </form>

        <!-- Footer link -->
        <div class="border-t border-zinc-100 pt-4 text-center text-xs text-zinc-400">
            Đã có tài khoản? 
            <a asp-action="Login" class="font-semibold text-red-600 hover:underline transition">Đăng nhập</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/register.js" asp-append-version="true"></script>
}
