@{
    Layout = null;
    ViewData["Title"] = "Nhật ký hệ thống - ComplianceHub";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <style>
            body {
                font-family: 'Inter', sans-serif;
                margin: 0;
                padding: 0;
        }</style>
    </head>
    <body class="bg-zinc-50 text-zinc-900">

        <div class="flex h-screen w-full overflow-hidden">
            <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden md:hidden transition-opacity"></div>

            <aside id="admin-sidebar" class="fixed md:relative w-64 h-full bg-white border-r border-zinc-200 transition-transform duration-300 z-50 md:z-0 -translate-x-full md:translate-x-0 shrink-0 flex flex-col">
                <div class="p-6 border-b border-zinc-200 shrink-0">
                    <h1 class="text-2xl font-bold text-red-600 flex items-center gap-2">
                        <div class="w-8 h-8 bg-red-600 rounded-lg flex items-center justify-center"><span class="text-white font-bold text-lg">C</span></div>
                        <a href="/Admin">ComplianceHub</a>
                    </h1>
                </div>
                <nav class="flex-1 overflow-y-auto p-4 space-y-2">
                    <div><a href="/Admin" class="w-full flex items-center gap-3 px-4 py-2 text-zinc-600 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="7" height="9" x="3" y="3" rx="1" /><rect width="7" height="5" x="14" y="3" rx="1" /><rect width="7" height="9" x="14" y="12" rx="1" /><rect width="7" height="5" x="3" y="16" rx="1" /></svg>Dashboard</a></div>
                    <div><a href="/Admin/Models" class="w-full flex items-center gap-3 px-4 py-2 text-zinc-600 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1-1-1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" /><circle cx="12" cy="12" r="3" /></svg>Quản lý Model</a></div>
                    <div class="space-y-1"><a href="/Admin/Personnel" class="w-full flex items-center gap-3 px-4 py-2 text-zinc-600 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>Quản lý Nhân sự</a></div>
                    <div><a href="/Admin/AuditLogs" class="w-full flex items-center gap-3 px-4 py-2 bg-red-600 text-white rounded-md text-sm font-medium transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" /><path d="M14 2v4a2 2 0 0 0 2 2h4" /><path d="M10 9H8" /><path d="M16 13H8" /><path d="M16 17H8" /></svg>Nhật ký Hệ thống</a></div>
                    <div><a href="/Admin/Settings" class="w-full flex items-center gap-3 px-4 py-2 text-zinc-600 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>Cài đặt Hệ thống</a></div>
                </nav>
                <div class="p-4 border-t border-zinc-200 shrink-0">
                    <a href="/Account/Logout" class="w-full flex items-center gap-3 px-4 py-2 border border-zinc-200 text-zinc-700 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" x2="9" y1="12" y2="12" /></svg>Đăng xuất</a>
                </div>
            </aside>

            <div class="flex flex-col flex-1 min-w-0 h-full overflow-hidden bg-zinc-50">
                <header class="bg-white border-b border-zinc-200 shrink-0 z-40">
                    <div class="flex items-center justify-between px-6 py-4">
                        <h2 class="text-xl font-semibold text-zinc-900">Nhật ký Hệ thống</h2>
                    </div>
                </header>

                <main class="flex-1 overflow-y-auto p-6 space-y-6">
                    <div class="flex items-start justify-between">
                        <div>
                            <h1 class="text-3xl font-bold text-zinc-900 mb-2">Nhật ký Hệ thống</h1>
                            <p class="text-zinc-500">Theo dõi lịch sử hoạt động của toàn bộ hệ thống (Mock Data)</p>
                        </div>
                        <button onclick="downloadMockCSV()" class="flex items-center gap-2 bg-white border border-zinc-200 hover:bg-zinc-50 text-zinc-700 px-4 py-2 rounded-md text-sm font-medium transition-colors shadow-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" x2="12" y1="15" y2="3" /></svg>
                            Xuất CSV
                        </button>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                        <div class="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm">
                            <p class="text-sm text-zinc-500 mb-1">Thành công</p>
                            <p class="text-3xl font-bold text-emerald-600">4</p>
                        </div>
                        <div class="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm">
                            <p class="text-sm text-zinc-500 mb-1">Cảnh báo</p>
                            <p class="text-3xl font-bold text-amber-600">1</p>
                        </div>
                        <div class="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm">
                            <p class="text-sm text-zinc-500 mb-1">Lỗi</p>
                            <p class="text-3xl font-bold text-red-600">1</p>
                        </div>
                        <div class="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm">
                            <p class="text-sm text-zinc-500 mb-1">Tổng hoạt động</p>
                            <p class="text-3xl font-bold text-zinc-900">6</p>
                        </div>
                    </div>

                    <div class="bg-white border border-zinc-200 rounded-xl shadow-sm">
                        <div class="p-6 border-b border-zinc-100 flex items-center justify-between">
                            <div>
                                <h3 class="text-lg font-bold text-zinc-900">Danh sách hoạt động</h3>
                                <p class="text-sm text-zinc-500">Hiển thị các bản ghi gần đây nhất</p>
                            </div>
                            <div class="flex items-center gap-2">
                                <button class="flex items-center gap-2 bg-white border border-zinc-200 hover:bg-zinc-50 text-zinc-700 px-3 py-1.5 rounded-md text-sm font-medium transition-colors shadow-sm">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" /></svg>
                                    Tất cả trạng thái
                                </button>
                            </div>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm text-left whitespace-nowrap">
                                <thead class="text-xs text-zinc-800 bg-zinc-100 border-b border-zinc-200 uppercase font-bold">
                                    <tr>
                                        <th class="px-6 py-4">Thời gian</th>
                                        <th class="px-6 py-4">Người dùng</th>
                                        <th class="px-6 py-4">Hành động</th>
                                        <th class="px-6 py-4">Chi tiết</th>
                                        <th class="px-6 py-4">IP Address</th>
                                        <th class="px-6 py-4">Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="border-b border-zinc-100 hover:bg-zinc-50 transition-colors">
                                        <td class="px-6 py-4 font-medium">2024-06-11 14:35:22</td>
                                        <td class="px-6 py-4">Nguyễn Dương</td>
                                        <td class="px-6 py-4"><span class="px-2 py-1 bg-blue-50 text-blue-700 text-xs rounded-md border border-blue-100">Đăng nhập</span></td>
                                        <td class="px-6 py-4 text-zinc-500">Quản lý đã đăng nhập hệ thống</td>
                                        <td class="px-6 py-4 font-mono text-xs text-zinc-500">192.168.1.50</td>
                                        <td class="px-6 py-4"><span class="px-2.5 py-0.5 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full">Thành công</span></td>
                                    </tr>
                                    <tr class="border-b border-zinc-100 hover:bg-zinc-50 transition-colors">
                                        <td class="px-6 py-4 font-medium">2024-06-11 14:30:15</td>
                                        <td class="px-6 py-4">Admin System</td>
                                        <td class="px-6 py-4"><span class="px-2 py-1 bg-blue-50 text-blue-700 text-xs rounded-md border border-blue-100">Cập nhật cấu hình</span></td>
                                        <td class="px-6 py-4 text-zinc-500">Cập nhật Model Chấm công - ngưỡng độ tin cậy 85%</td>
                                        <td class="px-6 py-4 font-mono text-xs text-zinc-500">127.0.0.1</td>
                                        <td class="px-6 py-4"><span class="px-2.5 py-0.5 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full">Thành công</span></td>
                                    </tr>
                                    <tr class="border-b border-zinc-100 hover:bg-zinc-50 transition-colors">
                                        <td class="px-6 py-4 font-medium">2024-06-11 14:20:33</td>
                                        <td class="px-6 py-4">Admin System</td>
                                        <td class="px-6 py-4"><span class="px-2 py-1 bg-blue-50 text-blue-700 text-xs rounded-md border border-blue-100">Camera</span></td>
                                        <td class="px-6 py-4 text-zinc-500">Camera Tầng 3 - Lối thoát hiểm đã mất kết nối</td>
                                        <td class="px-6 py-4 font-mono text-xs text-zinc-500">127.0.0.1</td>
                                        <td class="px-6 py-4"><span class="px-2.5 py-0.5 bg-amber-100 text-amber-700 text-xs font-semibold rounded-full">Cảnh báo</span></td>
                                    </tr>
                                    <tr class="border-b border-zinc-100 hover:bg-zinc-50 transition-colors">
                                        <td class="px-6 py-4 font-medium">2024-06-11 14:05:45</td>
                                        <td class="px-6 py-4">Trần Văn Minh</td>
                                        <td class="px-6 py-4"><span class="px-2 py-1 bg-blue-50 text-blue-700 text-xs rounded-md border border-blue-100">Đăng nhập</span></td>
                                        <td class="px-6 py-4 text-zinc-500">Mật khẩu không chính xác - Lần 1/3</td>
                                        <td class="px-6 py-4 font-mono text-xs text-zinc-500">192.168.1.182</td>
                                        <td class="px-6 py-4"><span class="px-2.5 py-0.5 bg-red-100 text-red-700 text-xs font-semibold rounded-full">Lỗi</span></td>
                                    </tr>
                                    <tr class="border-b border-zinc-100 hover:bg-zinc-50 transition-colors">
                                        <td class="px-6 py-4 font-medium">2024-06-11 13:58:30</td>
                                        <td class="px-6 py-4">Admin System</td>
                                        <td class="px-6 py-4"><span class="px-2 py-1 bg-blue-50 text-blue-700 text-xs rounded-md border border-blue-100">Webhook Zalo</span></td>
                                        <td class="px-6 py-4 text-zinc-500">Gửi thông báo về vi phạm qua Webhook Zalo</td>
                                        <td class="px-6 py-4 font-mono text-xs text-zinc-500">127.0.0.1</td>
                                        <td class="px-6 py-4"><span class="px-2.5 py-0.5 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full">Thành công</span></td>
                                    </tr>
                                    <tr class="border-b border-zinc-100 hover:bg-zinc-50 transition-colors">
                                        <td class="px-6 py-4 font-medium">2024-06-11 13:45:28</td>
                                        <td class="px-6 py-4">System</td>
                                        <td class="px-6 py-4"><span class="px-2 py-1 bg-blue-50 text-blue-700 text-xs rounded-md border border-blue-100">Dọn dẹp dữ liệu</span></td>
                                        <td class="px-6 py-4 text-zinc-500">Xóa dữ liệu cũ hơn 90 ngày (15 bản ghi)</td>
                                        <td class="px-6 py-4 font-mono text-xs text-zinc-500">127.0.0.1</td>
                                        <td class="px-6 py-4"><span class="px-2.5 py-0.5 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full">Thành công</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </main>
            </div>
        </div>

        <script>
                document.getElementById('mobile-menu-btn').addEventListener('click', function () {
                    document.getElementById('admin-sidebar').classList.toggle('-translate-x-full');
                    document.getElementById('sidebar-overlay').classList.toggle('hidden');
                });
                document.getElementById('sidebar-overlay').addEventListener('click', function () {
                    document.getElementById('admin-sidebar').classList.add('-translate-x-full');
                    this.classList.add('hidden');
                });

                // Hàm giả lập chức năng Xuất file Excel (CSV)
                function downloadMockCSV() {
                    // Dữ liệu CSV giả lập
                    const csvContent = "data:text/csv;charset=utf-8,"
                        + "Thời gian,Người dùng,Hành động,Chi tiết,IP Address,Trạng thái\n"
                        + "2024-06-11 14:35:22,Nguyễn Dương,Đăng nhập,Quản lý đã đăng nhập hệ thống,192.168.1.50,Thành công\n"
                        + "2024-06-11 14:30:15,Admin System,Cập nhật cấu hình AI,Cập nhật Model Chấm công - ngưỡng độ tin cậy 85%,127.0.0.1,Thành công\n"
                        + "2024-06-11 14:20:33,Admin System,Camera mất kết nối,Camera Tầng 3 - Lối thoát hiểm đã mất kết nối,127.0.0.1,Cảnh báo\n"
                        + "2024-06-11 14:05:45,Trần Văn Minh,Đăng nhập thất bại,Mật khẩu không chính xác - Lần 1/3,192.168.1.182,Lỗi\n"
                        + "2024-06-11 13:58:30,Admin System,Webhook Zalo gửi,Gửi thông báo về vi phạm qua Webhook Zalo,127.0.0.1,Thành công\n"
                        + "2024-06-11 13:45:28,System,Dọn dẹp dữ liệu,Xóa dữ liệu cũ hơn 90 ngày (15 bản ghi),127.0.0.1,Thành công";

                    // Mã hóa URI và tạo link tải xuống
                    const encodedUri = encodeURI(csvContent);
                    const link = document.createElement("a");
                    link.setAttribute("href", encodedUri);
                    link.setAttribute("download", "nhat_ky_he_thong.csv");

                    // Tự động bấm tải
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                }
        </script>
    </body>
</html>