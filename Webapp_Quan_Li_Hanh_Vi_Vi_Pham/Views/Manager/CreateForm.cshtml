@model Webapp_Quan_Li_Hanh_Vi_Vi_Pham.Models.Manager.FormTemplate
@{
    ViewData["Title"] = "Thêm biểu mẫu mới";
    Layout = "_ManagerLayout";
}

<div class="max-w-2xl mx-auto space-y-6">
    <div class="flex items-center gap-2 text-sm text-slate-500">
        <a href="@Url.Action("Forms", "Manager")" class="hover:text-red-600 transition">Quản lý biểu mẫu</a>
        <i class="fa-solid fa-chevron-right text-xs"></i>
        <span class="text-slate-800 font-medium">Thêm biểu mẫu mới</span>
    </div>

    <div>
        <h1 class="text-2xl font-bold text-slate-900">Tạo tài liệu biểu mẫu mới</h1>
        <p class="text-sm text-slate-500 mt-1">Cung cấp các biểu mẫu văn bản, tài liệu chuẩn để nhân viên tải về và sử dụng.</p>
    </div>

    <div class="bg-white rounded-[8px] shadow-[0_4px_10px_rgba(0,0,0,0.03),0_0_2px_rgba(0,0,0,0.06),0_2px_6px_rgba(0,0,0,0.12)] border border-slate-200 p-6">
        <form asp-action="CreateForm" method="post" class="space-y-5">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="p-4 bg-red-50 border border-red-200 text-red-600 rounded-[8px] text-sm">
                    <div asp-validation-summary="All" class="text-red-600"></div>
                </div>
            }

            <div>
                <label asp-for="Title" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Tiêu đề biểu mẫu <span class="text-red-500">*</span></label>
                <input asp-for="Title" type="text" placeholder="Ví dụ: Đơn xin nghỉ phép năm, Mẫu báo cáo tiến độ..." required
                       class="w-full text-sm p-3 border border-slate-200 rounded-[8px] outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 transition bg-slate-50/50" />
            </div>

            <div>
                <label asp-for="Description" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Mô tả biểu mẫu</label>
                <textarea asp-for="Description" rows="4" placeholder="Nhập tóm tắt nội dung hoặc hướng dẫn nhân viên cách điền thông tin biểu mẫu..."
                          class="w-full text-sm p-3 border border-slate-200 rounded-[8px] outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 transition bg-slate-50/50 resize-none"></textarea>
            </div>

            <div>
                <label asp-for="FileUrl" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Đường dẫn tệp tin (URL) <span class="text-red-500">*</span></label>
                <div class="relative rounded-[8px] shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                        <i class="fa-solid fa-link text-sm"></i>
                    </div>
                    <input asp-for="FileUrl" type="url" placeholder="https://drive.google.com/file/d/..." required
                           class="w-full text-sm p-3 pl-10 border border-slate-200 rounded-[8px] outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 transition bg-slate-50/50" />
                </div>
                <p class="text-[11px] text-slate-400 mt-1.5">Bạn có thể tải tệp lên Google Drive hoặc OneDrive rồi dán link chia sẻ công khai vào đây.</p>
            </div>

            <div class="border-t border-slate-100 pt-5 flex items-center justify-end gap-3">
                <a href="@Url.Action("Forms", "Manager")" class="px-4 py-2.5 text-sm font-medium text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-[8px] transition">
                    Hủy bỏ
                </a>
                <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-red-600 hover:bg-red-700 rounded-[8px] transition shadow-[0_4px_12px_rgba(220,38,38,0.2)]">
                    <i class="fa-solid fa-floppy-disk mr-1"></i> Lưu biểu mẫu
                </button>
            </div>
        </form>
    </div>
</div>