<section data-tab-panel="messages" class="employee-tab-panel hidden">
    <div class="grid gap-6 lg:grid-cols-[300px_1fr]">
        <div class="rounded-[30px] border border-slate-200/70 bg-white p-5 shadow-sm">
            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-400">
                Danh sách hội thoại nội bộ
            </div>
            <div class="mt-5 space-y-3">
                <button type="button" class="w-full rounded-2xl border border-sky-100 bg-sky-50 p-4 text-left" data-chat-target="manager">
                    <p class="font-semibold text-slate-900">Quản lý trực tiếp</p>
                    <p class="mt-1 text-xs text-slate-500">Trao đổi công việc</p>
                </button>
                <button type="button" class="w-full rounded-2xl border border-slate-200 bg-white p-4 text-left" data-chat-target="hr">
                    <p class="font-semibold text-slate-900">Phòng nhân sự</p>
                    <p class="mt-1 text-xs text-slate-500">Thông tin nhân sự</p>
                </button>
            </div>
        </div>

        <div class="rounded-[30px] border border-slate-200/70 bg-white shadow-sm">
            <div class="border-b border-slate-100 px-6 py-5">
                <h2 class="font-outfit text-2xl font-bold text-slate-900" data-chat-title>Quản lý trực tiếp</h2>
                <p class="text-sm text-slate-500">Tin nhắn được lưu cục bộ trong phiên trình duyệt.</p>
            </div>
            <div class="space-y-4 px-6 py-6 min-h-72" data-chat-thread></div>
            <div class="border-t border-slate-100 p-5">
                <div class="flex gap-3">
                    <input type="text" data-chat-input class="flex-1 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 outline-none focus:border-red-300" placeholder="Nhập tin nhắn..." />
                    <button type="button" data-chat-send class="rounded-2xl bg-red-600 px-5 py-3 text-sm font-semibold text-white">
                        Gửi
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>
