<div data-tab-panel="payroll" class="hidden space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="font-outfit text-2xl font-bold text-slate-900">Quản lý Lương thưởng (Payroll)</h2>
            <p class="text-sm text-slate-500 mt-1">Tính toán, duyệt lương và trả lương hàng tháng cho nhân viên.</p>
        </div>
        <div class="flex gap-2">
            <select id="payrollMonth" class="border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-300">
                <option value="1">Tháng 1</option>
                <option value="2">Tháng 2</option>
                <option value="3">Tháng 3</option>
                <option value="4">Tháng 4</option>
                <option value="5">Tháng 5</option>
                <option value="6" selected>Tháng 6</option>
                <option value="7">Tháng 7</option>
                <option value="8">Tháng 8</option>
                <option value="9">Tháng 9</option>
                <option value="10">Tháng 10</option>
                <option value="11">Tháng 11</option>
                <option value="12">Tháng 12</option>
            </select>
            <select id="payrollYear" class="border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-300">
                <option value="2026" selected>2026</option>
            </select>
            <button onclick="calculatePayroll()" class="bg-slate-800 hover:bg-slate-900 text-white px-4 py-2 rounded-lg text-sm font-medium transition shadow-sm">
                Tính lương tháng này
            </button>
        </div>
    </div>

    <div class="saas-card bg-white">
        <div class="p-4 border-b border-slate-100 bg-slate-50/50 rounded-t-2xl">
            <h3 class="font-bold text-slate-800"><i class="fa-solid fa-money-check-dollar text-slate-400 mr-2"></i>Bảng lương nhân viên</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-slate-600">
                <thead class="text-xs uppercase bg-slate-50 text-slate-500 border-b border-slate-200">
                    <tr>
                        <th class="p-4 py-3 font-bold">Nhân viên</th>
                        <th class="p-4 py-3 font-bold text-right">Lương cơ bản</th>
                        <th class="p-4 py-3 font-bold text-right">Ngày công</th>
                        <th class="p-4 py-3 font-bold text-right">Lương NC</th>
                        <th class="p-4 py-3 font-bold text-right">Thưởng KPI</th>
                        <th class="p-4 py-3 font-bold text-right">Trừ vi phạm</th>
                        <th class="p-4 py-3 font-bold text-right">Thực nhận</th>
                        <th class="p-4 py-3 font-bold text-center">Trạng thái</th>
                        <th class="p-4 py-3 font-bold text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="managerPayrollTbody">
                    <tr><td colspan="7" class="p-8 text-center text-slate-400">Chọn tháng và bấm "Tính lương tháng này" để bắt đầu</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Edit Payroll Modal -->
<div id="editPayrollModal" class="fixed inset-0 z-[1200] hidden items-center justify-center bg-slate-950/70 p-4 backdrop-blur-sm">
    <div class="w-full max-w-md overflow-hidden rounded-[24px] bg-white shadow-2xl">
        <div class="flex items-center justify-between border-b border-slate-100 px-6 py-4">
            <h3 class="font-outfit text-lg font-bold text-slate-900">Chỉnh sửa Lương</h3>
            <button type="button" onclick="closeEditPayrollModal()" class="text-slate-400 hover:text-slate-600 transition">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>
        <div class="p-6 space-y-4">
            <input type="hidden" id="editPayrollId" />
            <div>
                <label class="mb-1 block text-sm font-bold text-slate-700">Lương cơ bản (VNĐ)</label>
                <input type="number" id="editPayrollBase" class="w-full rounded-xl border border-slate-200 px-4 py-2 text-sm focus:border-red-500 focus:ring-2 focus:ring-red-200 outline-none" />
            </div>
            <div>
                <label class="mb-1 block text-sm font-bold text-slate-700">Ngày công chuẩn (Ngày)</label>
                <input type="number" id="editPayrollStandardDays" class="w-full rounded-xl border border-slate-200 px-4 py-2 text-sm focus:border-red-500 focus:ring-2 focus:ring-red-200 outline-none" />
            </div>
            <div>
                <label class="mb-1 block text-sm font-bold text-slate-700">Ngày công thực tế (Ngày)</label>
                <input type="number" id="editPayrollActualDays" class="w-full rounded-xl border border-slate-200 px-4 py-2 text-sm focus:border-red-500 focus:ring-2 focus:ring-red-200 outline-none" />
            </div>
            <div>
                <label class="mb-1 block text-sm font-bold text-slate-700">Thưởng KPI (VNĐ)</label>
                <input type="number" id="editPayrollKpi" class="w-full rounded-xl border border-slate-200 px-4 py-2 text-sm focus:border-red-500 focus:ring-2 focus:ring-red-200 outline-none" />
            </div>
            <p class="text-xs text-slate-500">Lương Thực nhận sẽ được tự động tính toán lại theo công thức mới.</p>
        </div>
        <div class="border-t border-slate-100 bg-slate-50 px-6 py-4 flex justify-end gap-3">
            <button type="button" onclick="closeEditPayrollModal()" class="rounded-xl px-4 py-2 text-sm font-bold text-slate-600 hover:bg-slate-200 transition">Hủy</button>
            <button type="button" onclick="submitEditPayroll()" class="rounded-xl bg-slate-800 px-4 py-2 text-sm font-bold text-white hover:bg-slate-900 transition">Lưu thay đổi</button>
        </div>
    </div>
</div>
