@{
    Layout = null;
    ViewData["Title"] = "Trang chủ - HDPH";
}

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/output.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700&display=swap" rel="stylesheet">
    <style>
            body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-white text-zinc-950 antialiased min-h-screen selection:bg-zinc-900 selection:text-white">

    <header class="sticky top-0 z-50 w-full bg-white/80 border-b border-zinc-200 backdrop-blur-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="p-2 bg-zinc-900 rounded-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-white"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><path d="M12 8v4" /><path d="M12 16h.01" /></svg>
                </div>
                <div class="flex flex-col">
                    <span class="text-xl font-bold text-zinc-950">ComplianceHub</span>
                    <span class="text-xs text-zinc-500">Misconduct Management System</span>
                </div>
            </div>

            <nav class="hidden md:flex items-center gap-8">
                <a href="#features" class="text-sm font-medium text-zinc-950 hover:text-zinc-600 transition-colors">Tính năng</a>
                <a href="#roles" class="text-sm font-medium text-zinc-950 hover:text-zinc-600 transition-colors">Vai trò</a>
                <a href="#about" class="text-sm font-medium text-zinc-950 hover:text-zinc-600 transition-colors">Giới thiệu</a>
            </nav>

            <div class="flex items-center gap-3">
                <button class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-zinc-950 border border-zinc-200 bg-white hover:bg-zinc-100 hover:text-zinc-900 h-9 px-4 py-2">
                    Đăng nhập
                </button>
                <button class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-zinc-950 bg-zinc-900 text-white shadow hover:bg-zinc-800 h-9 px-4 py-2">
                    Đăng ký
                </button>
            </div>
        </div>
    </header>

    <section class="relative w-full py-24 sm:py-32 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-zinc-50 to-blue-50/50"></div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div class="space-y-8">
                    <div class="space-y-4">
                        <div class="inline-flex items-center px-4 py-2 bg-zinc-100 rounded-full border border-zinc-200">
                            <span class="text-sm font-semibold text-zinc-900">✨ Nền tảng quản lý hành vi vi phạm</span>
                        </div>
                        <h1 class="text-balance text-5xl sm:text-6xl font-bold tracking-tight text-zinc-950">
                            Quản lý hành vi vi phạm một cách <span class="text-zinc-900">minh bạch</span> & <span class="text-blue-600">hiệu quả</span>
                        </h1>
                        <p class="text-xl text-zinc-500 leading-relaxed">
                            ComplianceHub giúp tổ chức của bạn xây dựng môi trường làm việc lành mạnh thông qua hệ thống quản lý hành vi vi phạm toàn diện, công bằng và minh bạch.
                        </p>
                    </div>

                    <div class="space-y-3">
                        <div class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-zinc-900 flex-shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" /></svg>
                            <span class="text-base text-zinc-950">Quản lý đơn vị, nhân sự và hành vi vi phạm tập trung</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-zinc-900 flex-shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" /></svg>
                            <span class="text-base text-zinc-950">Quy trình làm việc tự động và minh bạch</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-zinc-900 flex-shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" /></svg>
                            <span class="text-base text-zinc-950">Báo cáo chi tiết và phân tích dữ liệu</span>
                        </div>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-4 pt-4">
                        <button class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-zinc-950 bg-zinc-900 text-white shadow hover:bg-zinc-800 h-11 px-8 group">
                            Bắt đầu ngay
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform"><path d="M5 12h14" /><path d="M12 5l7 7-7 7" /></svg>
                        </button>
                        <button class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-zinc-950 border border-zinc-200 bg-white hover:bg-zinc-100 hover:text-zinc-900 h-11 px-8">
                            Xem demo
                        </button>
                    </div>
                </div>

                <div class="relative h-96 sm:h-[500px] hidden lg:block">
                    <div class="absolute inset-0 bg-gradient-to-br from-zinc-200 to-blue-100 rounded-2xl blur-3xl"></div>
                    <div class="absolute inset-4 bg-white rounded-xl border border-zinc-200 overflow-hidden shadow-sm">
                        <div class="p-6 h-full flex flex-col justify-between">
                            <div class="space-y-4">
                                <div class="h-3 w-32 bg-zinc-200 rounded"></div>
                                <div class="h-3 w-24 bg-blue-100 rounded"></div>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div class="p-4 bg-zinc-50 rounded-lg border border-zinc-200">
                                    <div class="text-2xl font-bold text-zinc-900">3</div>
                                    <div class="text-xs text-zinc-500">Vai trò chính</div>
                                </div>
                                <div class="p-4 bg-blue-50/50 rounded-lg border border-blue-100">
                                    <div class="text-2xl font-bold text-blue-600">∞</div>
                                    <div class="text-xs text-zinc-500">Khả năng mở rộng</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="roles" class="w-full py-24 sm:py-32 bg-zinc-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center space-y-4 mb-16">
                <h2 class="text-balance text-4xl sm:text-5xl font-bold text-zinc-950">
                    Các vai trò & chức năng chính
                </h2>
                <p class="text-xl text-zinc-500 max-w-2xl mx-auto">
                    Mỗi vai trò có những chức năng riêng biệt, được thiết kế để phù hợp với nhu cầu cụ thể của tổ chức
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="group relative overflow-hidden rounded-xl border border-zinc-200 bg-white hover:border-zinc-900 transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
                    <div class="absolute inset-0 bg-gradient-to-br from-zinc-900 to-zinc-700 opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>
                    <div class="relative p-8 space-y-6">
                        <div class="inline-flex p-3 rounded-lg bg-gradient-to-br from-zinc-900 to-zinc-700 text-white">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                        </div>
                        <div class="space-y-2">
                            <h3 class="text-xl font-bold text-zinc-950">Admin - Quản lý hệ thống</h3>
                            <p class="text-sm text-zinc-500 leading-relaxed">Toàn quyền kiểm soát hệ thống và định cấu hình chính sách</p>
                        </div>
                        <div class="space-y-3">
                            <div class="flex items-start gap-3">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-zinc-900 flex-shrink-0 mt-1"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" /></svg>
                                <span class="text-sm text-zinc-950">Quản lý mô hình vi phạm</span>
                            </div>
                            <div class="flex items-start gap-3">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-zinc-900 flex-shrink-0 mt-1"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" /></svg>
                                <span class="text-sm text-zinc-950">Quản lý tài khoản nhân sự</span>
                            </div>
                        </div>
                        <button class="w-full inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors bg-zinc-900 text-white hover:bg-zinc-800 h-9 px-4 py-2 mt-4">Tìm hiểu thêm</button>
                    </div>
                </div>

                <div class="group relative overflow-hidden rounded-xl border border-zinc-200 bg-white hover:border-zinc-900 transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
                    <div class="absolute inset-0 bg-gradient-to-br from-blue-600 to-orange-500 opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>
                    <div class="relative p-8 space-y-6">
                        <div class="inline-flex p-3 rounded-lg bg-gradient-to-br from-blue-600 to-orange-500 text-white">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M3 3v18h18" /><path d="M18 17V9" /><path d="M13 17V5" /><path d="M8 17v-3" /></svg>
                        </div>
                        <div class="space-y-2">
                            <h3 class="text-xl font-bold text-zinc-950">Quản lý - Giám sát</h3>
                            <p class="text-sm text-zinc-500 leading-relaxed">Theo dõi, phê duyệt và quản lý hành vi vi phạm của nhân viên</p>
                        </div>
                        <div class="space-y-3">
                            <div class="flex items-start gap-3">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-zinc-900 flex-shrink-0 mt-1"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" /></svg>
                                <span class="text-sm text-zinc-950">Theo dõi biểu mẫu vi phạm</span>
                            </div>
                            <div class="flex items-start gap-3">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-zinc-900 flex-shrink-0 mt-1"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" /></svg>
                                <span class="text-sm text-zinc-950">Xét duyệt yêu cầu bồi thường</span>
                            </div>
                        </div>
                        <button class="w-full inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors bg-zinc-900 text-white hover:bg-zinc-800 h-9 px-4 py-2 mt-4">Tìm hiểu thêm</button>
                    </div>
                </div>

                <div class="group relative overflow-hidden rounded-xl border border-zinc-200 bg-white hover:border-zinc-900 transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
                    <div class="absolute inset-0 bg-gradient-to-br from-orange-500 to-yellow-500 opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>
                    <div class="relative p-8 space-y-6">
                        <div class="inline-flex p-3 rounded-lg bg-gradient-to-br from-orange-500 to-yellow-500 text-white">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                        </div>
                        <div class="space-y-2">
                            <h3 class="text-xl font-bold text-zinc-950">Nhân viên - Tự quản lý</h3>
                            <p class="text-sm text-zinc-500 leading-relaxed">Quản lý thông tin cá nhân và theo dõi trạng thái yêu cầu của bạn</p>
                        </div>
                        <div class="space-y-3">
                            <div class="flex items-start gap-3">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-zinc-900 flex-shrink-0 mt-1"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" /></svg>
                                <span class="text-sm text-zinc-950">Kiểm tra phê duyệt từ quản lý</span>
                            </div>
                            <div class="flex items-start gap-3">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-zinc-900 flex-shrink-0 mt-1"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" /></svg>
                                <span class="text-sm text-zinc-950">Xem lịch sử vi phạm cá nhân</span>
                            </div>
                        </div>
                        <button class="w-full inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors bg-zinc-900 text-white hover:bg-zinc-800 h-9 px-4 py-2 mt-4">Tìm hiểu thêm</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="features" class="w-full py-24 sm:py-32 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center space-y-4 mb-16">
                <h2 class="text-balance text-4xl sm:text-5xl font-bold text-zinc-950">Tính năng nổi bật</h2>
                <p class="text-xl text-zinc-500 max-w-2xl mx-auto">
                    ComplianceHub cung cấp tất cả những gì bạn cần để quản lý hành vi vi phạm hiệu quả
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <div class="group p-8 rounded-xl border border-zinc-200 bg-white hover:border-zinc-900 hover:bg-zinc-50 transition-all duration-300">
                    <div class="space-y-4">
                        <div class="inline-flex p-3 rounded-lg bg-zinc-100 group-hover:bg-zinc-200 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-zinc-900"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>
                        </div>
                        <div class="space-y-2">
                            <h3 class="text-lg font-semibold text-zinc-950">Xử lý nhanh chóng</h3>
                            <p class="text-sm text-zinc-500 leading-relaxed">Tự động hóa quy trình xử lý vi phạm để giảm thời gian xử lý</p>
                        </div>
                    </div>
                </div>
                <div class="group p-8 rounded-xl border border-zinc-200 bg-white hover:border-zinc-900 hover:bg-zinc-50 transition-all duration-300">
                    <div class="space-y-4">
                        <div class="inline-flex p-3 rounded-lg bg-zinc-100 group-hover:bg-zinc-200 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-zinc-900"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                        </div>
                        <div class="space-y-2">
                            <h3 class="text-lg font-semibold text-zinc-950">Bảo mật & Quyền riêng tư</h3>
                            <p class="text-sm text-zinc-500 leading-relaxed">Dữ liệu nhân viên được bảo vệ với mã hóa cấp doanh nghiệp</p>
                        </div>
                    </div>
                </div>
                <div class="group p-8 rounded-xl border border-zinc-200 bg-white hover:border-zinc-900 hover:bg-zinc-50 transition-all duration-300">
                    <div class="space-y-4">
                        <div class="inline-flex p-3 rounded-lg bg-zinc-100 group-hover:bg-zinc-200 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-zinc-900"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg>
                        </div>
                        <div class="space-y-2">
                            <h3 class="text-lg font-semibold text-zinc-950">Phân tích dữ liệu</h3>
                            <p class="text-sm text-zinc-500 leading-relaxed">Báo cáo chi tiết giúp xác định xu hướng và cải thiện chính sách</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-20 p-12 rounded-2xl bg-gradient-to-r from-zinc-50 to-blue-50/50 border border-zinc-200 text-center space-y-6">
                <h3 class="text-3xl font-bold text-zinc-950">Sẵn sàng tối ưu hóa hệ thống của bạn?</h3>
                <p class="text-lg text-zinc-500 max-w-2xl mx-auto">
                    Hơn 500 tổ chức đang sử dụng hệ thống AI của chúng tôi để tạo môi trường làm việc kỷ luật và an toàn.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
                    <button class="px-8 py-3 bg-zinc-900 hover:bg-zinc-800 text-white font-semibold rounded-lg transition-colors">Liên hệ ngay</button>
                    <button class="px-8 py-3 border border-zinc-200 text-zinc-900 font-semibold rounded-lg hover:bg-zinc-50 transition-colors">Xem tài liệu</button>
                </div>
            </div>
        </div>
    </section>

    <footer class="w-full bg-zinc-950 text-white border-t border-zinc-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
                <div class="space-y-4">
                    <div class="flex items-center gap-3">
                        <div class="p-2 bg-zinc-800 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-white"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><path d="M12 8v4" /><path d="M12 16h.01" /></svg>
                        </div>
                        <span class="text-lg font-bold">ComplianceHub</span>
                    </div>
                    <p class="text-sm text-zinc-400">Nền tảng quản lý hành vi vi phạm toàn diện cho môi trường làm việc hiện đại</p>
                </div>
                <div class="space-y-4">
                    <h4 class="font-semibold text-white">Sản phẩm</h4>
                    <ul class="space-y-2 text-sm text-zinc-400">
                        <li><a href="#" class="hover:text-white transition-colors">Tính năng</a></li>
                        <li><a href="#" class="hover:text-white transition-colors">Bảo mật</a></li>
                    </ul>
                </div>
                <div class="space-y-4">
                    <h4 class="font-semibold text-white">Liên hệ</h4>
