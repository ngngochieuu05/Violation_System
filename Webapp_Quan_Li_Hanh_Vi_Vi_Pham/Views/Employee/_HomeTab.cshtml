<section data-tab-panel="home" class="employee-tab-panel grid gap-8 xl:grid-cols-[1.15fr_0.85fr]">
    <div class="employee-surface rounded-[30px] border border-slate-200/70 bg-white p-6 shadow-sm sm:p-8">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-[0.24em] text-red-500">Trang chủ</p>
                <h3 class="employee-text mt-2 font-outfit text-2xl font-bold text-slate-900">Thông tin cá nhân trong ngày</h3>
            </div>
            <span class="inline-flex items-center rounded-full bg-green-50 px-3 py-1 text-xs font-semibold text-green-700">
                <span class="mr-2 h-2 w-2 rounded-full bg-green-500"></span>
                Phiên làm việc ổn định
            </span>
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-3">
            <div class="employee-muted rounded-2xl border border-slate-200 bg-slate-50 p-5">
                <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Ngày hiện tại</p>
                <p class="employee-text mt-3 text-base font-semibold text-slate-900" data-home-date>--/--/----</p>
            </div>
            <div class="employee-muted rounded-2xl border border-slate-200 bg-slate-50 p-5">
                <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Thời gian</p>
                <p class="employee-text mt-3 font-mono text-2xl font-bold text-slate-900" data-home-time>--:--:--</p>
            </div>
            <div class="employee-muted rounded-2xl border border-slate-200 bg-slate-50 p-5">
                <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Ca làm việc</p>
                <p class="employee-text mt-3 font-outfit text-2xl font-bold text-slate-900">08:00 - 17:00</p>
            </div>
        </div>
    </div>

    <div class="employee-surface rounded-[30px] border border-slate-200/70 bg-white p-6 shadow-sm sm:p-8">
        <div class="flex items-start gap-4">
            <div class="employee-avatar-placeholder relative flex h-24 w-24 items-center justify-center overflow-hidden rounded-[28px] bg-red-50 text-red-600 ring-1 ring-red-100">
                <img data-avatar-image class="absolute inset-0 hidden h-full w-full object-cover" alt="Avatar employee" />
                <i data-avatar-fallback class="fa-solid fa-user text-4xl"></i>
            </div>
            <div class="min-w-0 flex-1">
                <p class="employee-text truncate font-outfit text-3xl font-bold text-slate-900" data-home-name>@User.FindFirst("FullName")?.Value</p>
                <p class="employee-subtext mt-1 truncate text-sm text-slate-500" data-home-username>@User.Identity?.Name</p>
                <p class="employee-subtext mt-3 text-sm text-slate-500">Khu vực này chỉ hiển thị thông tin cá nhân cơ bản của nhân viên.</p>
            </div>
        </div>

        <div class="mt-6 space-y-4">
            <div class="employee-muted rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Mã nhân viên</p>
                <p class="employee-text mt-2 font-semibold text-slate-900" data-profile-id>EMP-2026-014</p>
            </div>
            <div class="employee-muted rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Phòng ban</p>
                <p class="employee-text mt-2 font-semibold text-slate-900" data-profile-department>Khối vận hành</p>
            </div>
            <div class="employee-muted rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Quyền truy cập</p>
                <p class="employee-text mt-2 font-semibold text-slate-900">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
            </div>
        </div>
    </div>
</section>
