@{
    Layout = null;
    ViewData["Title"] = "Cài đặt hệ thống - ComplianceHub";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <style>
            body {
                font-family: 'Inter', sans-serif;
                margin: 0;
                padding: 0;
        }</style>
    </head>
    <body class="bg-zinc-50 text-zinc-900">

        <div class="flex h-screen w-full overflow-hidden">
            <aside id="admin-sidebar" class="fixed md:relative w-64 h-full bg-white border-r border-zinc-200 transition-transform duration-300 z-50 md:z-0 -translate-x-full md:translate-x-0 shrink-0 flex flex-col">
                <div class="p-6 border-b border-zinc-200 shrink-0">
                    <h1 class="text-2xl font-bold text-red-600 flex items-center gap-2">
                        <div class="w-8 h-8 bg-red-600 rounded-lg flex items-center justify-center"><span class="text-white font-bold text-lg">C</span></div>
                        <a href="/Admin">ComplianceHub</a>
                    </h1>
                </div>
                <nav class="flex-1 overflow-y-auto p-4 space-y-2">
                    <div><a href="/Admin" class="w-full flex items-center gap-3 px-4 py-2 text-zinc-600 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="7" height="9" x="3" y="3" rx="1" /><rect width="7" height="5" x="14" y="3" rx="1" /><rect width="7" height="9" x="14" y="12" rx="1" /><rect width="7" height="5" x="3" y="16" rx="1" /></svg>Dashboard</a></div>
                    <div><a href="/Admin/Models" class="w-full flex items-center gap-3 px-4 py-2 text-zinc-600 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" /><circle cx="12" cy="12" r="3" /></svg>Quản lý Model</a></div>
                    <div class="space-y-1"><a href="/Admin/Personnel" class="w-full flex items-center gap-3 px-4 py-2 text-zinc-600 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>Quản lý Nhân sự</a></div>
                    <div><a href="/Admin/AuditLogs" class="w-full flex items-center gap-3 px-4 py-2 text-zinc-600 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" /><path d="M14 2v4a2 2 0 0 0 2 2h4" /><path d="M10 9H8" /><path d="M16 13H8" /><path d="M16 17H8" /></svg>Nhật ký Hệ thống</a></div>
                    <div><a href="/Admin/Settings" class="w-full flex items-center gap-3 px-4 py-2 bg-red-600 text-white rounded-md text-sm font-medium transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>Cài đặt Hệ thống</a></div>
                </nav>
                <div class="p-4 border-t border-zinc-200 shrink-0">
                    <a href="/Account/Logout" class="w-full flex items-center gap-3 px-4 py-2 border border-zinc-200 text-zinc-700 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" x2="9" y1="12" y2="12" /></svg>Đăng xuất</a>
                </div>
            </aside>

            <div class="flex flex-col flex-1 min-w-0 h-full overflow-hidden bg-zinc-50">
                <header class="bg-white border-b border-zinc-200 shrink-0 z-40">
                    <div class="flex items-center justify-between px-6 py-4">
                        <h2 class="text-xl font-semibold text-zinc-900">Cài đặt Hệ thống</h2>
                    </div>
                </header>

                <main class="flex-1 overflow-y-auto p-6 space-y-6">
                    <div>
                        <h1 class="text-3xl font-bold text-zinc-900 mb-2">Cài đặt Hệ thống</h1>
                        <p class="text-zinc-500">Cấu hình các thông số toàn cục của ứng dụng (Mock UI)</p>
                    </div>

                    <div class="w-full">
                        <div class="grid w-full grid-cols-4 bg-zinc-100 rounded-lg p-1 text-sm font-medium mb-6">
                            <button onclick="openTab(event, 'general')" class="tab-link active-tab w-full rounded-md py-1.5 transition-all text-zinc-900 bg-white shadow-sm">Cài đặt chung</button>
                            <button onclick="openTab(event, 'notifications')" class="tab-link w-full rounded-md py-1.5 transition-all text-zinc-500 hover:text-zinc-700">Thông báo</button>
                            <button onclick="openTab(event, 'webhook')" class="tab-link w-full rounded-md py-1.5 transition-all text-zinc-500 hover:text-zinc-700">Webhook</button>
                            <button onclick="openTab(event, 'security')" class="tab-link w-full rounded-md py-1.5 transition-all text-zinc-500 hover:text-zinc-700">Bảo mật</button>
                        </div>

                        <div id="general" class="tab-content block">
                            <div class="bg-white border border-zinc-200 rounded-xl shadow-sm">
                                <div class="p-6 border-b border-zinc-100">
                                    <h3 class="text-lg font-bold text-zinc-900">Cài đặt Cơ sở dữ liệu</h3>
                                    <p class="text-sm text-zinc-500">Cấu hình kết nối cơ sở dữ liệu chính</p>
                                </div>
                                <div class="p-6 space-y-6">
                                    <div class="grid grid-cols-2 gap-6">
                                        <div><label class="block text-sm font-medium text-zinc-900 mb-2">Tên Database</label><input type="text" value="compliance_hub_db" class="w-full px-3 py-2 border border-zinc-200 rounded-md focus:ring-2 focus:ring-red-600 outline-none text-sm" /></div>
                                        <div><label class="block text-sm font-medium text-zinc-900 mb-2">Host</label><input type="text" value="localhost" class="w-full px-3 py-2 border border-zinc-200 rounded-md focus:ring-2 focus:ring-red-600 outline-none text-sm" /></div>
                                        <div><label class="block text-sm font-medium text-zinc-900 mb-2">Port</label><input type="text" value="5432" class="w-full px-3 py-2 border border-zinc-200 rounded-md focus:ring-2 focus:ring-red-600 outline-none text-sm" /></div>
                                        <div><label class="block text-sm font-medium text-zinc-900 mb-2">Người dùng</label><input type="text" value="admin" class="w-full px-3 py-2 border border-zinc-200 rounded-md focus:ring-2 focus:ring-red-600 outline-none text-sm" /></div>
                                    </div>
                                    <div class="border-t border-zinc-100 pt-6">
                                        <h3 class="text-sm font-semibold text-zinc-900 mb-4">Dọn dẹp dữ liệu</h3>
                                        <div class="flex items-center gap-4">
                                            <div class="flex-1">
                                                <label class="block text-sm text-zinc-500 mb-2">Số ngày giữ dữ liệu</label>
                                                <div class="flex items-center gap-2">
                                                    <input type="number" value="90" min="1" class="w-24 px-3 py-2 border border-zinc-200 rounded-md focus:ring-2 focus:ring-red-600 outline-none text-sm" />
                                                    <span class="text-sm text-zinc-500">ngày</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div id="notifications" class="tab-content hidden">
                            <div class="bg-white border border-zinc-200 rounded-xl shadow-sm">
                                <div class="p-6 border-b border-zinc-100">
                                    <h3 class="text-lg font-bold text-zinc-900">Cài đặt Email SMTP</h3>
                                    <p class="text-sm text-zinc-500">Cấu hình gửi email cảnh báo vi phạm</p>
                                </div>
                                <div class="p-6 space-y-4">
                                    <div class="grid grid-cols-2 gap-4">
                                        <div><label class="block text-sm font-medium text-zinc-900 mb-2">SMTP Server</label><input type="text" placeholder="smtp.gmail.com" class="w-full px-3 py-2 border border-zinc-200 rounded-md focus:ring-2 focus:ring-red-600 outline-none text-sm" /></div>
                                        <div><label class="block text-sm font-medium text-zinc-900 mb-2">SMTP Port</label><input type="text" placeholder="587" class="w-full px-3 py-2 border border-zinc-200 rounded-md focus:ring-2 focus:ring-red-600 outline-none text-sm" /></div>
                                        <div><label class="block text-sm font-medium text-zinc-900 mb-2">Email Người gửi</label><input type="email" placeholder="noreply@company.com" class="w-full px-3 py-2 border border-zinc-200 rounded-md focus:ring-2 focus:ring-red-600 outline-none text-sm" /></div>
                                        <div><label class="block text-sm font-medium text-zinc-900 mb-2">Mật khẩu</label><input type="password" placeholder="••••••••" class="w-full px-3 py-2 border border-zinc-200 rounded-md focus:ring-2 focus:ring-red-600 outline-none text-sm" /></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div id="webhook" class="tab-content hidden space-y-6">
                            <div class="bg-white border border-zinc-200 rounded-xl shadow-sm">
                                <div class="p-6 border-b border-zinc-100">
                                    <h3 class="text-lg font-bold text-zinc-900">Telegram Webhook</h3>
                                </div>
                                <div class="p-6 space-y-4">
                                    <div><label class="block text-sm font-medium text-zinc-900 mb-2">Bot Token</label><input type="password" placeholder="123456:ABC-DEF1234ghIkl" class="w-full px-3 py-2 border border-zinc-200 rounded-md focus:ring-2 focus:ring-red-600 outline-none text-sm" /></div>
                                    <div><label class="block text-sm font-medium text-zinc-900 mb-2">Chat ID</label><input type="text" placeholder="-1001234567890" class="w-full px-3 py-2 border border-zinc-200 rounded-md focus:ring-2 focus:ring-red-600 outline-none text-sm" /></div>
                                </div>
                            </div>
                        </div>

                        <div id="security" class="tab-content hidden">
                            <div class="bg-white border border-zinc-200 rounded-xl shadow-sm">
                                <div class="p-6 border-b border-zinc-100">
                                    <h3 class="text-lg font-bold text-zinc-900">Cài đặt Bảo mật</h3>
                                </div>
                                <div class="p-6 space-y-6">
                                    <div class="flex items-start justify-between border-b border-zinc-100 pb-6">
                                        <div>
                                            <h3 class="text-sm font-semibold text-zinc-900">Xác thực hai yếu tố (2FA)</h3>
                                            <p class="text-sm text-zinc-500">Bắt buộc tất cả người dùng sử dụng 2FA</p>
                                        </div>
                                        <input type="checkbox" checked class="w-4 h-4 cursor-pointer accent-red-600" />
                                    </div>
                                    <div>
                                        <h3 class="text-sm font-semibold text-zinc-900 mb-3">Khóa tài khoản sau sai mật khẩu</h3>
                                        <div class="flex items-center gap-4">
                                            <div><label class="block text-xs text-zinc-500 mb-2">Số lần thử tối đa</label><input type="number" value="5" class="w-24 px-3 py-2 border border-zinc-200 rounded-md focus:ring-2 focus:ring-red-600 outline-none text-sm" /></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </main>
            </div>
        </div>

        <script>
                function openTab(evt, tabId) {
                    var i, tabcontents, tablinks;
                    tabcontents = document.getElementsByClassName("tab-content");
                    for (i = 0; i < tabcontents.length; i++) {
                        tabcontents[i].style.display = "none";
                    }
                    tablinks = document.getElementsByClassName("tab-link");
                    for (i = 0; i < tablinks.length; i++) {
                        tablinks[i].className = tablinks[i].className.replace(" bg-white shadow-sm text-zinc-900 active-tab", " text-zinc-500 hover:text-zinc-700");
                    }
                    document.getElementById(tabId).style.display = "block";
                    evt.currentTarget.className = evt.currentTarget.className.replace(" text-zinc-500 hover:text-zinc-700", " bg-white shadow-sm text-zinc-900 active-tab");
                }
        </script>
    </body>
</html>