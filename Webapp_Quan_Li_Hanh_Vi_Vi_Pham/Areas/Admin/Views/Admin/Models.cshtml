@model List<Webapp_Quan_Li_Hanh_Vi_Vi_Pham.Models.Entities.AiModel>
@{
    Layout = null;
    ViewData["Title"] = "Quản lý Model - ComplianceHub";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <style>
            body {
                font-family: 'Inter', sans-serif;
                margin: 0;
                padding: 0;
            }
    </style>
</head>
<body class="bg-zinc-50 text-zinc-900">

    <div class="flex h-screen w-full overflow-hidden">
        <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden md:hidden transition-opacity"></div>

        <aside id="admin-sidebar" class="fixed md:relative w-64 h-full bg-white border-r border-zinc-200 transition-transform duration-300 z-50 md:z-0 -translate-x-full md:translate-x-0 shrink-0 flex flex-col">
            <div class="p-6 border-b border-zinc-200 shrink-0">
                <h1 class="text-2xl font-bold text-red-600 flex items-center gap-2">
                    <div class="w-8 h-8 bg-red-600 rounded-lg flex items-center justify-center">
                        <span class="text-white font-bold text-lg">C</span>
                    </div>
                    <a href="/Admin">ComplianceHub</a>
                </h1>
            </div>

            <nav class="flex-1 overflow-y-auto p-4 space-y-2">
                <div>
                    <a href="/Admin" class="w-full flex items-center gap-3 px-4 py-2 text-zinc-600 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="7" height="9" x="3" y="3" rx="1" /><rect width="7" height="5" x="14" y="3" rx="1" /><rect width="7" height="9" x="14" y="12" rx="1" /><rect width="7" height="5" x="3" y="16" rx="1" /></svg>
                        Dashboard
                    </a>
                </div>
                <div>
                    <a href="/Admin/Models" class="w-full flex items-center gap-3 px-4 py-2 bg-red-600 text-white rounded-md text-sm font-medium transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" /><circle cx="12" cy="12" r="3" /></svg>
                        Quản lý Model
                    </a>
                </div>
                <div class="space-y-1">
                    <a href="/Admin/Personnel" class="w-full flex items-center gap-3 px-4 py-2 text-zinc-600 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                        Quản lý Nhân sự
                    </a>
                </div>
                <div>
                    <a href="/Admin/AuditLogs" class="w-full flex items-center gap-3 px-4 py-2 text-zinc-600 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" /><path d="M14 2v4a2 2 0 0 0 2 2h4" /><path d="M10 9H8" /><path d="M16 13H8" /><path d="M16 17H8" /></svg>
                        Nhật ký Hệ thống
                    </a>
                </div>
                <div>
                    <a href="/Admin/Settings" class="w-full flex items-center gap-3 px-4 py-2 text-zinc-600 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>
                        Cài đặt Hệ thống
                    </a>
                </div>
            </nav>

            <div class="p-4 border-t border-zinc-200 shrink-0">
                <a href="/Account/Logout" class="w-full flex items-center gap-3 px-4 py-2 border border-zinc-200 text-zinc-700 hover:bg-zinc-100 rounded-md text-sm font-medium transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" x2="9" y1="12" y2="12" /></svg>
                    Đăng xuất
                </a>
            </div>
        </aside>

        <div class="flex flex-col flex-1 min-w-0 h-full overflow-hidden bg-zinc-50">
            <header class="bg-white border-b border-zinc-200 shrink-0 z-40">
                <div class="flex items-center justify-between px-6 py-4">
                    <div class="flex items-center gap-4">
                        <button id="mobile-menu-btn" class="md:hidden p-2 text-zinc-600 hover:bg-zinc-100 rounded-md">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><line x1="4" x2="20" y1="12" y2="12" /><line x1="4" x2="20" y1="6" y2="6" /><line x1="4" x2="20" y1="18" y2="18" /></svg>
                        </button>
                        <h2 class="text-2xl font-bold text-zinc-900">Quản lý Model</h2>
                    </div>

                    <div class="flex items-center gap-4">
                        <div class="hidden md:flex bg-zinc-100 rounded-lg px-4 py-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 mr-2"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /></svg>
                            <input type="text" placeholder="Tìm model..." class="bg-transparent outline-none text-sm w-48" />
                        </div>
                        <button class="relative p-2 text-zinc-600 hover:bg-zinc-100 rounded-md">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9" /><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" /></svg>
                        </button>
                        <button class="p-2 text-zinc-600 hover:bg-zinc-100 rounded-md">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                        </button>
                    </div>
                </div>
            </header>

            <main class="flex-1 overflow-auto p-6 space-y-6">

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="bg-emerald-50 text-emerald-700 px-4 py-3 rounded-lg text-sm font-medium border border-emerald-100">@TempData["SuccessMessage"]</div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg text-sm font-medium border border-red-100">@TempData["ErrorMessage"]</div>
                }

                <div class="flex items-start justify-between">
                    <div>
                        <h1 class="text-3xl font-bold text-zinc-900 mb-2">Quản lý Model</h1>
                        <p class="text-zinc-500">Tạo, chỉnh sửa và quản lý các mô hình AI cho phát hiện vi phạm</p>
                    </div>
                    <button onclick="toggleForm('add-form-container')" class="flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="M12 5v14" /></svg>
                        Thêm Model
                    </button>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                    <div class="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm">
                        <div class="flex items-start justify-between">
                            <div>
                                <p class="text-sm text-zinc-500 mb-1">Tổng Model</p>
                                <p class="text-3xl font-bold text-red-600">@Model.Count</p>
                            </div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-600"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" /><circle cx="12" cy="12" r="3" /></svg>
                        </div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm">
                        <div class="flex items-start justify-between">
                            <div>
                                <p class="text-sm text-zinc-500 mb-1">Model Hoạt động</p>
                                <p class="text-3xl font-bold text-green-600">@Model.Count(m => m.IsActive)</p>
                            </div>
                            <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-600 font-bold">✓</div>
                        </div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm">
                        <div class="flex items-start justify-between">
                            <div>
                                <p class="text-sm text-zinc-500 mb-1">Độ chính xác TB (Conf)</p>
                                <p class="text-3xl font-bold text-blue-600">@(Model.Any() ? (Model.Average(m => m.ConfThreshold) * 100).ToString("0.0") : "0")%</p>
                            </div>
                            <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">📊</div>
                        </div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm">
                        <div class="flex items-start justify-between">
                            <div>
                                <p class="text-sm text-zinc-500 mb-1">Tổng lượt sử dụng</p>
                                <p class="text-3xl font-bold text-purple-600">2,590</p>
                            </div>
                            <div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center text-purple-600">📈</div>
                        </div>
                    </div>
                </div>

                <div id="add-form-container" class="hidden">
                    <div class="bg-white border border-zinc-200 rounded-xl shadow-sm mb-6">
                        <div class="p-6 border-b border-zinc-100">
                            <h3 class="text-lg font-bold text-zinc-900">Thêm Model AI Mới</h3>
                            <p class="text-sm text-zinc-500">Nhập thông tin mô hình, cấu hình đường dẫn tệp và các thông số</p>
                        </div>
                        <div class="p-6">
                            <form id="form_add_inline" asp-action="AddAiModel" method="post" class="space-y-4">
                                <input type="hidden" id="add_modelPath" name="modelPath" />

                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-sm font-medium text-zinc-900 mb-2">Tên Model</label>
                                        <input type="text" name="name" required placeholder="VD: Model Phát hiện..." class="w-full px-3 py-2 bg-white border border-zinc-200 rounded-md focus:outline-none focus:ring-2 focus:ring-red-600 text-sm" />
                                    </div>
                                    <div>
                                        <label class="block text-sm font-medium text-zinc-900 mb-2">Phân loại Model</label>
                                        <select id="add_type_select" name="type" required class="w-full px-3 py-2 bg-white border border-zinc-200 rounded-md focus:outline-none focus:ring-2 focus:ring-red-600 text-sm">
                                            <option value="YoloSmoking">Nhận diện Hút thuốc (YOLO)</option>
                                            <option value="YoloLeaving">Nhận diện Rời vị trí (YOLO)</option>
                                            <option value="Deepface">Nhận diện Sinh trắc học (DeepFace)</option>
                                        </select>
                                    </div>
                                </div>

                                <div id="add_yolo_path_div">
                                    <label class="block text-sm font-medium text-zinc-900 mb-2">Đường dẫn tệp (.pt)</label>
                                    <input type="text" id="add_yolo_input" placeholder="yolov8n.pt" class="w-full px-3 py-2 bg-white border border-zinc-200 rounded-md focus:outline-none focus:ring-2 focus:ring-red-600 text-sm" />
                                </div>
                                <div id="add_df_path_div" class="hidden">
                                    <label class="block text-sm font-medium text-zinc-900 mb-2">Kiến trúc (Model Name)</label>
                                    <select id="add_df_select" class="w-full px-3 py-2 bg-white border border-zinc-200 rounded-md focus:outline-none focus:ring-2 focus:ring-red-600 text-sm">
                                        <option value="ArcFace">ArcFace (Đề xuất)</option>
                                        <option value="VGG-Face">VGG-Face</option>
                                        <option value="Facenet">Facenet</option>
                                    </select>
                                </div>

                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label id="add_conf_label" class="block text-sm font-medium text-zinc-900 mb-2">Ngưỡng Conf (0-1)</label>
                                        <input type="number" step="0.01" min="0" max="1" name="confThreshold" value="0.25" required class="w-full px-3 py-2 bg-white border border-zinc-200 rounded-md focus:outline-none focus:ring-2 focus:ring-red-600 text-sm" />
                                    </div>
                                    <div id="add_iou_div">
                                        <label class="block text-sm font-medium text-zinc-900 mb-2">Ngưỡng IoU</label>
                                        <input type="number" step="0.01" min="0" max="1" id="add_iou_input" name="iouThreshold" value="0.45" class="w-full px-3 py-2 bg-white border border-zinc-200 rounded-md focus:outline-none focus:ring-2 focus:ring-red-600 text-sm" />
                                    </div>
                                </div>

                                <div class="flex gap-2 justify-end pt-2">
                                    <button type="button" onclick="toggleForm('add-form-container')" class="px-4 py-2 bg-white border border-zinc-200 text-zinc-700 hover:bg-zinc-50 rounded-md text-sm font-medium transition-colors">Hủy</button>
                                    <input type="submit" value="Lưu Model" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-md text-sm font-medium transition-colors cursor-pointer" />
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="bg-white border border-zinc-200 rounded-xl shadow-sm">
                    <div class="p-6 border-b border-zinc-100">
                        <h3 class="text-xl font-bold text-zinc-900">Danh sách Model (@Model.Count)</h3>
                        <p class="text-sm text-zinc-500">Quản lý tất cả các mô hình AI được triển khai trong hệ thống</p>
                    </div>
                    <div class="p-0 overflow-x-auto">
                        <table class="w-full text-sm text-left whitespace-nowrap">
                            <thead class="text-xs text-zinc-800 bg-zinc-100 border-b border-zinc-200 uppercase font-bold">
                                <tr>
                                    <th class="px-6 py-4">Tên Model</th>
                                    <th class="px-6 py-4">Phân loại / File</th>
                                    <th class="px-6 py-4">Độ chính xác</th>
                                    <th class="px-6 py-4">Version</th>
                                    <th class="px-6 py-4 text-center">Trạng thái</th>
                                    <th class="px-6 py-4 text-center">Lượt dùng</th>
                                    <th class="px-6 py-4">Cập nhật</th>
                                    <th class="px-6 py-4 text-right">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr><td colspan="8" class="px-6 py-8 text-center text-zinc-500">Chưa có dữ liệu. Hãy thêm mới Model AI.</td></tr>
                                }
                                @foreach (var item in Model)
                                {
                                    <tr class="border-b border-zinc-100 hover:bg-zinc-50/50 transition-colors">
                                        <td class="px-6 py-4 font-medium text-zinc-900">@item.Name</td>

                                        <td class="px-6 py-4 text-zinc-500 text-sm">
                                            <span class="block text-zinc-800 font-semibold mb-0.5">@(item.Type.StartsWith("Yolo") ? "Mô hình YOLO" : "Sinh trắc học DeepFace")</span>
                                            <span class="block text-xs font-mono text-zinc-400">@item.ModelPath</span>
                                        </td>

                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-2">
                                                <div class="w-16 bg-zinc-200 rounded-full h-2">
                                                    <div class="bg-red-600 h-2 rounded-full" style="width: @(item.ConfThreshold * 100)%"></div>
                                                </div>
                                                <span class="text-sm font-medium text-zinc-800">@(item.ConfThreshold * 100)%</span>
                                            </div>
                                        </td>

                                        <td class="px-6 py-4 font-mono text-sm text-zinc-600">1.0.0</td>

                                        <td class="px-6 py-4 text-center">
                                            <span class="px-3 py-1 rounded-full text-xs font-semibold @(item.IsActive ? "bg-emerald-100 text-emerald-700" : "bg-zinc-100 text-zinc-600")">
                                                @(item.IsActive ? "Hoạt động" : "Vô hiệu")
                                            </span>
                                        </td>

                                        <td class="px-6 py-4 text-zinc-500 font-medium text-center">0</td>

                                        <td class="px-6 py-4 text-zinc-500 text-sm">@item.CreatedAtUtc.ToString("dd/MM/yyyy")</td>

                                        <td class="px-6 py-4">
                                            <div class="flex items-center justify-end gap-2">
                                                <button type="button" onclick="navigator.clipboard.writeText('@item.ModelPath'); alert('Đã sao chép đường dẫn file!');" class="p-1.5 bg-zinc-100 text-zinc-500 hover:text-blue-600 hover:bg-blue-100 rounded-md transition" title="Sao chép tên file">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2" /><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" /></svg>
                                                </button>

                                                <button type="button" onclick="openEditModal('@item.Id', '@item.Name', '@item.Type', '@item.ModelPath', '@item.ConfThreshold.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)', '@item.IouThreshold.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)')" class="p-1.5 bg-zinc-100 text-zinc-500 hover:text-amber-600 hover:bg-amber-100 rounded-md transition" title="Hiệu chỉnh">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" /></svg>
                                                </button>

                                                <form asp-action="ToggleAiModel" method="post" class="m-0 inline-block">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="p-1.5 bg-zinc-100 text-zinc-500 hover:text-emerald-600 hover:bg-emerald-100 rounded-md transition cursor-pointer" title="@(item.IsActive ? "Tắt mô hình" : "Bật mô hình")">
                                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18.36 6.64a9 9 0 1 1-12.73 0" /><line x1="12" y1="2" x2="12" y2="12" /></svg>
                                                    </button>
                                                </form>

                                                @if (!item.IsActive)
                                                {
                                                    <form asp-action="DeleteAiModel" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa mô hình này vĩnh viễn?')" class="m-0 inline-block">
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="p-1.5 bg-zinc-100 text-zinc-500 hover:text-red-600 hover:bg-red-100 rounded-md transition cursor-pointer" title="Xóa bỏ">
                                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18" /><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" /><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" /></svg>
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <div id="unifiedEditModal" class="fixed inset-0 z-[60] hidden">
        <div class="fixed inset-0 bg-zinc-900/40 backdrop-blur-sm transition-opacity" onclick="closeModal('unifiedEditModal')"></div>
        <div class="fixed inset-0 flex items-center justify-center p-4">
            <div class="bg-white rounded-2xl shadow-xl w-full max-w-md overflow-hidden transform transition-all relative z-10">
                <div class="px-6 py-4 border-b border-zinc-100 flex items-center justify-between">
                    <h3 class="text-lg font-bold text-zinc-900">Hiệu chỉnh Model</h3>
                    <button type="button" onclick="closeModal('unifiedEditModal')" class="text-zinc-400 hover:text-zinc-700">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>
                <form id="form_edit_unified" asp-action="EditAiModel" method="post">
                    <input type="hidden" id="edit_id" name="id" />
                    <input type="hidden" id="edit_modelPath" name="modelPath" />
                    <div class="p-6 space-y-4">
                        <div>
                            <label class="block text-xs font-semibold text-zinc-700 mb-1.5">Tên mô hình</label>
                            <input type="text" id="edit_name" name="name" required class="w-full px-3 py-2 bg-zinc-50 border border-zinc-200 rounded-lg text-sm focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500" />
                        </div>
                        <div id="edit_yolo_path_div">
                            <label class="block text-xs font-semibold text-zinc-700 mb-1.5">Đường dẫn tệp (.pt)</label>
                            <input type="text" id="edit_yolo_input" class="w-full px-3 py-2 bg-zinc-50 border border-zinc-200 rounded-lg text-sm focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500" />
                        </div>
                        <div id="edit_df_path_div" class="hidden">
                            <label class="block text-xs font-semibold text-zinc-700 mb-1.5">Kiến trúc (Model Name)</label>
                            <select id="edit_df_select" class="w-full px-3 py-2 bg-zinc-50 border border-zinc-200 rounded-lg text-sm focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500">
                                <option value="ArcFace">ArcFace</option>
                                <option value="VGG-Face">VGG-Face</option>
                                <option value="Facenet">Facenet</option>
                            </select>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label id="edit_conf_label" class="block text-xs font-semibold text-zinc-700 mb-1.5">Ngưỡng Conf</label>
                                <input type="number" step="0.01" min="0" max="1" id="edit_conf" name="confThreshold" required class="w-full px-3 py-2 bg-zinc-50 border border-zinc-200 rounded-lg text-sm focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500" />
                            </div>
                            <div id="edit_iou_div">
                                <label class="block text-xs font-semibold text-zinc-700 mb-1.5">Ngưỡng IoU</label>
                                <input type="number" step="0.01" min="0" max="1" id="edit_iou" name="iouThreshold" required class="w-full px-3 py-2 bg-zinc-50 border border-zinc-200 rounded-lg text-sm focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500" />
                            </div>
                        </div>
                    </div>
                    <div class="px-6 py-4 bg-zinc-50 border-t border-zinc-100 flex justify-end gap-2">
                        <button type="button" onclick="closeModal('unifiedEditModal')" class="px-4 py-2 text-zinc-600 bg-white border border-zinc-200 rounded-lg text-sm font-medium hover:bg-zinc-50">Hủy</button>
                        <input type="submit" value="Cập nhật" class="px-4 py-2 bg-red-600 text-white rounded-lg text-sm font-medium hover:bg-red-700 cursor-pointer" />
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
            document.getElementById('mobile-menu-btn').addEventListener('click', function () {
                document.getElementById('admin-sidebar').classList.toggle('-translate-x-full');
                document.getElementById('sidebar-overlay').classList.toggle('hidden');
            });
            document.getElementById('sidebar-overlay').addEventListener('click', function () {
                document.getElementById('admin-sidebar').classList.add('-translate-x-full');
                this.classList.add('hidden');
            });

            function toggleForm(id) {
                const form = document.getElementById(id);
                form.classList.toggle('hidden');
            }

            function closeModal(id) { document.getElementById(id).classList.add('hidden'); }

            document.getElementById('add_type_select').addEventListener('change', function () {
                const isDF = this.value === 'Deepface';
                document.getElementById('add_yolo_path_div').classList.toggle('hidden', isDF);
                document.getElementById('add_df_path_div').classList.toggle('hidden', !isDF);
                document.getElementById('add_iou_div').classList.toggle('hidden', isDF);
                document.getElementById('add_conf_label').innerText = isDF ? 'Khoảng cách (Distance)' : 'Ngưỡng Conf (0-1)';
                document.getElementById('add_iou_input').required = !isDF;
                if (isDF) document.getElementById('add_iou_input').value = '0.00';
            });

            document.getElementById('form_add_inline').addEventListener('submit', function () {
                const isDF = document.getElementById('add_type_select').value === 'Deepface';
                document.getElementById('add_modelPath').value = isDF ? document.getElementById('add_df_select').value : document.getElementById('add_yolo_input').value;
            });

            function openEditModal(id, name, type, path, conf, iou) {
                document.getElementById('edit_id').value = id;
                document.getElementById('edit_name').value = name;
                document.getElementById('edit_conf').value = conf;
                document.getElementById('edit_iou').value = iou;

                const isDF = type === 'Deepface';
                document.getElementById('edit_yolo_path_div').classList.toggle('hidden', isDF);
                document.getElementById('edit_df_path_div').classList.toggle('hidden', !isDF);
                document.getElementById('edit_iou_div').classList.toggle('hidden', isDF);
                document.getElementById('edit_conf_label').innerText = isDF ? 'Khoảng cách (Distance)' : 'Ngưỡng Conf (0-1)';

                if (isDF) {
                    document.getElementById('edit_df_select').value = path;
                    document.getElementById('edit_iou').required = false;
                } else {
                    document.getElementById('edit_yolo_input').value = path;
                    document.getElementById('edit_iou').required = true;
                }
                document.getElementById('unifiedEditModal').classList.remove('hidden');
            }

            document.getElementById('form_edit_unified').addEventListener('submit', function () {
                const isDF = document.getElementById('edit_yolo_path_div').classList.contains('hidden');
                document.getElementById('edit_modelPath').value = isDF ? document.getElementById('edit_df_select').value : document.getElementById('edit_yolo_input').value;
            });
    </script>
</body>
</html>