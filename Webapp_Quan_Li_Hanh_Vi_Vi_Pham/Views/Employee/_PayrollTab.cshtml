<section data-tab-panel="payroll" class="employee-tab-panel hidden">
    <div class="grid gap-8 lg:grid-cols-1 max-w-4xl mx-auto">
        <div class="employee-surface rounded-[2rem] border border-white/60 bg-white/90 backdrop-blur-xl p-6 shadow-xl sm:p-8 relative overflow-hidden">
            <div class="absolute -right-20 -top-20 h-48 w-48 rounded-full bg-red-100 blur-3xl opacity-50"></div>
            <div class="flex items-center justify-between border-b border-slate-100 pb-5 relative z-10">
                <div>
                    <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-red-500">Lương Thưởng</p>
                    <h3 class="mt-2 font-outfit text-2xl font-bold text-slate-900 employee-text">Phiếu lương điện tử</h3>
                    <p class="mt-1 text-sm text-slate-500 employee-subtext">Kỳ lương: Tháng <span class="font-bold text-slate-700 employee-text">05/2026</span></p>
                </div>
                <div class="flex flex-col items-end">
                    <span class="inline-flex items-center rounded-full bg-green-50 px-3 py-1 text-xs font-semibold text-green-700 mb-2 border border-green-200 shadow-sm">
                        <span class="mr-2 h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>Đã thanh toán
                    </span>
                    <button type="button" id="unlockPayrollBtn" class="rounded-xl bg-slate-800 px-4 py-2 text-xs font-bold text-white shadow-md transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:bg-slate-700 hover:shadow-lg">
                        <i class="fa-solid fa-lock mr-2 text-amber-400"></i>Xem chi tiết
                    </button>
                </div>
            </div>

            <div class="mt-8 space-y-6 relative z-10">
                <!-- Thu nhập -->
                <div>
                    <h4 class="text-sm font-bold text-slate-800 mb-3 employee-text"><i class="fa-solid fa-arrow-trend-up text-green-500 mr-2"></i>Thu nhập</h4>
                    <div class="employee-muted rounded-[1.5rem] border border-slate-100 bg-slate-50/70 p-5 space-y-4 shadow-sm backdrop-blur-sm">
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-medium text-slate-600 employee-text">Lương cơ bản</span>
                            <span class="payroll-secure-data blur-md select-none font-mono text-base font-bold text-slate-900 employee-text transition-all duration-300">15,000,000 ₫</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-medium text-slate-600 employee-text">Lương làm thêm giờ (OT)</span>
                            <span class="payroll-secure-data blur-md select-none font-mono text-base font-bold text-slate-900 employee-text transition-all duration-300">2,450,000 ₫</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-medium text-slate-600 employee-text">Phụ cấp (Ăn trưa, Xăng xe)</span>
                            <span class="payroll-secure-data blur-md select-none font-mono text-base font-bold text-slate-900 employee-text transition-all duration-300">1,200,000 ₫</span>
                        </div>
                    </div>
                </div>

                <!-- Khấu trừ -->
                <div>
                    <h4 class="text-sm font-bold text-slate-800 mb-3 employee-text"><i class="fa-solid fa-arrow-trend-down text-red-500 mr-2"></i>Khấu trừ</h4>
                    <div class="rounded-[1.5rem] border border-red-50 bg-red-50/30 p-5 space-y-4 shadow-sm backdrop-blur-sm">
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-medium text-slate-600 employee-text">Thuế TNCN</span>
                            <span class="payroll-secure-data blur-md select-none font-mono text-base font-bold text-red-600 transition-all duration-300">- 850,000 ₫</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-medium text-slate-600 employee-text">Bảo hiểm (BHXH, BHYT, BHTN)</span>
                            <span class="payroll-secure-data blur-md select-none font-mono text-base font-bold text-red-600 transition-all duration-300">- 1,575,000 ₫</span>
                        </div>
                    </div>
                </div>

                <!-- Tổng thực nhận -->
                <div class="rounded-[1.5rem] border border-green-200 bg-gradient-to-r from-green-50 to-emerald-50 p-6 mt-4 flex items-center justify-between shadow-md">
                    <div>
                        <p class="text-xs font-bold text-green-700 uppercase tracking-widest">Tổng thực nhận (Net Pay)</p>
                        <p class="text-[10px] font-semibold text-green-600 mt-1"><i class="fa-solid fa-building-columns mr-1"></i>Đã chuyển khoản Techcombank ****1234</p>
                    </div>
                    <span class="payroll-secure-data blur-md select-none font-outfit text-3xl font-black text-green-700 transition-all duration-300 drop-shadow-sm">16,225,000 ₫</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- PIN Verification Modal -->
<div id="payrollPinModal" class="hidden items-center justify-center transition-opacity" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1500; background-color: rgba(15, 23, 42, 0.75); backdrop-filter: blur(8px);">
    <div class="w-full max-w-sm overflow-hidden border border-slate-200 bg-white shadow-2xl p-6 relative transform transition-all duration-300" id="payrollPinModalContent" style="border-radius: 2rem; transform: scale(0.95); opacity: 0;">
        <button type="button" id="closePayrollPinModal" class="absolute top-4 right-4 text-slate-400 hover:text-red-500 transition-colors h-8 w-8 flex items-center justify-center rounded-full hover:bg-red-50">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
        <div class="text-center mb-6 mt-2">
            <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-red-50 mb-4 text-red-600 shadow-inner">
                <i class="fa-solid fa-shield-halved text-3xl"></i>
            </div>
            <h3 class="font-outfit text-2xl font-bold text-slate-900">Xác thực bảo mật</h3>
            <p class="text-sm text-slate-500 mt-2">Vui lòng nhập mã PIN để mở khóa hiển thị số liệu phiếu lương.</p>
        </div>
        
        <div class="space-y-5">
            <div class="relative">
                <input type="password" id="payrollPinInput" maxlength="6" class="w-full text-center font-mono text-3xl border-2 border-slate-200 bg-slate-50 px-4 py-4 outline-none focus:border-red-400 focus:bg-white transition shadow-inner text-slate-800" placeholder="••••" style="letter-spacing: 0.75em; border-radius: 1.5rem;" />
            </div>
            <p id="payrollPinError" class="text-xs font-semibold text-red-600 text-center hidden"><i class="fa-solid fa-triangle-exclamation mr-1"></i>Mã PIN không đúng. Vui lòng thử lại.</p>
            
            <button type="button" id="verifyPayrollPinBtn" class="w-full bg-red-600 px-5 py-4 text-sm font-bold text-white shadow-lg transition-all hover:bg-red-700 hover:shadow-xl" style="border-radius: 1.5rem;">
                Mở khóa dữ liệu
            </button>
            <div class="flex items-center justify-center gap-2 text-center text-xs text-slate-400 mt-4">
                <i class="fa-solid fa-circle-info"></i>
                <span>Mã PIN demo: <strong class="text-slate-600">1234</strong></span>
            </div>
        </div>
    </div>
</div>
