@{
    ViewData["Title"] = "Workspace Nhân viên";
    Layout = "_Layout";
    var initialTab = (Context.Request.Query["tab"].ToString() ?? "home").ToLowerInvariant();
    if (string.IsNullOrWhiteSpace(initialTab))
    {
        initialTab = "home";
    }
}

<style>
    .employee-dark body,
    body.employee-dark {
        background-color: #0f172a !important;
        color: #e2e8f0 !important;
    }

    body.employee-dark .employee-surface {
        background: #111827 !important;
        border-color: rgba(148, 163, 184, 0.18) !important;
        color: #e2e8f0 !important;
    }

    body.employee-dark .employee-muted {
        background: #1e293b !important;
        color: #cbd5e1 !important;
        border-color: rgba(148, 163, 184, 0.14) !important;
    }

    body.employee-dark .employee-text {
        color: #e2e8f0 !important;
    }

    body.employee-dark .employee-subtext {
        color: #94a3b8 !important;
    }

    body.employee-dark .employee-input {
        background: #1e293b !important;
        border-color: rgba(148, 163, 184, 0.18) !important;
        color: #e2e8f0 !important;
    }

    body.employee-dark .employee-tab-shell {
        background: #111827 !important;
        border-color: rgba(148, 163, 184, 0.18) !important;
    }

    body.employee-dark .employee-avatar-placeholder {
        background: #1e293b !important;
        color: #f87171 !important;
    }
</style>

<div class="min-h-screen bg-[radial-gradient(circle_at_top,#fee2e2_0%,#f8fafc_42%,#f8fafc_100%)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8" data-employee-app data-initial-tab="@initialTab">
        <section class="relative overflow-hidden rounded-[32px] bg-white text-black shadow-2xl shadow-slate-200/60">
            <div class="absolute -top-16 -right-12 h-48 w-48 rounded-full bg-slate-100 blur-2xl"></div>
            <div class="absolute bottom-0 left-1/3 h-32 w-32 rounded-full bg-slate-100 blur-xl"></div>
            <div class="relative grid gap-6 px-6 py-8 sm:px-8 lg:grid-cols-[1.45fr_1fr] lg:items-end lg:px-10">
                <div class="space-y-5">
                    <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-100 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.24em] backdrop-blur-sm text-black">
                        <i class="fa-solid fa-user-check text-[11px]"></i>
                        Employee Workspace
                    </span>
                    <div class="space-y-3">
                        <h1 class="font-outfit text-3xl font-extrabold tracking-tight sm:text-4xl text-black">
                            Xin chào, <span data-employee-name>@User.FindFirst("FullName")?.Value</span>
                        </h1>
                        <p class="max-w-2xl text-sm leading-6 text-gray-600 sm:text-base">
                            Trang chủ chỉ hiển thị thông tin cá nhân và thời gian hiện tại. Mọi chức năng như chấm công, nhắn tin,
                            gửi đơn, profile và setting được mở theo từng tab bên dưới.
                        </p>
                    </div>
                    <div class="flex flex-wrap gap-3">
                        <button type="button" data-tab-trigger="attendance" class="inline-flex items-center rounded-2xl bg-red-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-red-700">
                            Mở chấm công
                        </button>
                        <button type="button" data-tab-trigger="requests" class="inline-flex items-center rounded-2xl border border-slate-200 bg-slate-100 px-4 py-2.5 text-sm font-semibold text-black backdrop-blur-sm transition hover:bg-slate-200">
                            Mở đơn từ
                        </button>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4 backdrop-blur-sm">
                        <p class="text-xs uppercase tracking-[0.2em] text-gray-500">Vai trò</p>
                        <p class="mt-3 font-outfit text-2xl font-bold text-black">Employee</p>
                    </div>
                    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4 backdrop-blur-sm">
                        <p class="text-xs uppercase tracking-[0.2em] text-gray-500">Trạng thái</p>
                        <p class="mt-3 font-outfit text-2xl font-bold text-black" data-live-status>Online</p>
                    </div>
                    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4 backdrop-blur-sm">
                        <p class="text-xs uppercase tracking-[0.2em] text-gray-500">Ngày</p>
                        <p class="mt-3 text-sm font-semibold text-black" data-live-date>--/--/----</p>
                    </div>
                    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4 backdrop-blur-sm">
                        <p class="text-xs uppercase tracking-[0.2em] text-gray-500">Giờ hiện tại</p>
                        <p class="mt-3 font-mono text-lg font-semibold text-black" data-live-time>--:--:--</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="rounded-[30px] border border-slate-200/70 bg-white p-3 shadow-sm">
            <div class="grid gap-3 sm:grid-cols-3 xl:grid-cols-6">
                <button type="button" data-tab-trigger="home" class="employee-tab-btn rounded-2xl px-4 py-3 text-sm font-semibold text-slate-600 transition hover:bg-red-50 hover:text-red-600">
                    <i class="fa-solid fa-house mr-2"></i>Trang chủ
                </button>
                <button type="button" data-tab-trigger="attendance" class="employee-tab-btn rounded-2xl px-4 py-3 text-sm font-semibold text-slate-600 transition hover:bg-red-50 hover:text-red-600">
                    <i class="fa-solid fa-fingerprint mr-2"></i>Chấm công
                </button>
                <button type="button" data-tab-trigger="messages" class="employee-tab-btn rounded-2xl px-4 py-3 text-sm font-semibold text-slate-600 transition hover:bg-red-50 hover:text-red-600">
                    <i class="fa-solid fa-comments mr-2"></i>Tin nhắn
                </button>
                <button type="button" data-tab-trigger="requests" class="employee-tab-btn rounded-2xl px-4 py-3 text-sm font-semibold text-slate-600 transition hover:bg-red-50 hover:text-red-600">
                    <i class="fa-solid fa-file-signature mr-2"></i>Đơn từ
                </button>
                <button type="button" data-tab-trigger="profile" class="employee-tab-btn rounded-2xl px-4 py-3 text-sm font-semibold text-slate-600 transition hover:bg-red-50 hover:text-red-600">
                    <i class="fa-solid fa-id-badge mr-2"></i>Profile
                </button>
                <button type="button" data-tab-trigger="settings" class="employee-tab-btn rounded-2xl px-4 py-3 text-sm font-semibold text-slate-600 transition hover:bg-red-50 hover:text-red-600">
                    <i class="fa-solid fa-gear mr-2"></i>Setting
                </button>
            </div>
        </section>

        <partial name="_HomeTab" />
        <partial name="_AttendanceTab" />
        <partial name="_MessagesTab" />
        <partial name="_RequestsTab" />
        <partial name="_ProfileTab" />
        <partial name="_SettingsTab" />
    </div>
</div>

@section Scripts {
    <script src="~/js/employee.js" asp-append-version="true"></script>
}
