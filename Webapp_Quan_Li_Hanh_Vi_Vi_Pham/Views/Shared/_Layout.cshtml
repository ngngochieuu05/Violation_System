<!DOCTYPE html>
<html lang="vi" class="h-full bg-slate-50">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ Thống Quản Lý Vi Phạm & Nhân Sự</title>
    
    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- CSS: Tailwind & Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }
        h1, h2, h3, h4, h5, h6, .font-outfit {
            font-family: 'Outfit', sans-serif;
        }
        /* Custom Glassmorphism */
        .glass-panel {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.25);
        }
        .glass-navbar {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }
    </style>
</head>
<body class="flex flex-col min-h-screen text-slate-800">

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- Header / Glassmorphic Navbar (Only show after login) -->
        <header class="sticky top-0 z-50">
            <nav class="glass-navbar py-3">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="flex items-center justify-between h-14">
                        <!-- Brand -->
                        <div class="flex items-center">
                            <a class="flex items-center space-x-2 text-red-600 hover:text-red-700 transition" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fa-solid fa-shield-halved text-2xl text-red-600"></i>
                                <span class="font-outfit font-extrabold text-xl tracking-tight text-slate-900">Compliance<span class="text-red-600">Hub</span></span>
                            </a>
                        </div>
                        
                        <!-- Navigation Menu -->
                        <div class="flex items-center space-x-6">
                            @if (User.IsInRole("Admin"))
                            {
                                <a class="text-sm font-medium text-slate-600 hover:text-red-600 transition flex items-center space-x-1" asp-area="" asp-controller="Violations" asp-action="Index">
                                    <i class="fa-solid fa-chart-line text-slate-400"></i>
                                    <span>Dashboard</span>
                                </a>
                                <a class="text-sm font-medium text-slate-600 hover:text-red-600 transition flex items-center space-x-1" asp-area="Admin" asp-controller="Admin" asp-action="Index">
                                    <i class="fa-solid fa-sliders text-slate-400"></i>
                                    <span>Cấu hình AI & Key</span>
                                </a>
                            }
                            else if (User.IsInRole("Manager"))
                            {
                                <a class="text-sm font-medium text-slate-600 hover:text-red-600 transition flex items-center space-x-1" asp-area="" asp-controller="Manager" asp-action="Index">
                                    <i class="fa-solid fa-house text-slate-400"></i>
                                    <span>Trang chủ</span>
                                </a>
                            }
                            else if (User.IsInRole("Employee"))
                            {
                                <a class="text-sm font-medium text-slate-600 hover:text-red-600 transition flex items-center space-x-1" asp-area="" asp-controller="Employee" asp-action="Index" asp-route-tab="home">
                                    <i class="fa-solid fa-house text-slate-400"></i>
                                    <span>Trang chủ</span>
                                </a>
                                <a class="text-sm font-medium text-slate-600 hover:text-red-600 transition flex items-center space-x-1" asp-area="" asp-controller="Employee" asp-action="Index" asp-route-tab="attendance">
                                    <i class="fa-solid fa-fingerprint text-slate-400"></i>
                                    <span>Chấm công</span>
                                </a>
                                <a class="text-sm font-medium text-slate-600 hover:text-red-600 transition flex items-center space-x-1" asp-area="" asp-controller="Employee" asp-action="Index" asp-route-tab="messages">
                                    <i class="fa-solid fa-comments text-slate-400"></i>
                                    <span>Tin nhắn</span>
                                </a>
                                <a class="text-sm font-medium text-slate-600 hover:text-red-600 transition flex items-center space-x-1" asp-area="" asp-controller="Employee" asp-action="Index" asp-route-tab="requests">
                                    <i class="fa-solid fa-file-signature text-slate-400"></i>
                                    <span>Đơn từ</span>
                                </a>
                                <a class="text-sm font-medium text-slate-600 hover:text-red-600 transition flex items-center space-x-1" asp-area="" asp-controller="Employee" asp-action="Index" asp-route-tab="profile">
                                    <i class="fa-solid fa-id-badge text-slate-400"></i>
                                    <span>Profile</span>
                                </a>
                                <a class="text-sm font-medium text-slate-600 hover:text-red-600 transition flex items-center space-x-1" asp-area="" asp-controller="Employee" asp-action="Index" asp-route-tab="settings">
                                    <i class="fa-solid fa-gear text-slate-400"></i>
                                    <span>Setting</span>
                                </a>
                            }
                            
                            <!-- User info & Logout -->
                            <div class="flex items-center space-x-3 border-l border-slate-200 pl-4">
                                <div class="text-right hidden sm:block">
                                    <p class="text-xs font-semibold text-slate-900">@User.FindFirst("FullName")?.Value</p>
                                    <p class="text-[10px] text-slate-400 uppercase tracking-wider font-bold">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
                                </div>
                                <a class="inline-flex items-center justify-center p-2 rounded-full text-slate-400 hover:text-red-500 hover:bg-red-50 transition" asp-area="" asp-controller="Account" asp-action="Logout" title="Đăng xuất">
                                    <i class="fa-solid fa-right-from-bracket text-lg"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </nav>
        </header>
    }

    <!-- Main Content Area -->
    <main class="flex-grow">
        @RenderBody()
    </main>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- Footer (Minimalist style, only show after login) -->
        <footer class="bg-white border-t border-slate-200 py-4 mt-12 text-slate-500 text-xs">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-2">
                <div>
                    &copy; 2026 - <span class="font-semibold text-slate-700">ComplianceHub App</span>. Môi trường làm việc an toàn & văn minh.
                </div>
                <div class="flex space-x-4">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="hover:text-slate-700 transition">Chính sách bảo mật</a>
                    <span>&bull;</span>
                    <span>Hỗ trợ kỹ thuật</span>
                </div>
            </div>
        </footer>
    }

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
