<section data-tab-panel="home" class="employee-tab-panel active">
    <div class="mb-6 relative">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center">
            <div class="relative z-10 pt-4 pb-2">
                <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-1.5 text-xs font-bold text-slate-600 shadow-sm mb-4">
                    <i class="fa-solid fa-user-tie"></i> EMPLOYEE WORKSPACE
                </span>
                <div class="flex items-center flex-wrap gap-3">
                    <h1 class="text-3xl md:text-4xl font-outfit font-bold text-slate-900">
                        Xin chào, <span class="text-red-600" data-profile-name>@User.FindFirst("FullName")?.Value</span>
                    </h1>
                </div>
                <p class="mt-2 text-slate-500">Tổng quan công việc và dữ liệu cá nhân của bạn được đồng bộ từ hệ thống.</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
        <div class="saas-card p-6">
            <p class="text-xs text-slate-500 font-semibold mb-2 uppercase tracking-wider">Vị trí công việc</p>
            <p class="text-2xl font-bold text-slate-900 truncate">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
        </div>
        <div class="saas-card p-6">
            <p class="text-xs text-slate-500 font-semibold mb-2 uppercase tracking-wider">Trạng thái chấm công</p>
            <div class="flex items-center gap-2">
                <span id="attendanceStatusDot" class="h-2 w-2 rounded-full bg-amber-500"></span>
                <p class="text-lg font-bold text-slate-900" id="attendanceStatusText">Chưa Check-in</p>
            </div>
            <p class="mt-2 text-xs text-slate-500" id="attendanceStatusSubText">Yêu cầu xác thực khuôn mặt</p>
        </div>
        <div class="saas-card p-6">
            <p class="text-xs text-slate-500 font-semibold mb-2 uppercase tracking-wider">Ngày làm việc</p>
            <p class="text-xl font-bold text-slate-900" data-home-date>--/--/----</p>
        </div>
        <div class="saas-card p-6">
            <p class="text-xs text-slate-500 font-semibold mb-2 uppercase tracking-wider">Giờ hiện tại</p>
            <p class="text-2xl font-bold text-slate-900 font-mono" data-home-time>--:--:--</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-7 xl:col-span-8 flex flex-col gap-6">
            <div class="saas-card p-6 flex-1">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="saas-heading text-lg flex items-center gap-2">
                        <i class="fa-regular fa-clipboard text-red-600"></i> Nhiệm vụ cần hoàn thiện
                    </h3>
                    <button type="button" data-tab-trigger="schedule" class="text-sm font-bold text-red-600 hover:underline">Chi tiết &rarr;</button>
                </div>
                <div class="grid grid-cols-3 gap-4 mb-4">
                    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center">
                        <p class="text-xs text-slate-500 uppercase tracking-wider">Tổng</p>
                        <p class="mt-2 text-2xl font-bold text-slate-900" data-home-task-total>0</p>
                    </div>
                    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center">
                        <p class="text-xs text-slate-500 uppercase tracking-wider">Đang làm</p>
                        <p class="mt-2 text-2xl font-bold text-amber-600" data-home-task-pending>0</p>
                    </div>
                    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center">
                        <p class="text-xs text-slate-500 uppercase tracking-wider">Hoàn thành</p>
                        <p class="mt-2 text-2xl font-bold text-emerald-600" data-home-task-done>0</p>
                    </div>
                </div>
                <div class="space-y-4" data-home-task-list>
                    <div class="rounded-xl border border-slate-100 bg-slate-50 p-4 text-sm text-slate-500">
                        Chưa có nhiệm vụ nào được giao.
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-5 xl:col-span-4 flex flex-col gap-6">
            <div class="saas-card p-6">
                <h3 class="saas-heading text-lg mb-6">Thao tác nhanh</h3>
                <div class="grid grid-cols-2 gap-4">
                    <button type="button" data-tab-trigger="attendance" class="flex flex-col items-center justify-center p-6 rounded-2xl bg-red-50 text-red-600 hover:bg-red-100 transition active:scale-95 group">
                        <i class="fa-solid fa-fingerprint text-3xl mb-3 group-hover:scale-110 transition-transform"></i>
                        <span class="text-sm font-bold">Chấm công</span>
                    </button>
                    <button type="button" data-tab-trigger="requests" class="flex flex-col items-center justify-center p-6 rounded-2xl bg-slate-50 text-slate-700 hover:bg-slate-100 transition active:scale-95 group">
                        <i class="fa-solid fa-file-pen text-3xl mb-3 text-slate-600 group-hover:scale-110 transition-transform"></i>
                        <span class="text-sm font-bold">Gửi đơn từ</span>
                    </button>
                </div>
            </div>

            <div class="saas-card p-6 flex-1 flex flex-col">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="saas-heading text-lg">Vi phạm gần đây</h3>
                    <span class="text-xs text-slate-400" id="homeViolationCount">0 vi phạm</span>
                </div>
                <div class="space-y-3" id="homeViolationList">
                    <div class="rounded-xl border border-slate-100 bg-slate-50 p-4 text-sm text-slate-500">
                        Chưa có vi phạm nào được ghi nhận.
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
