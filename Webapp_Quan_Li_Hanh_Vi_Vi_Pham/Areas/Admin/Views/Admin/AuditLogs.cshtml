@model List<Webapp_Quan_Li_Hanh_Vi_Vi_Pham.Models.Entities.AuditLog>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Nhật ký Hệ thống";
    ViewData["ActivePage"] = "AuditLogs";
}
                    <div class="flex items-start justify-between">
                        <div>
                            <h1 class="text-3xl font-bold text-zinc-900 mb-2">Nhật ký Hệ thống</h1>
                            <p class="text-zinc-500">Theo dõi lịch sử hoạt động thực tế trên toàn hệ thống</p>
                        </div>
                        <button onclick="downloadCSV()" class="flex items-center gap-2 bg-white border border-zinc-200 hover:bg-zinc-50 text-zinc-700 px-4 py-2 rounded-md text-sm font-medium transition-colors shadow-sm cursor-pointer">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" x2="12" y1="15" y2="3" /></svg>
                            Xuất CSV
                        </button>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                        <div class="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm">
                            <p class="text-sm text-zinc-500 mb-1">Thành công</p>
                            <p class="text-3xl font-bold text-emerald-600">@Model.Count(l => l.Status == "Thành công")</p>
                        </div>
                        <div class="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm">
                            <p class="text-sm text-zinc-500 mb-1">Cảnh báo</p>
                            <p class="text-3xl font-bold text-amber-600">@Model.Count(l => l.Status == "Cảnh báo")</p>
                        </div>
                        <div class="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm">
                            <p class="text-sm text-zinc-500 mb-1">Lỗi</p>
                            <p class="text-3xl font-bold text-red-600">@Model.Count(l => l.Status == "Lỗi")</p>
                        </div>
                        <div class="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm">
                            <p class="text-sm text-zinc-500 mb-1">Tổng hoạt động</p>
                            <p class="text-3xl font-bold text-zinc-900">@Model.Count</p>
                        </div>
                    </div>

                    <div class="bg-white border border-zinc-200 rounded-xl shadow-sm">
                        <div class="p-6 border-b border-zinc-100 flex items-center justify-between">
                            <div>
                                <h3 class="text-lg font-bold text-zinc-900">Danh sách hoạt động</h3>
                                <p class="text-sm text-zinc-500">Hiển thị các bản ghi gần đây nhất</p>
                            </div>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm text-left whitespace-nowrap" id="logsTable">
                                <thead class="text-xs text-zinc-800 bg-zinc-100 border-b border-zinc-200 uppercase font-bold">
                                    <tr>
                                        <th class="px-6 py-4">Thời gian</th>
                                        <th class="px-6 py-4">Người dùng</th>
                                        <th class="px-6 py-4">Hành động</th>
                                        <th class="px-6 py-4">Chi tiết</th>
                                        <th class="px-6 py-4">IP Address</th>
                                        <th class="px-6 py-4">Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!Model.Any())
                                    {
                                        <tr><td colspan="6" class="px-6 py-8 text-center text-zinc-500">Chưa có nhật ký hoạt động.</td></tr>
                                    }
                                    @foreach (var log in Model)
                                    {
                                        <tr class="border-b border-zinc-100 hover:bg-zinc-50 transition-colors">
                                            <td class="px-6 py-4 font-medium">@log.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                            <td class="px-6 py-4">@log.Username</td>
                                            <td class="px-6 py-4">
                                                @{
                                                    string badgeClass = "bg-blue-50 text-blue-700 border-blue-100";
                                                    if (log.Action.Contains("Xóa") || log.Action.Contains("Tắt") || log.Action.Contains("Reset") || log.Action.Contains("Delete"))
                                                    {
                                                        badgeClass = "bg-red-50 text-red-700 border-red-100";
                                                    }
                                                    else if (log.Action.Contains("Cập nhật") || log.Action.Contains("Sửa") || log.Action.Contains("Toggle"))
                                                    {
                                                        badgeClass = "bg-amber-50 text-amber-700 border-amber-100";
                                                    }
                                                    else if (log.Action.Contains("Thêm") || log.Action.Contains("Tạo") || log.Action.Contains("Add"))
                                                    {
                                                        badgeClass = "bg-emerald-50 text-emerald-700 border-emerald-100";
                                                    }
                                                }
                                                <span class="px-2 py-1 text-xs rounded-md border @badgeClass">@log.Action</span>
                                            </td>
                                            <td class="px-6 py-4 text-zinc-500">@log.Details</td>
                                            <td class="px-6 py-4 font-mono text-xs text-zinc-500">@log.IpAddress</td>
                                            <td class="px-6 py-4">
                                                @{
                                                    string statusClass = "bg-emerald-100 text-emerald-700";
                                                    if (log.Status == "Cảnh báo")
                                                    {
                                                        statusClass = "bg-amber-100 text-amber-700";
                                                    }
                                                    else if (log.Status == "Lỗi")
                                                    {
                                                        statusClass = "bg-red-100 text-red-700";
                                                    }
                                                }
                                                <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold @statusClass">@log.Status</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </main>
            </div>
        </div>

@section Scripts {
    <script>
            function downloadCSV() {
                let csv = "Thời gian,Người dùng,Hành động,Chi tiết,IP Address,Trạng thái\n";
                const rows = document.querySelectorAll("#logsTable tbody tr");
                rows.forEach(row => {
                    const cols = row.querySelectorAll("td");
                    if (cols.length >= 6) {
                        const data = Array.from(cols).map(col => `"${col.innerText.replace(/"/g, '""')}"`);
                        csv += data.join(",") + "\n";
                    }
                });

                const blob = new Blob([new Uint8Array([0xEF, 0xBB, 0xBF]), csv], { type: "text/csv;charset=utf-8;" });
                const link = document.createElement("a");
                link.href = URL.createObjectURL(blob);
                link.download = "nhat_ky_he_thong.csv";
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            }
    </script>
}