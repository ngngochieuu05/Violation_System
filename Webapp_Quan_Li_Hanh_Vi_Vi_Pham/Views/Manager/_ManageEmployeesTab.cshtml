<div data-tab-panel="employees" class="hidden space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="font-outfit text-2xl font-bold text-slate-900">Quản lý Nhân viên</h2>
            <p class="text-sm text-slate-500 mt-1">Danh sách tất cả nhân viên trong hệ thống.</p>
        </div>
        <div class="flex items-center gap-3">
            <button onclick="window.openAddEmployeeModal()" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition shadow-sm flex items-center">
                <i class="fa-solid fa-plus mr-2"></i>Thêm nhân viên
            </button>
        </div>
    </div>

<!-- Add Employee Modal -->
<div id="addEmployeeModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-900/50 backdrop-blur-sm transition-all">
    <div class="saas-card w-full max-w-md bg-white p-6 transition-transform scale-95 origin-center">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-slate-900 font-outfit">Thêm Nhân Viên Mới</h3>
            <button onclick="window.closeAddEmployeeModal()" class="text-slate-400 hover:text-slate-600">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>
        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Họ & Tên</label>
                <input type="text" id="newEmpFullName" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-red-100 focus:border-red-300 outline-none text-sm transition" placeholder="Nhập họ và tên...">
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Phòng ban</label>
                <input type="text" id="newEmpDepartment" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-red-100 focus:border-red-300 outline-none text-sm transition" placeholder="Ví dụ: Kỹ thuật, Nhân sự...">
            </div>
            <div id="newEmpResult" class="hidden p-3 bg-green-50 text-green-700 border border-green-200 rounded-lg text-sm">
                Tạo thành công!<br>
                Tài khoản: <span id="resUsername" class="font-bold"></span><br>
                Mật khẩu: <span id="resPassword" class="font-bold"></span>
            </div>
            <button onclick="window.submitAddEmployee()" class="w-full bg-red-600 hover:bg-red-700 text-white font-medium py-2 rounded-lg transition-colors shadow-sm">
                Tạo tài khoản
            </button>
        </div>
    </div>
</div>    <div class="saas-card bg-white">
        <div class="p-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50 rounded-t-2xl">
            <h3 class="font-bold text-slate-800"><i class="fa-solid fa-users text-slate-400 mr-2"></i>Danh sách nhân sự</h3>
            <div class="relative">
                <i class="fa-solid fa-magnifying-glass absolute left-3 top-2.5 text-slate-400 text-sm"></i>
                <input type="text" placeholder="Tìm kiếm nhân viên..." class="pl-9 pr-4 py-1.5 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-red-100 focus:border-red-300 outline-none w-64">
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-slate-600">
                <thead class="text-xs uppercase bg-slate-50 text-slate-500 border-b border-slate-200">
                    <tr>
                        <th class="p-4 py-3 font-bold">Mã NV</th>
                        <th class="p-4 py-3 font-bold">Họ & Tên</th>
                        <th class="p-4 py-3 font-bold">Phòng ban</th>
                        <th class="p-4 py-3 font-bold">Tài khoản</th>
                        <th class="p-4 py-3 font-bold text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="employeeListTbody">
                    <!-- Dữ liệu sẽ được load qua JS -->
                    <tr><td colspan="6" class="p-8 text-center text-slate-400">Đang tải dữ liệu...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
