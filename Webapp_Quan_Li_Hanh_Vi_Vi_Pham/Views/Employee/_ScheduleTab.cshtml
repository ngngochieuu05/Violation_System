<section data-tab-panel="schedule" class="employee-tab-panel hidden">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="saas-heading text-2xl">Lịch làm việc & Nhiệm vụ</h2>
            <p class="text-sm text-slate-500 mt-1">Dữ liệu lịch và nhiệm vụ được đồng bộ từ hệ thống.</p>
        </div>
        <button type="button" data-task-add-trigger class="rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-800 transition shadow-sm flex items-center gap-2">
            <i class="fa-solid fa-plus"></i> Thêm công việc
        </button>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8 flex flex-col gap-6">
            <div class="saas-card p-6 flex-1">
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center gap-4">
                        <h3 class="saas-heading text-lg">Lịch tháng hiện tại</h3>
                    </div>
                </div>
                <div id="scheduleCalendar" class="grid grid-cols-7 gap-px bg-slate-200 border border-slate-200 rounded-xl overflow-hidden"></div>
            </div>
        </div>

        <div class="lg:col-span-4 flex flex-col gap-6">
            <div class="saas-card p-5">
                <p class="saas-label mb-2">Tiến độ hôm nay</p>
                <div class="flex items-end gap-2 mb-3">
                    <span class="font-outfit text-4xl font-bold text-slate-900" data-task-stats-done>0</span>
                    <span class="pb-1 text-base font-medium text-slate-400">/ <span data-task-stats-total>0</span></span>
                </div>
                <div class="h-2 w-full rounded-full bg-slate-100 overflow-hidden">
                    <div class="h-full rounded-full bg-emerald-500 transition-all duration-500" style="width: 0%" data-task-progress-bar></div>
                </div>
                <p class="mt-2 text-xs font-medium text-slate-500 text-right" data-task-progress-text>0% hoàn thành</p>
            </div>

            <div class="saas-card p-5 flex-1 flex flex-col">
                <h3 class="saas-heading text-base mb-4">Nhiệm vụ của bạn</h3>
                <div class="flex-1 space-y-3 overflow-y-auto max-h-[500px]" data-task-list>
                    <div class="rounded-2xl bg-slate-50 p-4 text-sm text-slate-500">Chưa có nhiệm vụ nào.</div>
                </div>

                <h3 class="saas-heading text-base mt-6 mb-4">Đã hoàn thành</h3>
                <div class="space-y-3" data-task-done-list>
                    <div class="text-sm text-slate-500">Chưa hoàn thành công việc nào.</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Task Add Modal -->
<div data-task-add-modal class="fixed inset-0 z-[1200] hidden items-center justify-center p-4 backdrop-blur-sm" style="background-color: rgba(15, 23, 42, 0.5);">
    <div class="w-full max-w-md overflow-hidden rounded-[20px] bg-white shadow-2xl">
        <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4">
            <h3 class="font-outfit text-base font-bold text-slate-900">Thêm công việc mới</h3>
            <button type="button" data-task-add-close class="text-slate-400 hover:text-slate-600 transition">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>
        <div class="p-5 space-y-4">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">Tiêu đề công việc</label>
                <input type="text" id="newTaskTitle" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm text-slate-900 outline-none focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 transition" placeholder="Nhập tiêu đề..." />
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">Mô tả (Tùy chọn)</label>
                <textarea id="newTaskDesc" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm text-slate-900 outline-none focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 transition resize-none h-20" placeholder="Chi tiết công việc..."></textarea>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">Hạn chót</label>
                <input type="datetime-local" id="newTaskDate" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm text-slate-900 outline-none focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 transition" />
            </div>
        </div>
        <div class="border-t border-slate-100 px-5 py-4 flex gap-3">
            <button type="button" data-task-add-close class="flex-1 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-50 transition">Hủy</button>
            <button type="button" id="submitNewTaskBtn" class="flex-1 rounded-xl bg-red-600 px-4 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-red-700 transition active:scale-95">Thêm ngay</button>
        </div>
    </div>
</div>
