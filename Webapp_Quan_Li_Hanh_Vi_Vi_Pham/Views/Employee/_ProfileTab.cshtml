<section data-tab-panel="profile" class="employee-tab-panel hidden">
    <div class="grid gap-8 lg:grid-cols-[0.92fr_1.08fr]">
        <div class="employee-surface rounded-[2rem] border border-white/60 bg-white/90 backdrop-blur-xl p-6 shadow-xl sm:p-8">
            <div class="flex flex-col items-center gap-6 text-center">
                <!-- Avatar Container -->
                <div style="position: relative; width: 160px; height: 160px; flex-shrink: 0; margin-bottom: 24px;">
                    <div class="employee-avatar-placeholder" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; overflow: hidden; border-radius: 50%; background-color: #fef2f2; border: 4px solid #fee2e2; display: flex; align-items: center; justify-content: center; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);">
                        <img data-avatar-image class="hidden" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 10;" alt="Avatar employee" />
                        <i data-avatar-fallback class="fa-solid fa-user" style="font-size: 4rem; color: #dc2626; z-index: 0;"></i>
                    </div>
                    <!-- Nút camera góc phải dưới -->
                    <label class="transition hover:bg-red-600" style="position: absolute; bottom: 4px; right: 4px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 50%; background-color: #1e293b; color: white; border: 2px solid white; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); cursor: pointer; z-index: 20;" title="Cập nhật ảnh đại diện">
                        <input type="file" accept="image/*" data-avatar-input style="display: none;" />
                        <i class="fa-solid fa-camera" style="font-size: 0.875rem;"></i>
                    </label>
                </div>

                <div class="text-center" style="margin-top: 8px;">
                    <p class="employee-text font-outfit font-bold text-slate-900" style="font-size: 2.25rem; line-height: 2.5rem;" data-profile-name>@User.FindFirst("FullName")?.Value</p>
                    <p class="employee-subtext font-medium text-slate-500" style="font-size: 0.875rem; margin-top: 4px;">@User.Identity?.Name</p>
                    <button type="button" data-avatar-remove class="transition hover:border-red-200 hover:text-red-500" style="margin-top: 12px; display: inline-flex; align-items: center; border-radius: 9999px; border: 1px solid #e2e8f0; padding: 6px 16px; font-size: 0.75rem; font-weight: 600; color: #64748b; background-color: white;">
                        <i class="fa-solid fa-trash-can" style="margin-right: 8px;"></i>Xóa ảnh đại diện
                    </button>
                </div>
            </div>

            <div class="mt-6 rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md shadow-sm px-4 py-3 text-sm text-slate-600" data-avatar-message>
                Ảnh đại diện hiện đang dùng biểu tượng mặc định.
            </div>

            <div class="mt-6 space-y-4">
                <div class="employee-muted rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md shadow-sm p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Mã nhân viên</p>
                    <p class="employee-text mt-2 font-semibold text-slate-900">EMP-2026-014</p>
                </div>
                <div class="employee-muted rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md shadow-sm p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Bộ phận</p>
                    <p class="employee-text mt-2 font-semibold text-slate-900" data-profile-department-view>Khối vận hành</p>
                </div>
                <div class="employee-muted rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md shadow-sm p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Vai trò</p>
                    <p class="employee-text mt-2 font-semibold text-slate-900">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
                </div>
            </div>
        </div>

        <div class="employee-surface rounded-[2rem] border border-white/60 bg-white/90 backdrop-blur-xl p-6 shadow-xl sm:p-8">
            <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-500">Profile</p>
            <h2 class="employee-text mt-2 font-outfit text-2xl font-bold text-slate-900">Cập nhật thông tin hiển thị</h2>

            <div class="mt-6 grid gap-4 md:grid-cols-2">
                <div>
                    <label class="employee-text mb-2 block text-sm font-semibold text-slate-700">Họ tên</label>
                    <input type="text" data-profile-input="name" value="@User.FindFirst("FullName")?.Value" class="employee-input w-full rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md shadow-sm px-4 py-3 text-sm text-slate-700 outline-none focus:border-red-300" />
                </div>
                <div>
                    <label class="employee-text mb-2 block text-sm font-semibold text-slate-700">Bộ phận</label>
                    <input type="text" data-profile-input="department" value="Khối vận hành" class="employee-input w-full rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md shadow-sm px-4 py-3 text-sm text-slate-700 outline-none focus:border-red-300" />
                </div>
                <div>
                    <label class="employee-text mb-2 block text-sm font-semibold text-slate-700">Email công việc</label>
                    <input type="email" data-profile-input="email" value="employee@compliancehub.vn" class="employee-input w-full rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md shadow-sm px-4 py-3 text-sm text-slate-700 outline-none focus:border-red-300" />
                </div>
                <div>
                    <label class="employee-text mb-2 block text-sm font-semibold text-slate-700">Số điện thoại</label>
                    <input type="text" data-profile-input="phone" value="0123 456 789" class="employee-input w-full rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md shadow-sm px-4 py-3 text-sm text-slate-700 outline-none focus:border-red-300" />
                </div>
                <div class="md:col-span-2">
                    <button type="button" data-profile-save class="rounded-2xl bg-red-600 px-5 py-3 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:shadow-md hover:bg-red-700">
                        Lưu thông tin
                    </button>
                </div>
            </div>

            <div class="employee-muted mt-5 rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md shadow-sm px-4 py-3 text-sm text-slate-600" data-profile-message>
                Thông tin hiện đang ở trạng thái mặc định.
            </div>

            <div class="mt-8 border-t border-slate-200/50 pt-8">
                <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-500">Security</p>
                <h2 class="employee-text mt-2 font-outfit text-2xl font-bold text-slate-900">Bảo mật tài khoản</h2>

                <div class="mt-6 grid gap-6 md:grid-cols-2">
                    <div class="space-y-4 rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md p-5 shadow-sm">
                        <h4 class="font-semibold text-slate-800">Đổi mật khẩu</h4>
                        <div>
                            <label class="employee-text mb-1 block text-xs font-semibold text-slate-500">Mật khẩu cũ</label>
                            <input type="password" data-profile-pwd-old class="employee-input w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 outline-none focus:border-red-300" />
                        </div>
                        <div>
                            <label class="employee-text mb-1 block text-xs font-semibold text-slate-500">Mật khẩu mới</label>
                            <input type="password" data-profile-pwd-new class="employee-input w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 outline-none focus:border-red-300" />
                        </div>
                        <div>
                            <label class="employee-text mb-1 block text-xs font-semibold text-slate-500">Xác nhận mật khẩu</label>
                            <input type="password" data-profile-pwd-confirm class="employee-input w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 outline-none focus:border-red-300" />
                        </div>
                        <button type="button" data-profile-change-pwd class="w-full rounded-xl bg-red-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-red-700 hover:shadow-md">
                            Cập nhật mật khẩu
                        </button>
                        <p data-profile-pwd-msg class="text-xs font-semibold mt-2 hidden"></p>
                    </div>

                    <div class="space-y-4 rounded-[1.5rem] border border-white/60 bg-white/80 backdrop-blur-md p-5 shadow-sm flex flex-col">
                        <h4 class="font-semibold text-slate-800">Dữ liệu khuôn mặt</h4>
                        <p class="text-sm text-slate-500 flex-1">
                            Dữ liệu sinh trắc học được sử dụng để điểm danh khuôn mặt hàng ngày. Nếu bạn thay đổi diện mạo (cắt tóc, đeo kính mới,...), hãy cập nhật lại dữ liệu này.
                        </p>
                        <button type="button" data-profile-update-face class="w-full flex items-center justify-center rounded-xl border-2 border-red-600 bg-white px-4 py-2.5 text-sm font-semibold text-red-600 transition hover:bg-red-50 hover:shadow-sm">
                            <i class="fa-solid fa-camera mr-2"></i> Chụp lại khuôn mặt
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Face Update Modal -->
    <div data-face-modal class="fixed inset-0 z-[1200] hidden items-center justify-center bg-slate-950/70 p-4 backdrop-blur-sm">
        <div class="w-full max-w-lg overflow-hidden rounded-[30px] border border-slate-700 bg-slate-900 shadow-2xl">
            <div class="flex items-center justify-between border-b border-slate-800 px-6 py-4">
                <h3 class="font-outfit text-lg font-bold text-white">Cập nhật dữ liệu khuôn mặt</h3>
                <button type="button" data-face-close class="text-slate-400 hover:text-white transition">
                    <i class="fa-solid fa-xmark text-xl"></i>
                </button>
            </div>
            
            <div class="p-6">
                <!-- Instruction Steps -->
                <div class="mb-6 flex justify-between gap-2 text-center text-xs font-semibold">
                    <div class="flex-1 rounded-lg bg-red-600/20 py-2 text-red-400 border border-red-600/30 transition-colors duration-300" id="step-0">Trực diện</div>
                    <div class="flex-1 rounded-lg bg-slate-800 py-2 text-slate-400 transition-colors duration-300" id="step-1">Quay trái</div>
                    <div class="flex-1 rounded-lg bg-slate-800 py-2 text-slate-400 transition-colors duration-300" id="step-2">Quay phải</div>
                    <div class="flex-1 rounded-lg bg-slate-800 py-2 text-slate-400 transition-colors duration-300" id="step-3">Ngước lên</div>
                </div>

                <div class="relative aspect-[4/3] bg-black rounded-2xl overflow-hidden shadow-inner">
                    <video data-face-video autoplay muted playsinline class="h-full w-full object-cover transform -scale-x-100"></video>
                    <canvas data-face-canvas class="hidden"></canvas>
                    <div data-face-scanline class="absolute left-0 top-0 hidden h-[2px] w-full bg-gradient-to-r from-transparent via-red-500 to-transparent shadow-[0_0_10px_#dc2626]"></div>
                    <div data-face-overlay class="pointer-events-none absolute inset-0 border-2 border-dashed border-white/30 rounded-2xl m-4 transition-colors"></div>
                    <div data-face-status class="absolute inset-0 flex flex-col items-center justify-center bg-slate-950/70 p-5 text-center text-white hidden">
                        <div class="mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-white/10">
                            <i class="fa-solid fa-spinner fa-spin text-lg"></i>
                        </div>
                        <p class="text-sm font-semibold" data-face-status-text>Đang khởi tạo camera...</p>
                    </div>
                </div>

                <div class="mt-6 text-center">
                    <p class="mb-4 text-sm font-medium text-amber-400" data-face-instruction>
                        Nhìn thẳng trực diện vào camera và nhấn chụp.
                    </p>
                    <button type="button" data-face-capture class="mx-auto flex w-full max-w-xs items-center justify-center rounded-2xl bg-red-600 px-5 py-3.5 text-base font-bold text-white shadow-lg transition-all duration-200 hover:-translate-y-0.5 active:scale-95 hover:shadow-xl hover:bg-red-700">
                        <i class="fa-solid fa-camera mr-3 text-lg"></i>Chụp góc hiện tại
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>
