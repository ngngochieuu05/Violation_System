                <div class="relative z-10 p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                    <div>
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">VINH DANH</p>
                        <h3 class="saas-heading text-lg mb-4">Nhân viên xuất sắc tháng</h3>
                        
                        <div class="flex items-center gap-4">
                            <div class="relative">
                                <div class="w-14 h-14 rounded-full bg-amber-400 flex items-center justify-center text-white font-bold text-xl shadow-lg border-2 border-white">NV</div>
                                <div class="absolute -bottom-1 -right-1 w-6 h-6 bg-white rounded-full flex items-center justify-center shadow-sm">
                                    <i class="fa-solid fa-crown text-[10px] text-amber-500"></i>
                                </div>
                            </div>
                            <div>
                                <p class="font-bold text-slate-900">Trần Văn Khôi</p>
                                <p class="text-xs text-slate-500 mt-0.5">Khối Vận hành &bull; 3,200 Điểm</p>
                            </div>
                        </div>
                    </div>
                    
                    <a href="#" class="text-sm font-bold text-red-600 hover:underline flex items-center sm:self-end mt-4 sm:mt-0">
                        Xem bảng xếp hạng &rarr;
                    </a>
                </div>
            </div>

        </div>

        <!-- Right Column -->
        <div class="lg:col-span-5 xl:col-span-4 flex flex-col gap-6">
            
            <!-- Thao tác nhanh -->
            <div class="saas-card p-6">
                <h3 class="saas-heading text-lg mb-6">Thao tác nhanh</h3>
                <div class="grid grid-cols-2 gap-4">
                    <button type="button" data-tab-trigger="attendance" class="flex flex-col items-center justify-center p-6 rounded-2xl bg-red-50 text-red-600 hover:bg-red-100 transition active:scale-95 group">
                        <i class="fa-solid fa-fingerprint text-3xl mb-3 group-hover:scale-110 transition-transform"></i>
                        <span class="text-sm font-bold">Chấm công</span>
                    </button>
                    
                    <button type="button" data-tab-trigger="requests" class="flex flex-col items-center justify-center p-6 rounded-2xl bg-slate-50 text-slate-700 hover:bg-slate-100 transition active:scale-95 group">
                        <i class="fa-solid fa-file-pen text-3xl mb-3 text-slate-600 group-hover:scale-110 transition-transform"></i>
                        <span class="text-sm font-bold">Gửi đơn từ</span>
                    </button>
                </div>
            </div>

            <!-- Vi phạm gần đây -->
            <div class="saas-card p-6 flex-1 flex flex-col">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="saas-heading text-lg">Vi phạm gần đây</h3>
                    <span class="text-xs text-slate-400">0 vi phạm</span>
                </div>
                
                <div class="flex-1 flex flex-col items-center justify-center py-8">
                    <div class="w-16 h-16 rounded-full bg-emerald-500 flex items-center justify-center text-white text-3xl mb-4 shadow-lg shadow-emerald-500/20">
                        <i class="fa-solid fa-check"></i>
                    </div>
                    <p class="text-sm text-slate-500 font-medium">Không có vi phạm ghi nhận</p>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- Scripts cho các tiện ích nhỏ trên Home -->
<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Cập nhật đồng hồ và ngày tháng
        const timeDisplay = document.getElementById('currentTimeDisplay');
        const dateDisplay = document.getElementById('currentDateDisplay');
        
        function updateDateTime() {
            const now = new Date();
            
            if (timeDisplay) {
                timeDisplay.textContent = now.toLocaleTimeString('vi-VN', { hour12: false });
            }
            
            if (dateDisplay) {
                const days = ['Chủ Nhật', 'Thứ Hai', 'Thứ Ba', 'Thứ Tư', 'Thứ Năm', 'Thứ Sáu', 'Thứ Bảy'];
                const dayName = days[now.getDay()];
                const dateStr = now.toLocaleDateString('vi-VN', {
                    day: '2-digit', month: '2-digit', year: 'numeric'
                });
                dateDisplay.textContent = `${dayName}, ${dateStr}`;
            }
        }
        
        updateDateTime();
        setInterval(updateDateTime, 1000);
    });
</script>
