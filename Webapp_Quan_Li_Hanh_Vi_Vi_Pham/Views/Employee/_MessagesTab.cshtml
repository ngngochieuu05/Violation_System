<section data-tab-panel="messages" class="employee-tab-panel hidden h-full">
    <div class="h-[calc(100vh-140px)] grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-4 flex flex-col saas-card overflow-hidden">
            <div class="p-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                <h3 class="saas-heading text-lg">Hộp Thư</h3>
            </div>
            <div class="flex-1 overflow-y-auto p-2 space-y-1" id="messageChannelList">
                <div class="text-sm text-slate-500 text-center py-4">Đang tải danh bạ...</div>
            </div>
        </div>

        <div class="lg:col-span-8 flex flex-col saas-card overflow-hidden">
            <div class="h-16 flex items-center justify-between px-6 border-b border-slate-100 bg-white flex-shrink-0">
                <div>
                    <h2 class="saas-heading text-base leading-tight" data-chat-title>Quản lý trực tiếp</h2>
                    <p class="text-xs text-slate-500 mt-0.5">Dữ liệu đồng bộ từ hệ thống nhắn tin nội bộ</p>
                </div>
            </div>

            <div class="flex-1 overflow-y-auto p-6 bg-slate-50/50 space-y-4" data-chat-thread>
                <div class="rounded-xl border border-slate-100 bg-white p-4 text-sm text-slate-500">
                    Chưa có tin nhắn nào trong kênh này.
                </div>
            </div>

            <div class="p-4 border-t border-slate-100 bg-white flex-shrink-0">
                <div data-chat-edit-bar class="mb-3 hidden items-center justify-between rounded-xl border border-amber-200 bg-amber-50 px-4 py-2 text-sm text-amber-700">
                    <span data-chat-edit-label>Đang chỉnh sửa tin nhắn</span>
                    <button type="button" data-chat-edit-cancel class="font-semibold text-amber-800 hover:underline">Hủy</button>
                </div>
                <div class="flex items-center gap-3">
                    <div class="flex-1 relative">
                        <input type="text" data-chat-input class="w-full bg-slate-100 border-transparent focus:border-red-300 focus:bg-white focus:ring-2 focus:ring-red-100 rounded-full py-2.5 pl-4 pr-4 text-sm transition" placeholder="Nhập tin nhắn..." />
                    </div>
                    <button type="button" data-chat-send class="w-10 h-10 rounded-full bg-red-600 text-white hover:bg-red-700 transition flex items-center justify-center shadow-sm active:scale-95 flex-shrink-0">
                        <i class="fa-solid fa-paper-plane text-sm"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>
