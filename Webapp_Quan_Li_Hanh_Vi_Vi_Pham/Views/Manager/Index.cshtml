@{
    ViewData["Title"] = "Trang chủ Quản lý";
    Layout = "_Layout";
}

<div class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-white rounded-3xl shadow-xl border border-slate-100 overflow-hidden">
        <!-- Header banner -->
        <div class="bg-gradient-to-r from-red-600 via-red-700 to-rose-700 px-8 py-10 text-white relative overflow-hidden">
            <div class="absolute w-64 h-64 bg-white/10 rounded-full blur-2xl -top-20 -right-20"></div>
            <div class="absolute w-32 h-32 bg-white/5 rounded-full blur-xl bottom-10 right-10"></div>
            
            <div class="relative z-10">
                <span class="px-3 py-1 bg-white/20 text-white text-xs font-semibold uppercase tracking-wider rounded-full backdrop-blur-sm">Quản lý Doanh nghiệp</span>
                <h1 class="font-outfit text-3xl font-extrabold mt-3">Chào mừng bạn trở lại, @User.FindFirst("FullName")?.Value</h1>
                <p class="text-red-100 text-sm mt-1">Hệ thống đã xác nhận phiên đăng nhập và kích hoạt khóa bảo mật thành công.</p>
            </div>
        </div>

        <div class="p-8 space-y-8">
            <!-- Success Status Card -->
            <div class="flex flex-col sm:flex-row items-center bg-green-50 rounded-2xl p-6 border border-green-100 gap-4">
                <div class="w-12 h-12 bg-green-500 rounded-full flex items-center justify-center text-white text-2xl flex-shrink-0 animate-bounce">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div>
                    <h3 class="font-outfit font-bold text-green-900 text-lg">Đăng nhập & Kích hoạt thành công</h3>
                    <p class="text-sm text-green-700">Tài khoản quản lý của bạn đã được liên kết với khóa bản quyền và sẵn sàng hoạt động. Mọi luồng xử lý và dữ liệu đã được cấu hình đồng bộ.</p>
                </div>
            </div>

            <!-- Profile Info & Meta details -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-slate-50 rounded-2xl p-6 border border-slate-200/60">
                    <h4 class="font-outfit font-bold text-slate-900 mb-4 flex items-center space-x-2">
                        <i class="fa-solid fa-user-tie text-red-500"></i>
                        <span>Thông tin tài khoản</span>
                    </h4>
                    <ul class="space-y-3 text-sm">
                        <li class="flex justify-between py-2 border-b border-slate-200/40">
                            <span class="text-slate-500">Tên đăng nhập:</span>
                            <span class="font-semibold text-slate-800">@User.Identity?.Name</span>
                        </li>
                        <li class="flex justify-between py-2 border-b border-slate-200/40">
                            <span class="text-slate-500">Họ tên:</span>
                            <span class="font-semibold text-slate-800">@User.FindFirst("FullName")?.Value</span>
                        </li>
                        <li class="flex justify-between py-2">
                            <span class="text-slate-500">Quyền hạn:</span>
                            <span class="px-2.5 py-0.5 bg-red-100 text-red-700 text-xs font-semibold rounded-full uppercase">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                        </li>
                    </ul>
                </div>

                <div class="bg-slate-50 rounded-2xl p-6 border border-slate-200/60 flex flex-col justify-between">
                    <div>
                        <h4 class="font-outfit font-bold text-slate-900 mb-2 flex items-center space-x-2">
                            <i class="fa-solid fa-circle-info text-red-500"></i>
                            <span>Báo cáo nhanh</span>
                        </h4>
                        <p class="text-xs text-slate-500">Nhánh chức năng quản lý nhân sự đang được Admin liên kết nâng cấp. Phiên bản hiện tại ghi nhận tài khoản đã được cấp phép vận hành.</p>
                    </div>
                    <div class="mt-4 pt-4 border-t border-slate-200/40 flex justify-between items-center text-xs text-slate-400">
                        <span>Trạng thái: <strong class="text-green-500">Online</strong></span>
                        <span>Mã phiên: #@Guid.NewGuid().ToString().Substring(0,8).ToUpper()</span>
                    </div>
                </div>
            </div>

            <!-- Custom Quick Actions (Simulated) -->
            <div>
                <h4 class="font-outfit font-bold text-slate-900 mb-4">Lối tắt nhanh</h4>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                    <div class="bg-white hover:bg-red-50/30 border border-slate-200 rounded-2xl p-4 text-center cursor-pointer hover:border-red-300 transition duration-200">
                        <i class="fa-solid fa-users text-2xl text-slate-400 mb-2"></i>
                        <p class="text-xs font-semibold text-slate-700">Nhân sự (Sắp có)</p>
                    </div>
                    <div class="bg-white hover:bg-red-50/30 border border-slate-200 rounded-2xl p-4 text-center cursor-pointer hover:border-red-300 transition duration-200">
                        <i class="fa-solid fa-clock-rotate-left text-2xl text-slate-400 mb-2"></i>
                        <p class="text-xs font-semibold text-slate-700">Lịch sử hoạt động</p>
                    </div>
                    <div class="bg-white hover:bg-red-50/30 border border-slate-200 rounded-2xl p-4 text-center cursor-pointer hover:border-red-300 transition duration-200">
                        <i class="fa-solid fa-bell text-2xl text-slate-400 mb-2"></i>
                        <p class="text-xs font-semibold text-slate-700">Thông báo</p>
                    </div>
                    <a asp-controller="Account" asp-action="Logout" class="bg-white hover:bg-red-50/30 border border-slate-200 rounded-2xl p-4 text-center cursor-pointer hover:border-red-300 transition duration-200 block no-underline">
                        <i class="fa-solid fa-right-from-bracket text-2xl text-slate-400 mb-2 hover:text-red-500 transition"></i>
                        <p class="text-xs font-semibold text-slate-700">Đăng xuất</p>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
