<section data-tab-panel="payroll" class="employee-tab-panel hidden">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="saas-card p-4">
            <div class="flex items-center justify-between text-slate-400 mb-2">
                <span class="saas-label">Lương cơ bản</span>
                <i class="fa-solid fa-money-bill-wave text-blue-500"></i>
            </div>
            <p id="empBaseSalaryTop" class="font-outfit text-xl font-bold text-slate-900 payroll-secure-data blur-md select-none transition-all duration-300">0 ₫</p>
        </div>
        <div class="saas-card p-4">
            <div class="flex items-center justify-between text-slate-400 mb-2">
                <span class="saas-label">Phụ cấp & Thưởng</span>
                <i class="fa-solid fa-hand-holding-dollar text-emerald-500"></i>
            </div>
            <p id="empKpiBonusTop" class="font-outfit text-xl font-bold text-slate-900 payroll-secure-data blur-md select-none transition-all duration-300">0 ₫</p>
        </div>
        <div class="saas-card p-4">
            <div class="flex items-center justify-between text-slate-400 mb-2">
                <span class="saas-label">Khấu trừ</span>
                <i class="fa-solid fa-arrow-trend-down text-red-500"></i>
            </div>
            <p id="empDeductionTop" class="font-outfit text-xl font-bold text-red-600 payroll-secure-data blur-md select-none transition-all duration-300">0 ₫</p>
        </div>
        <div class="saas-card p-4 bg-gradient-to-br from-emerald-50 to-white border-emerald-100">
            <div class="flex items-center justify-between text-emerald-600 mb-2">
                <span class="saas-label text-emerald-600">Tổng thực nhận</span>
                <i class="fa-solid fa-wallet text-emerald-600"></i>
            </div>
            <p id="empNetSalaryTop" class="font-outfit text-2xl font-black text-emerald-700 payroll-secure-data blur-md select-none transition-all duration-300">0 ₫</p>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-6">
        <div class="xl:col-span-8 flex flex-col gap-6">
            <div class="saas-card p-6 flex-1 relative overflow-hidden">
                <div class="flex items-center justify-between mb-6 relative z-10 border-b border-slate-100 pb-4">
                    <div>
                        <h3 class="saas-heading text-lg">Chi tiết Phiếu lương</h3>
                        <p class="text-sm text-slate-500 mt-1">Dữ liệu được đồng bộ từ bảng lương thực tế.</p>
                    </div>
                    <div class="flex flex-col items-end gap-2">
                        <span id="empPayrollStatusBadge" class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700 border border-slate-200">
                            Chưa có dữ liệu
                        </span>
                        <button type="button" id="unlockPayrollBtn" class="rounded-lg bg-slate-800 px-3 py-1.5 text-xs font-bold text-white hover:bg-slate-700 transition active:scale-95 shadow-sm">
                            <i class="fa-solid fa-lock mr-1.5 text-amber-400"></i>Xem chi tiết
                        </button>
                    </div>
                </div>

                <div class="space-y-6 relative z-10">
                    <div>
                        <h4 class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-3"><i class="fa-solid fa-arrow-trend-up text-emerald-500 mr-2"></i>Các khoản thu nhập</h4>
                        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 space-y-3">
                            <div class="flex justify-between items-center">
                                <span class="text-sm font-medium text-slate-700">Lương cơ bản</span>
                                <span id="empBaseSalary" class="payroll-secure-data blur-md select-none font-mono text-sm font-bold text-slate-900 transition-all duration-300">0 ₫</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-sm font-medium text-slate-700">KPI / thưởng</span>
                                <span id="empKpiBonus" class="payroll-secure-data blur-md select-none font-mono text-sm font-bold text-slate-900 transition-all duration-300">0 ₫</span>
                            </div>
                        </div>
                    </div>

                    <div>
                        <h4 class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-3"><i class="fa-solid fa-arrow-trend-down text-red-500 mr-2"></i>Các khoản khấu trừ</h4>
                        <div class="rounded-xl border border-red-100 bg-red-50/50 p-4 space-y-3">
                            <div class="flex justify-between items-center">
                                <span class="text-sm font-medium text-slate-700">Khấu trừ vi phạm</span>
                                <span id="empDeduction" class="payroll-secure-data blur-md select-none font-mono text-sm font-bold text-red-600 transition-all duration-300">0 ₫</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="xl:col-span-4 flex flex-col gap-6">
            <div class="saas-card p-6 flex-1 flex flex-col">
                <h3 class="saas-heading text-lg mb-4">Lịch sử thu nhập</h3>
                <div id="payrollHistoryList" class="flex-1 space-y-3 overflow-y-auto">
                    <div class="p-4 text-center text-sm text-slate-400">Chưa có dữ liệu lương.</div>
                </div>
            </div>
        </div>
    </div>
</section>

<div id="payrollPinModal" class="hidden items-center justify-center transition-opacity" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1500; background-color: rgba(15, 23, 42, 0.75); backdrop-filter: blur(8px);">
    <div class="w-full max-w-sm overflow-hidden saas-card shadow-2xl p-6 relative transform transition-all duration-300" id="payrollPinModalContent" style="transform: scale(0.95); opacity: 0;">
        <button type="button" id="closePayrollPinModal" class="absolute top-4 right-4 text-slate-400 hover:text-red-500 transition-colors h-8 w-8 flex items-center justify-center rounded-full hover:bg-red-50">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
        <div class="text-center mb-6 mt-2">
            <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-red-50 mb-4 text-red-600 border border-red-100">
                <i class="fa-solid fa-shield-halved text-3xl"></i>
            </div>
            <h3 class="font-outfit text-xl font-bold text-slate-900">Xác thực bảo mật</h3>
            <p class="text-sm text-slate-500 mt-2">Vui lòng nhập mã PIN để mở khóa hiển thị số liệu phiếu lương.</p>
        </div>

        <div class="space-y-5">
            <div class="relative">
                <input type="password" id="payrollPinInput" maxlength="6" class="w-full text-center font-mono text-3xl border-2 border-slate-200 bg-slate-50 px-4 py-3 outline-none focus:border-red-400 focus:bg-white transition rounded-xl text-slate-800" placeholder="••••" style="letter-spacing: 0.75em;" />
            </div>
            <p id="payrollPinError" class="text-xs font-semibold text-red-600 text-center hidden"><i class="fa-solid fa-triangle-exclamation mr-1"></i>Mã PIN không đúng. Vui lòng thử lại.</p>
            <button type="button" id="verifyPayrollPinBtn" class="w-full bg-red-600 px-5 py-3.5 text-sm font-bold text-white shadow-sm transition-all hover:bg-red-700 active:scale-95 rounded-xl">
                Mở khóa dữ liệu
            </button>
            <div class="flex items-center justify-center gap-2 text-center text-xs text-slate-400 mt-4">
                <i class="fa-solid fa-circle-info"></i>
                <span>Mã PIN demo: <strong class="text-slate-600">1234</strong></span>
            </div>
        </div>
    </div>
</div>
