<!-- Grid thông số cá nhân dạng hộp vuông nhỏ gọn -->
<div class="grid gap-4 grid-cols-2 md:grid-cols-4 mb-6">
    <!-- Hộp 1: Mã nhân viên -->
    <div class="employee-surface rounded-2xl border border-white/60 bg-white/95 backdrop-blur-xl p-4 shadow-md flex flex-col justify-between h-28 hover:shadow-lg transition-all duration-200">
        <div class="flex items-center justify-between text-slate-400">
            <span class="text-[10px] font-bold uppercase tracking-wider">Mã nhân viên</span>
            <i class="fa-solid fa-id-card text-red-500 text-sm"></i>
        </div>
        <div>
            <p class="font-outfit text-lg font-bold text-slate-800 employee-text mt-1 truncate" data-profile-id>...</p>
            <span class="text-[10px] text-slate-400">Định danh chính thức</span>
        </div>
    </div>

    <!-- Hộp 2: Phòng ban -->
    <div class="employee-surface rounded-2xl border border-white/60 bg-white/95 backdrop-blur-xl p-4 shadow-md flex flex-col justify-between h-28 hover:shadow-lg transition-all duration-200">
        <div class="flex items-center justify-between text-slate-400">
            <span class="text-[10px] font-bold uppercase tracking-wider">Phòng ban</span>
            <i class="fa-solid fa-sitemap text-red-500 text-sm"></i>
        </div>
        <div>
            <p class="font-outfit text-base font-bold text-slate-800 employee-text mt-1 truncate" data-profile-department>...</p>
            <span class="text-[10px] text-slate-400">Đơn vị công tác</span>
        </div>
    </div>

    <!-- Hộp 3: Ca làm việc -->
    <div class="employee-surface rounded-2xl border border-white/60 bg-white/95 backdrop-blur-xl p-4 shadow-md flex flex-col justify-between h-28 hover:shadow-lg transition-all duration-200">
        <div class="flex items-center justify-between text-slate-400">
            <span class="text-[10px] font-bold uppercase tracking-wider">Ca làm việc</span>
            <i class="fa-solid fa-business-time text-red-500 text-sm"></i>
        </div>
        <div>
            <p class="font-outfit text-base font-bold text-slate-800 employee-text mt-1">08:00 - 17:00</p>
            <span class="text-[10px] text-slate-400">Giờ hành chính</span>
        </div>
    </div>

    <!-- Hộp 4: Trạng thái chấm công -->
    <div class="employee-surface rounded-2xl border border-white/60 bg-white/95 backdrop-blur-xl p-4 shadow-md flex flex-col justify-between h-28 hover:shadow-lg transition-all duration-200">
        <div class="flex items-center justify-between text-slate-400">
            <span class="text-[10px] font-bold uppercase tracking-wider">Chấm công ngày</span>
            <i class="fa-solid fa-fingerprint text-red-500 text-sm"></i>
        </div>
        <div>
            <div class="flex items-center gap-1.5 mt-1">
                <span class="h-2 w-2 rounded-full bg-amber-500" id="attendanceStatusDot"></span>
                <p class="font-outfit text-sm font-bold text-slate-800 employee-text" id="attendanceStatusText">Chưa Check-in</p>
            </div>
            <span class="text-[10px] text-slate-400" id="attendanceStatusSubText">Yêu cầu xác thực khuôn mặt</span>
        </div>
    </div>
</div>

<!-- Grid chính bên dưới: Nhiệm vụ và Lịch sử chấm công nhanh -->
<section data-tab-panel="home" class="employee-tab-panel grid gap-6 md:grid-cols-[1.2fr_0.8fr]">
    <!-- Cột trái: Nhiệm vụ hôm nay -->


    <!-- Nhiệm vụ hôm nay (Cột trái - 1.2fr) -->
    <div class="employee-surface rounded-[2rem] border border-white/60 bg-white/90 backdrop-blur-xl p-5 shadow-lg flex flex-col justify-between">
        <div>
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-slate-400">Tiến độ</p>
                    <h3 class="employee-text mt-1 font-outfit text-lg font-bold text-slate-800">Nhiệm vụ cần hoàn thiện</h3>
                </div>
                <button type="button" onclick="document.querySelector('[data-tab-trigger=\'schedule\']').click()" class="text-xs font-bold text-red-600 hover:text-red-700 hover:underline">Chi tiết <i class="fa-solid fa-arrow-right ml-0.5"></i></button>
            </div>

            <div class="mt-4 grid gap-3 grid-cols-3">
                <div class="rounded-xl border border-slate-150 bg-slate-50/70 p-3 flex items-center gap-2">
                    <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-red-600 text-white text-xs shadow-sm">
                        <i class="fa-solid fa-list-check"></i>
                    </div>
                    <div>
                        <p class="text-[10px] font-semibold text-slate-500">Tổng số</p>
                        <p class="font-outfit text-base font-bold text-slate-800 employee-text" data-home-task-total>0</p>
                    </div>
                </div>
                <div class="rounded-xl border border-amber-100 bg-amber-50/70 p-3 flex items-center gap-2">
                    <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500 text-white text-xs shadow-sm">
                        <i class="fa-solid fa-clock"></i>
                    </div>
                    <div>
                        <p class="text-[10px] font-semibold text-amber-500">Đang làm</p>
                        <p class="font-outfit text-base font-bold text-slate-800 employee-text" data-home-task-pending>0</p>
                    </div>
                </div>
                <div class="rounded-xl border border-green-100 bg-green-50/70 p-3 flex items-center gap-2">
                    <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-green-500 text-white text-xs shadow-sm">
                        <i class="fa-solid fa-check-double"></i>
                    </div>
                    <div>
                        <p class="text-[10px] font-semibold text-green-600">Đã xong</p>
                        <p class="font-outfit text-base font-bold text-slate-800 employee-text" data-home-task-done>0</p>
                    </div>
                </div>
            </div>

            <div class="mt-4 space-y-2 max-h-[220px] overflow-y-auto pr-1" data-home-task-list>
                <!-- Injected by JS -->
            </div>
        </div>
    </div>

    <!-- Tiện ích nhanh & Vi phạm (Cột phải - 0.8fr) -->
    <div class="flex flex-col gap-6">
        <!-- Card Lối tắt nhanh -->
        <div class="employee-surface rounded-[2rem] border border-white/60 bg-white/90 backdrop-blur-xl p-5 shadow-lg">
            <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-slate-400 mb-3">Thao tác nhanh</p>
            <div class="grid grid-cols-2 gap-3">
                <button type="button" onclick="document.querySelector('[data-tab-trigger=\'attendance\']').click()" class="flex flex-col items-center justify-center p-3 rounded-xl border border-red-100 bg-red-50/30 hover:bg-red-50 text-red-600 transition-all duration-200 group active:scale-95">
                    <i class="fa-solid fa-fingerprint text-xl mb-1 group-hover:scale-110 transition-transform"></i>
                    <span class="text-xs font-semibold">Chấm công</span>
                </button>
                <button type="button" onclick="document.querySelector('[data-tab-trigger=\'requests\']').click()" class="flex flex-col items-center justify-center p-3 rounded-xl border border-slate-100 bg-slate-50/50 hover:bg-slate-100 text-slate-700 transition-all duration-200 group active:scale-95">
                    <i class="fa-solid fa-file-signature text-xl mb-1 group-hover:scale-110 transition-transform"></i>
                    <span class="text-xs font-semibold">Gửi đơn từ</span>
                </button>
            </div>
        </div>

        <!-- Card Vi phạm của tôi gần đây -->
        <div class="employee-surface rounded-[2rem] border border-white/60 bg-white/90 backdrop-blur-xl p-5 shadow-lg flex-1">
            <div class="flex items-center justify-between mb-3">
                <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-slate-400">Vi phạm gần đây</p>
                <span class="inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-medium text-slate-600" id="homeViolationCount">0 vi phạm</span>
            </div>
            
            <div class="space-y-2.5 max-h-[160px] overflow-y-auto pr-1" id="homeViolationList">
                <div class="text-center py-6 text-slate-400">
                    <i class="fa-solid fa-circle-check text-2xl text-green-500 mb-2"></i>
                    <p class="text-xs">Không có vi phạm ghi nhận</p>
                </div>
            </div>
        </div>

        <!-- Card Khen Thưởng -->
        <div class="employee-surface rounded-[2rem] border border-white/60 bg-white/90 backdrop-blur-xl p-5 shadow-lg relative overflow-hidden group">
            <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-amber-200 blur-2xl opacity-40 group-hover:bg-amber-300 transition-all duration-500"></div>
            <div class="relative z-10">
                <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-amber-500 mb-3"><i class="fa-solid fa-trophy mr-1"></i>Vinh danh</p>
                <h4 class="font-outfit text-sm font-bold text-slate-800">Nhân viên xuất sắc tháng</h4>
                
                <div class="mt-4 flex items-center gap-3">
                    <div class="relative">
                        <img src="https://ui-avatars.com/api/?name=NV&background=f59e0b&color=fff&rounded=true&bold=true" alt="Avatar" class="h-10 w-10 rounded-full border-2 border-white shadow-sm" />
                        <span class="absolute -bottom-1 -right-1 flex h-4 w-4 items-center justify-center rounded-full bg-amber-500 border border-white text-[8px] text-white">
                            <i class="fa-solid fa-star"></i>
                        </span>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-slate-900">Trần Văn Khôi</p>
                        <p class="text-[10px] text-slate-500">Khối Vận hành • 3,200 Điểm</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
