                            <p class="text-sm font-semibold text-slate-700">Họp phòng chuyên môn</p>
                        </div>
                        <div class="flex items-center gap-4">
                            <span class="text-xs text-slate-400 font-medium">14:30 PM</span>
                            <span class="text-xs font-bold text-amber-500 min-w-[70px] text-right">Sắp đến hạn</span>
                        </div>
                    </div>

                    <!-- Task 3 -->
                    <div class="flex items-center justify-between p-4 rounded-xl border border-slate-100 bg-white hover:border-slate-200 transition shadow-sm">
                        <div class="flex items-center gap-3">
                            <span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span>
                            <p class="text-sm font-semibold text-slate-700">Chuẩn bị tài liệu dự án ABC</p>
                        </div>
                        <div class="flex items-center gap-4">
                            <span class="text-xs text-slate-400 font-medium">08:30 AM</span>
                            <span class="text-xs font-bold text-emerald-500 min-w-[70px] text-right">Hoàn thành</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Nhân viên xuất sắc -->
            <div class="saas-card overflow-hidden relative">
                <div class="absolute inset-0 bg-gradient-to-r from-slate-50 to-white z-0"></div>
                <!-- Optional background trophy watermark -->
