@{
    ViewData["Title"] = "Kích hoạt tài khoản Quản lý";
    Layout = "_Layout";
}

<div class="min-h-screen flex items-center justify-center bg-gradient-to-tr from-slate-900 via-red-950 to-slate-900 px-4 sm:px-6 lg:px-8 relative overflow-hidden py-12">
    <!-- Glowing circles -->
    <div class="absolute w-[500px] h-[500px] bg-red-500/20 rounded-full blur-[120px] -top-40 -left-40 animate-pulse"></div>
    <div class="absolute w-[400px] h-[400px] bg-rose-500/20 rounded-full blur-[100px] -bottom-40 -right-40 animate-pulse duration-5000"></div>

    <div class="max-w-md w-full space-y-6 bg-white p-8 rounded-3xl shadow-xl relative z-10 border border-red-100">
        <div class="text-center">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-red-50 text-red-600 mb-3 border border-red-100 shadow-sm">
                <i class="fa-solid fa-key text-2xl"></i>
            </div>
            <h2 class="font-outfit text-2xl font-extrabold tracking-tight text-zinc-900">Yêu cầu kích hoạt</h2>
            <p class="mt-1 text-sm text-zinc-500">Tài khoản quản lý của bạn cần được kích hoạt bằng khóa doanh nghiệp.</p>
        </div>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
        {
            <div class="bg-red-50 border border-red-100 text-red-800 text-sm rounded-xl p-4 flex items-start space-x-2">
                <i class="fa-solid fa-triangle-exclamation mt-0.5 text-red-500"></i>
                <div>
                    @foreach (var modelError in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p class="text-xs">@modelError.ErrorMessage</p>
                    }
                </div>
            </div>
        }

        <form asp-action="ActivateKey" method="post" class="space-y-5">
            <input type="hidden" name="username" value="@ViewBag.Username" />

            <div class="bg-zinc-50 border border-zinc-200 rounded-xl p-4 text-center">
                <span class="text-xs text-zinc-500">Tài khoản kích hoạt:</span>
                <p class="text-sm font-bold text-red-600 mt-0.5">@ViewBag.Username</p>
            </div>

            <div>
                <label for="key" class="block text-xs font-semibold text-zinc-700 mb-2">Khóa kích hoạt (Corporate Key)</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-zinc-400">
                        <i class="fa-solid fa-unlock-keyhole"></i>
                    </span>
                    <input type="password" id="key" name="key" required 
                           class="block w-full pl-10 pr-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent text-sm transition" 
                           placeholder="Nhập mã khóa doanh nghiệp..." />
                </div>
                <p class="text-[10px] text-zinc-500 mt-1.5">Mã mặc định khởi tạo là `hieudeptraivcl` nếu chưa được Admin thay đổi.</p>
            </div>

            <button type="submit" class="w-full py-3 px-4 bg-red-600 hover:bg-red-700 text-white rounded-xl text-sm font-semibold shadow-lg shadow-red-600/10 hover:-translate-y-0.5 transition duration-200">
                Xác thực & Kích hoạt
            </button>
        </form>

        <div class="border-t border-zinc-100 pt-6 text-center">
            <a asp-controller="Account" asp-action="Logout" class="text-xs font-semibold text-zinc-500 hover:text-zinc-900 transition">Quay lại Đăng nhập</a>
        </div>
    </div>
</div>
