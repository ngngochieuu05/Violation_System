<!DOCTYPE html>
<html lang="vi" class="h-full bg-slate-50">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ Thống Quản Lý Vi Phạm & Nhân Sự</title>
    
    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- CSS: Tailwind & Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }
        h1, h2, h3, h4, h5, h6, .font-outfit {
            font-family: 'Outfit', sans-serif;
        }
        /* Custom Glassmorphism */
        .glass-panel {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.25);
        }
        .glass-navbar {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }
    </style>
</head>
<body class="flex flex-col min-h-screen text-slate-800">

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- Header / Glassmorphic Navbar (Only show after login) -->
        <header class="sticky top-0 z-50">
            <nav class="glass-navbar py-3">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="flex items-center justify-between h-14">
                        <!-- Brand -->
                        <div class="flex items-center">
                            <a class="flex items-center space-x-2 text-red-600 hover:text-red-700 transition" asp-area="" asp-controller="Home" asp-action="Index">
                                <img src="~/images/logo/logo.png" alt="ComplianceHub Logo" class="h-10 w-10 rounded-lg object-contain" />
                                <span class="font-outfit font-extrabold text-xl tracking-tight text-slate-900">Compliance<span class="text-red-600">Hub</span></span>
                            </a>
                        </div>
                        
                        <!-- Navigation Menu -->
                        <div class="flex items-center space-x-6">
                            @if (User.IsInRole("Admin"))
                            {
                                <a class="text-sm font-medium text-slate-600 hover:text-red-600 transition flex items-center space-x-1" asp-area="" asp-controller="Violations" asp-action="Index">
                                    <i class="fa-solid fa-chart-line text-slate-400"></i>
                                    <span>Dashboard</span>
                                </a>
                                <a class="text-sm font-medium text-slate-600 hover:text-red-600 transition flex items-center space-x-1" asp-area="Admin" asp-controller="Admin" asp-action="Index">
                                    <i class="fa-solid fa-sliders text-slate-400"></i>
                                    <span>Cấu hình AI & Key</span>
                                </a>
                            }
                            <!-- Notification Bell -->
                            <button type="button" class="relative text-slate-500 hover:text-red-600 transition focus:outline-none">
                                <i class="fa-regular fa-bell text-xl"></i>
                                <span class="absolute top-0 right-0 flex h-2 w-2">
                                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                                    <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
                                </span>
                            </button>

                            <!-- User Avatar Dropdown -->
                            <div class="relative ml-4 border-l border-slate-200 pl-4" data-user-dropdown>
                                <button type="button" class="flex items-center focus:outline-none transition hover:opacity-80" data-dropdown-trigger>
                                    <div class="employee-avatar-placeholder relative flex h-10 w-10 items-center justify-center overflow-hidden rounded-full bg-red-50 text-red-600 ring-2 ring-white shadow-sm">
                                        <img data-avatar-image class="hidden absolute inset-0 h-full w-full object-cover z-10" alt="Avatar" />
                                        <i data-avatar-fallback class="fa-solid fa-user text-xl z-0"></i>
                                    </div>
                                </button>
                                
                                <div data-dropdown-menu class="absolute right-0 mt-2 w-56 origin-top-right rounded-2xl bg-white shadow-xl ring-1 ring-slate-200 hidden z-50">
                                    <div class="px-4 py-3 border-b border-slate-100">
                                        <p class="text-sm font-semibold text-slate-900 truncate" data-profile-name>@User.FindFirst("FullName")?.Value</p>
                                        <p class="text-xs text-slate-500 truncate uppercase font-bold tracking-wider">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
                                    </div>
                                    <div class="py-2">
                                        @if (User.IsInRole("Employee"))
                                        {
                                            <a href="/Employee?tab=profile" data-tab-trigger="profile" class="block px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-red-50 hover:text-red-600 transition-colors"><i class="fa-solid fa-id-badge mr-3 w-4 text-center"></i>Profile</a>
                                        }
                                    </div>
                                    <div class="border-t border-slate-100 py-2">
                                        <a asp-area="" asp-controller="Account" asp-action="Logout" class="block px-4 py-2.5 text-sm font-medium text-red-600 hover:bg-red-50 hover:text-red-700 transition-colors"><i class="fa-solid fa-right-from-bracket mr-3 w-4 text-center"></i>Đăng xuất</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </nav>
        </header>
    }

    <!-- Main Content Area -->
    <main class="flex-grow">
        @RenderBody()
    </main>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- Footer (Minimalist style, only show after login) -->
        <footer class="bg-white border-t border-slate-200 py-4 mt-12 text-slate-500 text-xs">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-2">
                <div>
                    &copy; 2026 - <span class="font-semibold text-slate-700">ComplianceHub App</span>. Môi trường làm việc an toàn & văn minh.
                </div>
                <div class="flex space-x-4">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="hover:text-slate-700 transition">Chính sách bảo mật</a>
                    <span>&bull;</span>

                    <span>Hỗ trợ kỹ thuật</span>
                </div>
            </div>
        </footer>
    }

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- User Dropdown Logic -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const dropdownContainer = document.querySelector('[data-user-dropdown]');
            if (dropdownContainer) {
                const trigger = dropdownContainer.querySelector('[data-dropdown-trigger]');
                const menu = dropdownContainer.querySelector('[data-dropdown-menu]');
                
                trigger.addEventListener('click', function(e) {
                    e.stopPropagation();
                    menu.classList.toggle('hidden');
                });
                
                document.addEventListener('click', function(e) {
                    if (!dropdownContainer.contains(e.target)) {
                        menu.classList.add('hidden');
                    }
                });
            }
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
