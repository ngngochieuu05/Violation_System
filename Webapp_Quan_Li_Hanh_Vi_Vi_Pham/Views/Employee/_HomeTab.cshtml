<section data-tab-panel="home" class="employee-tab-panel active">
    <!-- Hero Area -->
    <div class="mb-6 relative">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center">
            <div class="relative z-10 pt-4 pb-2">
                <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-1.5 text-xs font-bold text-slate-600 shadow-sm mb-4">
                    <i class="fa-solid fa-user-tie"></i> EMPLOYEE WORKSPACE
                </span>
                <div class="flex items-center flex-wrap gap-3">
                    <h1 class="text-3xl md:text-4xl font-outfit font-bold text-slate-900">
                        Xin chào, <span class="text-red-600" data-profile-name>@User.FindFirst("FullName")?.Value</span>
                    </h1>
                    <span class="inline-flex items-center gap-1.5 rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-sm font-bold text-amber-600 shadow-sm">
                        <i class="fa-solid fa-star"></i> 1,500
                    </span>
                </div>
                <p class="mt-2 text-slate-500">Chào mừng bạn đến với môi trường làm việc của mình.</p>
            </div>
            
            <!-- Illustration Placeholder (Optional) -->
            <div class="hidden md:block absolute right-0 top-0 w-64 h-40 opacity-80 pointer-events-none" style="background-image: radial-gradient(circle at center, #fee2e2 0%, transparent 60%);">
                <!-- Nơi đây có thể chèn ảnh minh họa vẫy tay -->
            </div>
        </div>
    </div>

    <!-- 4 Stats Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <!-- Card 1 -->
        <div class="saas-card p-4 flex items-center gap-4">
            <div class="w-12 h-12 rounded-2xl bg-red-50 text-red-500 flex items-center justify-center shrink-0">
                <i class="fa-solid fa-user text-xl"></i>
            </div>
            <div>
                <p class="text-xs text-slate-500 mb-0.5 font-medium">Vai trò</p>
                <p class="text-sm font-bold text-slate-900">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
            </div>
        </div>
        
        <!-- Card 2 -->
        <div class="saas-card p-4 flex items-center gap-4">
            <div class="w-12 h-12 rounded-2xl bg-emerald-50 text-emerald-500 flex items-center justify-center shrink-0">
                <i class="fa-solid fa-fingerprint text-xl"></i>
            </div>
            <div>
                <p class="text-xs text-slate-500 mb-0.5 font-medium">Trạng thái</p>
                <div class="flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                    <p class="text-sm font-bold text-slate-900">Online</p>
                </div>
            </div>
        </div>

        <!-- Card 3 -->
        <div class="saas-card p-4 flex items-center gap-4">
            <div class="w-12 h-12 rounded-2xl bg-blue-50 text-blue-500 flex items-center justify-center shrink-0">
                <i class="fa-regular fa-calendar text-xl"></i>
            </div>
            <div>
                <p class="text-xs text-slate-500 mb-0.5 font-medium">Ngày</p>
                <p class="text-sm font-bold text-slate-900" id="currentDateDisplay">--/--/----</p>
            </div>
        </div>

        <!-- Card 4 -->
        <div class="saas-card p-4 flex items-center gap-4">
            <div class="w-12 h-12 rounded-2xl bg-purple-50 text-purple-500 flex items-center justify-center shrink-0">
                <i class="fa-regular fa-clock text-xl"></i>
            </div>
            <div>
                <p class="text-xs text-slate-500 mb-0.5 font-medium">Giờ hiện tại</p>
                <p class="text-sm font-bold text-slate-900 font-mono" id="currentTimeDisplay">--:--:--</p>
            </div>
        </div>
    </div>

    <!-- Main Grid Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        
        <!-- Left Column -->
        <div class="lg:col-span-7 xl:col-span-8 flex flex-col gap-6">
            
            <!-- Nhiệm vụ cần hoàn thiện -->
            <div class="saas-card p-6 flex-1">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="saas-heading text-lg flex items-center gap-2">
                        <i class="fa-regular fa-clipboard text-red-600"></i> Nhiệm vụ cần hoàn thiện
                    </h3>
                    <a href="#" data-tab-trigger="schedule" class="text-sm font-bold text-red-600 hover:underline">Chi tiết &rarr;</a>
                </div>

                <div class="space-y-4">
                    <!-- Task 1 -->
                    <div class="flex items-center justify-between p-4 rounded-xl border border-slate-100 bg-white hover:border-slate-200 transition shadow-sm">
                        <div class="flex items-center gap-3">
                            <span class="w-2.5 h-2.5 rounded-full bg-red-500"></span>
                            <p class="text-sm font-semibold text-slate-700">Cập nhật báo cáo KPI tháng</p>
                        </div>
                        <div class="flex items-center gap-4">
                            <span class="text-xs text-slate-400 font-medium">10:00 AM</span>
                            <span class="text-xs font-bold text-red-500 min-w-[70px] text-right">Quá hạn</span>
                        </div>
                    </div>
                    
                    <!-- Task 2 -->
                    <div class="flex items-center justify-between p-4 rounded-xl border border-slate-100 bg-white hover:border-slate-200 transition shadow-sm">
                        <div class="flex items-center gap-3">
