@model Webapp_Quan_Li_Hanh_Vi_Vi_Pham.Models.Entities.ModelSetting
@{
    ViewData["Title"] = "Cấu hình AI & Quản lý Key";
    Layout = "_AdminLayout";
    var managers = ViewBag.Managers as List<Webapp_Quan_Li_Hanh_Vi_Vi_Pham.Models.Entities.User> ?? new List<Webapp_Quan_Li_Hanh_Vi_Vi_Pham.Models.Entities.User>();
    var aiModels = ViewBag.AiModels as List<Webapp_Quan_Li_Hanh_Vi_Vi_Pham.Models.Entities.AiModel> ?? new List<Webapp_Quan_Li_Hanh_Vi_Vi_Pham.Models.Entities.AiModel>();
}

<style>
    .theme-accent-bg {
        background-color: #dc2626 !important;
    }
    .theme-accent-text {
        color: #dc2626 !important;
    }
    .theme-accent-border {
        border-color: #fca5a5 !important;
    }
    .theme-light-bg {
        background-color: #fef2f2 !important;
    }
</style>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-8">
    <!-- Page Header -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between border-b border-red-100 pb-6 gap-4">
        <div class="flex items-center gap-3">
            <div class="bg-red-600 rounded-lg flex items-center justify-center shadow-sm" style="width: 44px; height: 44px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><path d="M12 8v4" /><path d="M12 16h.01" /></svg>
            </div>
            <div>
                <h1 class="font-outfit text-3xl font-extrabold text-zinc-900 tracking-tight">Compliance<span class="text-red-600">Hub</span> Admin</h1>
                <p class="text-sm text-zinc-500 mt-0.5">Bảng cấu hình quản trị hệ thống, quản lý mô hình AI & mã kích hoạt doanh nghiệp.</p>
            </div>
        </div>
        <div class="text-zinc-400 text-xs">
            Phiên bản hiện tại: <span class="font-semibold text-zinc-700">v3.0-stable</span>
        </div>
    </div>

    <!-- Feedback messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-red-50 border border-red-200 text-red-800 text-sm rounded-xl p-4 flex items-center space-x-2 shadow-sm">
            <i class="fa-solid fa-circle-check text-red-600 text-base"></i>
            <p class="font-medium">@TempData["SuccessMessage"]</p>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 border border-red-200 text-red-800 text-sm rounded-xl p-4 flex items-center space-x-2 shadow-sm">
            <i class="fa-solid fa-triangle-exclamation text-red-500 text-base"></i>
            <p class="font-medium">@TempData["ErrorMessage"]</p>
        </div>
    }

    <!-- Tabs and Content Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left Side: YOLO & DeepFace models list (Dynamic) -->
        <div class="lg:col-span-2 space-y-6">
            <!-- YOLO models panel -->
            <div class="bg-white rounded-2xl border border-red-100 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-red-50 bg-red-50/20 flex items-center justify-between">
                    <div class="flex items-center space-x-2">
                        <i class="fa-solid fa-camera text-red-600 text-lg"></i>
                        <h3 class="font-outfit font-bold text-zinc-900 text-lg">Mô hình Nhận diện Vi phạm (YOLO)</h3>
                    </div>
                    <!-- Add model trigger button -->
                    <button class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-xl text-xs font-semibold shadow transition-colors flex items-center gap-1.5"
                            data-bs-toggle="modal" data-bs-target="#addYoloModelModal">
                        <i class="fa-solid fa-plus"></i>
                        <span>Thêm mô hình YOLO</span>
                    </button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse text-sm">
                        <thead>
                            <tr class="bg-zinc-50 border-b border-red-50 text-zinc-400 text-xs font-bold uppercase tracking-wider">
                                <th class="p-4 pl-6">Tên mô hình</th>
                                <th class="p-4">Loại hành vi</th>
                                <th class="p-4">Đường dẫn tệp (.pt)</th>
                                <th class="p-4 text-center">Ngưỡng (Conf / IoU)</th>
                                <th class="p-4 text-center">Trạng thái</th>
                                <th class="p-4 pr-6 text-right">Hành động</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-zinc-100">
                            @{
                                var yoloModels = aiModels.Where(m => m.Type.StartsWith("Yolo")).ToList();
                            }
                            @if (!yoloModels.Any())
                            {
                                <tr>
                                    <td colspan="6" class="p-6 text-center text-zinc-400">Không có mô hình YOLO nào được cấu hình.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var modelItem in yoloModels)
                                {
                                    <tr class="hover:bg-red-50/10 transition">
                                        <td class="p-4 pl-6">
                                            <div class="font-bold text-zinc-900">@modelItem.Name</div>
                                            <div class="text-[10px] text-zinc-400">Thêm ngày: @modelItem.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</div>
                                        </td>
                                        <td class="p-4">
                                            @if (modelItem.Type == "YoloSmoking")
                                            {
                                                <span class="px-2 py-0.5 bg-red-50 text-red-700 text-[10px] font-bold rounded-full border border-red-100 uppercase">Hút thuốc</span>
                                            }
                                            else if (modelItem.Type == "YoloLeaving")
                                            {
                                                <span class="px-2 py-0.5 bg-orange-50 text-orange-700 text-[10px] font-bold rounded-full border border-orange-100 uppercase">Rời vị trí</span>
                                            }
                                        </td>
                                        <td class="p-4 font-mono text-xs text-zinc-500 max-w-[150px] truncate" title="@modelItem.ModelPath">
                                            @modelItem.ModelPath
                                        </td>
                                        <td class="p-4 text-center">
                                            <div class="font-semibold text-zinc-800 text-xs">Conf: @modelItem.ConfThreshold.ToString("0.00")</div>
                                            <div class="text-[10px] text-zinc-400">IoU: @modelItem.IouThreshold.ToString("0.00")</div>
                                        </td>
                                        <td class="p-4 text-center">
                                            @if (modelItem.IsActive)
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700 border border-emerald-100">
                                                    Hoạt động
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-zinc-100 text-zinc-500">
                                                    Tắt
                                                </span>
                                            }
                                        </td>
                                        <td class="p-4 pr-6 text-right">
                                            <div class="flex items-center justify-end space-x-2">
                                                <!-- Toggle form -->
                                                <form asp-action="ToggleAiModel" method="post" class="inline">
                                                    <input type="hidden" name="id" value="@modelItem.Id" />
                                                    <button type="submit" class="px-2.5 py-1.5 @(modelItem.IsActive ? "bg-zinc-100 text-zinc-600 hover:bg-zinc-200" : "bg-red-50 text-red-700 hover:bg-red-100") border border-transparent rounded-lg text-xs font-semibold transition">
                                                        @(modelItem.IsActive ? "Tắt" : "Bật")
                                                    </button>
                                                </form>

                                                <!-- Edit button -->
                                                <button type="button" class="p-1.5 text-zinc-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition"
                                                        data-bs-toggle="modal" data-bs-target="#editAiModelModal"
                                                        data-id="@modelItem.Id"
                                                        data-name="@modelItem.Name"
                                                        data-type="@modelItem.Type"
                                                        data-modelpath="@modelItem.ModelPath"
                                                        data-conf="@modelItem.ConfThreshold.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)"
                                                        data-iou="@modelItem.IouThreshold.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)"
                                                        title="Hiệu chỉnh">
                                                    <i class="fa-solid fa-pen-to-square"></i>
                                                </button>

                                                <!-- Delete form -->
                                                @if (!modelItem.IsActive)
                                                {
                                                    <form asp-action="DeleteAiModel" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa mô hình này?')" class="inline">
                                                        <input type="hidden" name="id" value="@modelItem.Id" />
                                                        <button type="submit" class="p-1.5 text-zinc-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition" title="Xóa mô hình">
                                                            <i class="fa-solid fa-trash"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- DeepFace models panel -->
            <div class="bg-white rounded-2xl border border-red-100 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-red-50 bg-red-50/20 flex items-center justify-between">
                    <div class="flex items-center space-x-2">
                        <i class="fa-solid fa-face-smile text-red-600 text-lg"></i>
                        <h3 class="font-outfit font-bold text-zinc-900 text-lg">Nhận diện Sinh trắc học (DeepFace)</h3>
                    </div>
                    <!-- Add model trigger button -->
                    <button class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-xl text-xs font-semibold shadow transition-colors flex items-center gap-1.5"
                            data-bs-toggle="modal" data-bs-target="#addDeepfaceModelModal">
                        <i class="fa-solid fa-plus"></i>
                        <span>Thêm mô hình DeepFace</span>
                    </button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse text-sm">
                        <thead>
                            <tr class="bg-zinc-50 border-b border-red-50 text-zinc-400 text-xs font-bold uppercase tracking-wider">
                                <th class="p-4 pl-6">Tên mô hình</th>
                                <th class="p-4">Kiến trúc (Model)</th>
                                <th class="p-4 text-center">Ngưỡng khoảng cách (Distance)</th>
                                <th class="p-4 text-center">Trạng thái</th>
                                <th class="p-4 pr-6 text-right">Hành động</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-zinc-100">
                            @{
                                var deepfaceModels = aiModels.Where(m => m.Type == "Deepface").ToList();
                            }
                            @if (!deepfaceModels.Any())
                            {
                                <tr>
                                    <td colspan="5" class="p-6 text-center text-zinc-400">Không có mô hình DeepFace nào được cấu hình.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var modelItem in deepfaceModels)
                                {
                                    <tr class="hover:bg-red-50/10 transition">
                                        <td class="p-4 pl-6">
                                            <div class="font-bold text-zinc-900">@modelItem.Name</div>
                                            <div class="text-[10px] text-zinc-400">Thêm ngày: @modelItem.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</div>
                                        </td>
                                        <td class="p-4 font-mono text-xs text-zinc-500">
                                            @modelItem.ModelPath
                                        </td>
                                        <td class="p-4 text-center">
                                            <div class="font-semibold text-zinc-800 text-xs">Threshold: @modelItem.ConfThreshold.ToString("0.00")</div>
                                        </td>
                                        <td class="p-4 text-center">
                                            @if (modelItem.IsActive)
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700 border border-emerald-100">
                                                    Hoạt động
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-zinc-100 text-zinc-500">
                                                    Tắt
                                                </span>
                                            }
                                        </td>
                                        <td class="p-4 pr-6 text-right">
                                            <div class="flex items-center justify-end space-x-2">
                                                <!-- Toggle form -->
                                                <form asp-action="ToggleAiModel" method="post" class="inline">
                                                    <input type="hidden" name="id" value="@modelItem.Id" />
                                                    <button type="submit" class="px-2.5 py-1.5 @(modelItem.IsActive ? "bg-zinc-100 text-zinc-600 hover:bg-zinc-200" : "bg-red-50 text-red-700 hover:bg-red-100") border border-transparent rounded-lg text-xs font-semibold transition">
                                                        @(modelItem.IsActive ? "Tắt" : "Bật")
                                                    </button>
                                                </form>

                                                <!-- Edit button -->
                                                <button type="button" class="p-1.5 text-zinc-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition"
                                                        data-bs-toggle="modal" data-bs-target="#editAiModelModal"
                                                        data-id="@modelItem.Id"
                                                        data-name="@modelItem.Name"
                                                        data-type="@modelItem.Type"
                                                        data-modelpath="@modelItem.ModelPath"
                                                        data-conf="@modelItem.ConfThreshold.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)"
                                                        data-iou="@modelItem.IouThreshold.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)"
                                                        title="Hiệu chỉnh">
                                                    <i class="fa-solid fa-pen-to-square"></i>
                                                </button>

                                                <!-- Delete form -->
                                                @if (!modelItem.IsActive)
                                                {
                                                    <form asp-action="DeleteAiModel" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa mô hình này?')" class="inline">
                                                        <input type="hidden" name="id" value="@modelItem.Id" />
                                                        <button type="submit" class="p-1.5 text-zinc-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition" title="Xóa mô hình">
                                                            <i class="fa-solid fa-trash"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Side: Enterprise Key / Manager List -->
        <div class="lg:col-span-1 space-y-6">
            <div class="bg-white rounded-2xl border border-red-100 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-red-50 bg-red-50/20">
                    <h3 class="font-outfit font-bold text-zinc-900 flex items-center space-x-2">
                        <i class="fa-solid fa-building-user text-red-600"></i>
                        <span>Quản lý Khóa Doanh nghiệp</span>
                    </h3>
                    <p class="text-xs text-zinc-500 mt-0.5">Mã kích hoạt cho tài khoản Manager.</p>
                </div>

                <div class="p-6 divide-y divide-zinc-100 space-y-4">
                    @if (!managers.Any())
                    {
                        <p class="text-sm text-zinc-400 text-center py-4">Không tìm thấy tài khoản quản lý nào.</p>
                    }
                    else
                    {
                        @foreach (var mgr in managers)
                        {
                            <div class="pt-4 first:pt-0 flex flex-col space-y-3">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <div class="font-bold text-zinc-900 text-sm">@mgr.FullName</div>
                                        <div class="text-xs text-zinc-400">@@@mgr.Username</div>
                                    </div>
                                    <div>
                                        @if (mgr.IsKeyActivated)
                                        {
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-50 text-emerald-700 border border-emerald-100">
                                                Đã kích hoạt
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-amber-50 text-amber-700 border border-amber-100">
                                                Chờ nhập
                                            </span>
                                        }
                                    </div>
                                </div>

                                <div class="flex items-center justify-between gap-2 bg-zinc-50 p-2.5 rounded-xl border border-zinc-100">
                                    <form asp-action="UpdateManagerKey" method="post" class="flex items-center justify-between w-full">
                                        <input type="hidden" name="managerId" value="@mgr.Id" />
                                        <input type="text" name="newKey" value="@mgr.ManagerKey" required
                                               class="bg-white border border-zinc-200 rounded-lg text-zinc-800 text-xs px-2 py-1 w-2/3 focus:outline-none focus:ring-1 focus:ring-red-500" />
                                        <button type="submit" class="px-2.5 py-1 bg-red-600 text-white rounded-lg text-[11px] font-semibold hover:bg-red-700 transition" title="Lưu Key">
                                            Lưu Key
                                        </button>
                                    </form>
                                </div>

                                @if (mgr.IsKeyActivated)
                                {
                                    <form asp-action="ResetManagerActivation" method="post" onsubmit="return confirm('Bạn có chắc muốn Reset trạng thái kích hoạt?')" class="text-right">
                                        <input type="hidden" name="managerId" value="@mgr.Id" />
                                        <button type="submit" class="text-[10px] text-red-600 hover:underline">
                                            Reset Activation
                                        </button>
                                    </form>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Thêm mô hình YOLO -->
<div class="modal fade" id="addYoloModelModal" tabindex="-1" aria-labelledby="addYoloModelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-2xl rounded-3xl overflow-hidden">
            <div class="modal-header border-b border-zinc-100 bg-red-600 text-white p-5">
                <h5 class="modal-title font-outfit font-extrabold text-lg flex items-center gap-2" id="addYoloModelModalLabel">
                    <i class="fa-solid fa-plus-circle"></i>
                    <span>Thêm mô hình YOLO mới</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AddAiModel" method="post">
                <div class="modal-body p-6 space-y-4">
                    <div>
                        <label for="yolo_name" class="block text-xs font-semibold text-zinc-700 mb-1.5">Tên mô hình</label>
                        <input type="text" id="yolo_name" name="name" required placeholder="Ví dụ: YOLO Hút thuốc v2"
                               class="block w-full px-3.5 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" />
                    </div>

                    <div>
                        <label for="yolo_type" class="block text-xs font-semibold text-zinc-700 mb-1.5">Loại vi phạm</label>
                        <select id="yolo_type" name="type" required
                                class="block w-full px-3.5 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition">
                            <option value="YoloSmoking">Nhận diện Hút thuốc (YOLO)</option>
                            <option value="YoloLeaving">Nhận diện Rời vị trí làm việc (YOLO)</option>
                        </select>
                    </div>

                    <div>
                        <label for="yolo_modelPath" class="block text-xs font-semibold text-zinc-700 mb-1.5">Đường dẫn tệp mô hình (.pt)</label>
                        <input type="text" id="yolo_modelPath" name="modelPath" required placeholder="Ví dụ: ML/weights/smoking.pt"
                               class="block w-full px-3.5 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="yolo_confThreshold" class="block text-xs font-semibold text-zinc-700 mb-1.5">Ngưỡng Conf (0 - 1)</label>
                            <input type="number" step="0.01" min="0" max="1" id="yolo_confThreshold" name="confThreshold" value="0.25" required
                                   class="block w-full px-3.5 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" />
                        </div>
                        <div>
                            <label for="yolo_iouThreshold" class="block text-xs font-semibold text-zinc-700 mb-1.5">Ngưỡng IoU (0 - 1)</label>
                            <input type="number" step="0.01" min="0" max="1" id="yolo_iouThreshold" name="iouThreshold" value="0.45" required
                                   class="block w-full px-3.5 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-t border-zinc-100 p-4 flex justify-end gap-2 bg-zinc-50">
                    <button type="button" class="px-4 py-2 border border-zinc-200 text-zinc-700 rounded-xl text-xs font-semibold hover:bg-zinc-100 transition" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="px-5 py-2 bg-red-600 hover:bg-red-700 text-white rounded-xl text-xs font-semibold shadow transition">Lưu mô hình</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Thêm mô hình DeepFace -->
<div class="modal fade" id="addDeepfaceModelModal" tabindex="-1" aria-labelledby="addDeepfaceModelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-2xl rounded-3xl overflow-hidden">
            <div class="modal-header border-b border-zinc-100 bg-red-600 text-white p-5">
                <h5 class="modal-title font-outfit font-extrabold text-lg flex items-center gap-2" id="addDeepfaceModelModalLabel">
                    <i class="fa-solid fa-plus-circle"></i>
                    <span>Thêm mô hình DeepFace mới</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AddAiModel" method="post">
                <input type="hidden" name="type" value="Deepface" />
                <input type="hidden" name="iouThreshold" value="0.00" />
                <div class="modal-body p-6 space-y-4">
                    <div>
                        <label for="df_name" class="block text-xs font-semibold text-zinc-700 mb-1.5">Tên mô hình</label>
                        <input type="text" id="df_name" name="name" required placeholder="Ví dụ: Face Net hoặc VGG-Face"
                               class="block w-full px-3.5 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" />
                    </div>

                    <div>
                        <label for="df_modelPath" class="block text-xs font-semibold text-zinc-700 mb-1.5">Kiến trúc nhận dạng (Model Name)</label>
                        <select id="df_modelPath" name="modelPath" required
                                class="block w-full px-3.5 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition">
                            <option value="ArcFace">ArcFace (Đề xuất)</option>
                            <option value="VGG-Face">VGG-Face</option>
                            <option value="Facenet">Facenet</option>
                            <option value="Facenet512">Facenet512</option>
                            <option value="OpenFace">OpenFace</option>
                            <option value="DeepFace">DeepFace</option>
                            <option value="SFace">SFace</option>
                        </select>
                    </div>

                    <div>
                        <label for="df_confThreshold" class="block text-xs font-semibold text-zinc-700 mb-1.5">Ngưỡng Khoảng cách (Cosine Distance, mặc định 0.40)</label>
                        <input type="number" step="0.01" min="0" max="1" id="df_confThreshold" name="confThreshold" value="0.40" required
                               class="block w-full px-3.5 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" />
                    </div>
                </div>
                <div class="modal-footer border-t border-zinc-100 p-4 flex justify-end gap-2 bg-zinc-50">
                    <button type="button" class="px-4 py-2 border border-zinc-200 text-zinc-700 rounded-xl text-xs font-semibold hover:bg-zinc-100 transition" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="px-5 py-2 bg-red-600 hover:bg-red-700 text-white rounded-xl text-xs font-semibold shadow transition">Lưu mô hình</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Chỉnh sửa mô hình AI -->
<div class="modal fade" id="editAiModelModal" tabindex="-1" aria-labelledby="editAiModelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-2xl rounded-3xl overflow-hidden">
            <div class="modal-header border-b border-zinc-100 bg-red-600 text-white p-5">
                <h5 class="modal-title font-outfit font-extrabold text-lg flex items-center gap-2" id="editAiModelModalLabel">
                    <i class="fa-solid fa-pen-to-square"></i>
                    <span>Hiệu chỉnh thông số mô hình</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="EditAiModel" method="post">
                <input type="hidden" id="edit_id" name="id" />
                <div class="modal-body p-6 space-y-4">
                    <div>
                        <label for="edit_name" class="block text-xs font-semibold text-zinc-700 mb-1.5">Tên mô hình</label>
                        <input type="text" id="edit_name" name="name" required
                               class="block w-full px-3.5 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" />
                    </div>

                    <!-- Div for YOLO model path -->
                    <div id="edit_yolo_path_container">
                        <label for="edit_yolo_modelPath" class="block text-xs font-semibold text-zinc-700 mb-1.5">Đường dẫn tệp mô hình (.pt)</label>
                        <input type="text" id="edit_yolo_modelPath"
                               class="block w-full px-3.5 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" />
                    </div>

                    <!-- Div for DeepFace model option -->
                    <div id="edit_df_path_container" class="hidden">
                        <label for="edit_df_modelPath" class="block text-xs font-semibold text-zinc-700 mb-1.5">Kiến trúc nhận dạng (Model Name)</label>
                        <select id="edit_df_modelPath" class="block w-full px-3.5 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition">
                            <option value="ArcFace">ArcFace (Đề xuất)</option>
                            <option value="VGG-Face">VGG-Face</option>
                            <option value="Facenet">Facenet</option>
                            <option value="Facenet512">Facenet512</option>
                            <option value="OpenFace">OpenFace</option>
                            <option value="DeepFace">DeepFace</option>
                            <option value="SFace">SFace</option>
                        </select>
                    </div>

                    <!-- Hidden input that actually submits modelPath -->
                    <input type="hidden" id="edit_modelPath" name="modelPath" />

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label id="edit_conf_label" for="edit_confThreshold" class="block text-xs font-semibold text-zinc-700 mb-1.5">Ngưỡng Conf (0 - 1)</label>
                            <input type="number" step="0.01" min="0" max="1" id="edit_confThreshold" name="confThreshold" required
                                   class="block w-full px-3.5 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" />
                        </div>
                        <div id="edit_iou_container">
                            <label for="edit_iouThreshold" class="block text-xs font-semibold text-zinc-700 mb-1.5">Ngưỡng IoU (0 - 1)</label>
                            <input type="number" step="0.01" min="0" max="1" id="edit_iouThreshold" name="iouThreshold" required
                                   class="block w-full px-3.5 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-800 focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-t border-zinc-100 p-4 flex justify-end gap-2 bg-zinc-50">
                    <button type="button" class="px-4 py-2 border border-zinc-200 text-zinc-700 rounded-xl text-xs font-semibold hover:bg-zinc-100 transition" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="px-5 py-2 bg-red-600 hover:bg-red-700 text-white rounded-xl text-xs font-semibold shadow transition">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Handling Edit Modal population
            const editModal = document.getElementById('editAiModelModal');
            if (editModal) {
                editModal.addEventListener('show.bs.modal', function (event) {
                    const button = event.relatedTarget;
                    const id = button.getAttribute('data-id');
                    const name = button.getAttribute('data-name');
                    const type = button.getAttribute('data-type');
                    const modelPath = button.getAttribute('data-modelpath');
                    const conf = button.getAttribute('data-conf');
                    const iou = button.getAttribute('data-iou');

                    // Set simple fields
                    document.getElementById('edit_id').value = id;
                    document.getElementById('edit_name').value = name;
                    document.getElementById('edit_confThreshold').value = conf;
                    document.getElementById('edit_iouThreshold').value = iou;
                    document.getElementById('edit_modelPath').value = modelPath;

                    // Configure based on type
                    if (type === 'Deepface') {
                        document.getElementById('edit_yolo_path_container').classList.add('hidden');
                        document.getElementById('edit_df_path_container').classList.remove('hidden');
                        document.getElementById('edit_iou_container').classList.add('hidden');
                        document.getElementById('edit_conf_label').innerText = 'Ngưỡng Khoảng cách (Distance)';
                        document.getElementById('edit_iouThreshold').value = "0.00";
                        
                        // Select value in dropdown
                        document.getElementById('edit_df_modelPath').value = modelPath;
                    } else {
                        document.getElementById('edit_yolo_path_container').classList.remove('hidden');
                        document.getElementById('edit_df_path_container').classList.add('hidden');
                        document.getElementById('edit_iou_container').classList.remove('hidden');
                        document.getElementById('edit_conf_label').innerText = 'Ngưỡng Conf (0 - 1)';
                        document.getElementById('edit_yolo_modelPath').value = modelPath;
                    }
                });

                // Sync dropdown / input back to hidden modelPath before form submit
                const form = editModal.querySelector('form');
                form.addEventListener('submit', function () {
                    const yoloContainer = document.getElementById('edit_yolo_path_container');
                    if (yoloContainer.classList.contains('hidden')) {
                        // It is DeepFace, take value from dropdown
                        document.getElementById('edit_modelPath').value = document.getElementById('edit_df_modelPath').value;
                    } else {
                        // It is YOLO, take value from input
                        document.getElementById('edit_modelPath').value = document.getElementById('edit_yolo_modelPath').value;
                    }
                });
            }
        });
    </script>
}
